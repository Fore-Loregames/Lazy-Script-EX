      "    socket.send_text(\"${3:hello}\",0)",
      "    local reply = socket.receive(${4:4096},0)",
      "    $0",
      "    reply.destroy()",
      "    socket.close()",
      "end",
      "socket.destroy()",
      "Sockets.cleanup()"
    ],
    "description": "Connect and exchange typed data through native WinSock2 TCP"
