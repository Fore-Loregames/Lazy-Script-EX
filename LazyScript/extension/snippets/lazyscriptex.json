  "Deep JSON file traversal": {
    "prefix": "lsx-json-traverse",
    "body": [
      "use \"@LazyScript/bindings/Data/Json.lsx\" as Json",
      "",
      "local document = Json.load(\"${1:assets/data.json}\")",
      "if not document.valid then return 1 end",
      "local array = document.get(document.root,\"${2:items}\")",
      "local index = 0",
      "while index < document.count(array) do",
      "    local item = document.at(array,index)",
      "    console.write_line(document.get_string(item,\"${3:name}\",\"unnamed\"))",
      "    index = index + 1",
      "end",
      "$0",
      "document.destroy()"
    ],
    "description": "Load a real JSON asset and traverse an array with a while loop"
  },
