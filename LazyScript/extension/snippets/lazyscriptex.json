  "FreeType SDF font": {
    "prefix": "lsx-sdf-font",
    "body": [
      "use \"@LazyScript/bindings/Text/Font.lsx\" as Font",
      "",
      "local face = Font.system(\"${1:Segoe UI}\",${2:64})",
      "if not face.valid() then",
      "    console.error_line(face.error())",
      "    return 1",
      "end",
      "local atlas = Font.create_ascii_atlas(face)",
      "if not atlas.valid() then",
      "    console.error_line(atlas.error())",
      "    face.destroy()",
      "    return 1",
      "end",
      "local texture = Font.upload_atlas(atlas)",
      "if not texture.valid() then",
      "    console.error_line(texture.error())",
      "    atlas.destroy()",
      "    face.destroy()",
      "    return 1",
      "end",
      "local mesh = Font.build_text(face,atlas,\"${3:Hello LSX}\",${4:24},${5:24},${6:1})",
      "if not mesh.valid() then return 1 end",
      "$0",
      "mesh.destroy()",
      "texture.destroy()",
      "atlas.destroy()",
      "face.destroy()"
    ],
    "description": "Build and upload a FreeType SDF atlas and one batched text mesh"
  },
