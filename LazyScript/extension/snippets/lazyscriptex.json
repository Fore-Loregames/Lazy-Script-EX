    ],
    "description": "Create a Vulkan LSG window without exposing Vulkan device or swapchain calls"
  },
  "LSG multiple windows": {
    "prefix": "lsx-multiple-windows",
    "body": [
      "use \"@LazyScript/LSG.lsx\" as LSG",
      "",
      "fn main()",
      "    LSG.use_vulkan()",
      "    local first = LSG.open(\"${1:Window A}\", ${2:640}, ${3:400})",
      "    local second = LSG.open(\"${4:Window B}\", ${5:640}, ${6:400})",
      "    if not first.ready() then return LSG.show_error(first.error()) end",
      "    if not second.ready() then return LSG.show_error(second.error()) end",
      "    first.set_vsync(false)",
      "    second.set_vsync(false)",
      "",
      "    while first.running() and second.running() do",
      "        first.activate()",
      "        first.begin(${7:0.20}, ${8:0.04}, ${9:0.06})",
      "        first.end()",
      "",
      "        second.activate()",
      "        second.begin(${10:0.03}, ${11:0.08}, ${12:0.22})",
      "        second.end()",
      "    end",
      "",
      "    second.destroy()",
      "    first.destroy()",
      "    return 0",
      "end"
    ],
    "description": "Render independent LSG windows through activate(), begin(), and end()"
  },
  "Static LSG window manager": {
    "prefix": "lsx-window-manager",
    "body": [
      "use \"@LazyScript/LSG.lsx\" as LSG",
      "",
      "export static const ${1:WindowManager} = {",
      "    windowHandle = null",
      "    title = \"\"",
      "",
      "    CreateWindow = fn(title, width, height)",
      "        self.title = title",
      "        self.windowHandle = LSG.open(title, width, height)",
      "        if not self.windowHandle.ready() then",
      "            return LSG.show_error(self.windowHandle.error())",
      "        end",
      "        self.windowHandle.set_vsync(false)",
      "        return self.windowHandle",
      "    end",
      "",
      "    BeginDrawing = fn(red, green, blue)",
      "        self.windowHandle.begin(red, green, blue)",
      "    end",
      "",
      "    EndDrawing = fn()",
      "        self.windowHandle.end()",
      "    end",
      "",
      "    Shutdown = fn()",
      "        if self.windowHandle ~= null then",
      "            self.windowHandle.destroy()",
      "            self.windowHandle = null",
      "        end",
      "    end",
      "}",
      "$0"
    ],
    "description": "Create a shared front-end LSG window manager whose null field gains the concrete Window API after LSG.open()"
  },
  "Native GLFW game project": {
    "prefix": "lsx-game",
    "body": [
      "use \"@LazyScript/bindings/GLFW/GLFW.lsx\" as GLFW",
      "use \"@LazyScript/bindings/OpenGL/OpenGL46.lsx\" as GL",
      "",
      "fn main()",
      "    if GLFW.lsxLoadLibraries() < 1 or GLFW.glfwInit() == 0 then return 1 end",
      "    GLFW.glfwWindowHint(GLFW.GLFW_CONTEXT_VERSION_MAJOR, 4)",
      "    GLFW.glfwWindowHint(GLFW.GLFW_CONTEXT_VERSION_MINOR, 6)",
      "    GLFW.glfwWindowHint(GLFW.GLFW_OPENGL_PROFILE, GLFW.GLFW_OPENGL_CORE_PROFILE)",
      "    local window = GLFW.glfwCreateWindow(1280, 720, \"${1:My LSX Game}\", 0, 0)",
      "    if window == 0 then return 1 end",
      "    GLFW.glfwMakeContextCurrent(window)",
      "    GL.lsxLoadOpenGL()",
      "    local framebuffer = GLFW.FramebufferSize.new()",
      "    while GLFW.glfwWindowShouldClose(window) == 0 do",
      "        framebuffer.refresh(window)",
      "        GL.glViewport(0, 0, framebuffer.width, framebuffer.height)",
      "        GL.glClearColor(${2:0.03}, ${3:0.04}, ${4:0.07}, 1.0)",
      "        GL.glClear(GL.GL_COLOR_BUFFER_BIT)",
      "        GLFW.glfwSwapBuffers(window)",
      "        GLFW.glfwPollEvents()",
      "    end",
      "    framebuffer.destroy()",
      "    GLFW.glfwDestroyWindow(window)",
      "    GLFW.glfwTerminate()",
      "    GLFW.lsxUnloadLibraries()",
      "    return 0",
      "end"
    ],
    "description": "Complete GLFW/OpenGL LSX entry point without per-frame output allocations"
  },
  "Reusable framebuffer size": {
    "prefix": "glfw-framebuffer-size",
    "body": [
      "local framebuffer = GLFW.FramebufferSize.new()",
      "framebuffer.refresh(window)",
      "GL.glViewport(0, 0, framebuffer.width, framebuffer.height)",
      "$0",
      "framebuffer.destroy()"
    ],
    "description": "Typed GLFW framebuffer size output"
  },
