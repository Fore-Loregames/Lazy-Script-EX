  "Packed OpenGL geometry": {
    "prefix": "lsx-packed-geometry",
    "body": [
      "local vertices = {",
      "    ${1:-1.0},${2:-1.0},${3:0.0},",
      "    ${4:1.0},${5:-1.0},${6:0.0},",
      "    ${7:0.0},${8:1.0},${9:0.0}",
      "}",
      "local indices = {0,1,2}",
      "GL.glBufferData(GL.GL_ARRAY_BUFFER,vertices.byte_length(),vertices,GL.GL_STATIC_DRAW)",
      "GL.glBufferData(GL.GL_ELEMENT_ARRAY_BUFFER,indices.byte_length(),indices,GL.GL_STATIC_DRAW)",
      "$0",
      "indices.destroy()",
      "vertices.destroy()"
    ],
    "description": "Use normal LSX literals for compiler-inferred packed f32 vertex and u32 index data"
  },
