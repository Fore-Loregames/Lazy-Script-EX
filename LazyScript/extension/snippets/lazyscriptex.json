{
  "LSG game window": {
    "prefix": "lsx-window",
    "body": [
      "use \"@LazyScript/LSG.lsx\" as LSG",
      "",
      "fn main()",
      "    local window = LSG.open(\"${1:My LSX Game}\", ${2:1280}, ${3:720})",
      "    if not window.ready() then return LSG.show_error(window.error()) end",
      "    window.set_vsync(${4:false})",
      "",
      "    while window.running() do",
      "        window.begin(${5:0.03}, ${6:0.04}, ${7:0.07})",
      "        $0",
      "        window.end()",
      "    end",
      "",
      "    window.destroy()",
      "    return 0",
      "end"
    ],
    "description": "Create a beginner-facing LSG window with the clear begin()/end() frame pair"
  },
  "LSG Vulkan game window": {
    "prefix": "lsx-vulkan-window",
    "body": [
      "use \"@LazyScript/LSG.lsx\" as LSG",
      "",
      "fn main()",
      "    LSG.use_vulkan()",
      "    local window = LSG.open(\"${1:My Vulkan Game}\", ${2:1280}, ${3:720})",
      "    if not window.ready() then return LSG.show_error(window.error()) end",
      "    window.set_vsync(${4:false})",
      "",
      "    while window.running() do",
      "        window.begin(${5:0.03}, ${6:0.04}, ${7:0.07})",
