  "Native worker thread": {
    "prefix": "lsx-thread",
    "body": [
      "use \"@LazyScript/bindings/System/Threading.lsx\" as Threading",
      "",
      "const ${1:Work} = {",
      "    ${2:value} = 0",
      "}",
      "",
      "fn ${3:worker}(work)",
      "    ${4:-- worker code}",
      "    return 0",
      "end",
      "",
      "local work = ${1:Work}.new()",
      "local task = Threading.Thread.start(${3:worker},work)",
      "task.join()",
      "task.close()",
      "$0",
      "work.destroy()"
    ],
    "description": "Start and join a real native LSX worker thread"
  },
