{
  "name": "lazyscriptex-native-gamekit",
  "displayName": "LazyScriptEX Native GameKit",
  "description": "Native LazyScriptEX tooling with reliable local and imported-module IntelliSense, scope-aware suggestions, import-path completion, built-in formatting, static objects, beginner API hovers, exact compiler ranges, LSHTML/LSCSS, and O6 compilation.",
  "version": "0.18.6",
  "publisher": "nissyokugames",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "LazyScriptEX",
    "lsx",
    "game development",
    "native",
    "threading",
    "sockets",
    "HTTP",
    "GLFW",
    "OpenGL",
    "OpenAL",
    "JSON",
    "file I/O",
    "logging",
    "images",
    "textures",
    "SDF fonts",
    "GLM",
    "vector math",
    "matrix math",
    "quaternions",
    "cameras",
    "LazyUI",
    "LSHTML",
    "LSCSS",
    "retained UI",
    "canvas",
    "game UI",
    "editor UI",
    "declarative canvas"
  ],
  "activationEvents": [
    "onLanguage:lazyscriptex",
    "workspaceContains:**/*.lsx",
    "onCommand:lazyscriptex.refreshIndex",
    "onCommand:lazyscriptex.selectLazyScriptRoot",
    "onCommand:lazyscriptex.selectApiPath",
    "onCommand:lazyscriptex.formatDocument"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lazyscriptex",
        "aliases": [
          "LazyScriptEX",
          "LSX"
        ],
        "extensions": [
          ".lsx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lazyscriptex",
        "scopeName": "source.lazyscriptex",
        "path": "./syntaxes/lazyscriptex.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "lazyscriptex",
        "path": "./snippets/lazyscriptex.json"
      }
    ],
    "commands": [
      {
        "command": "lazyscriptex.buildProject",
        "title": "LazyScriptEX: Build Project",
        "icon": "$(tools)"
      },
      {
        "command": "lazyscriptex.runProject",
        "title": "LazyScriptEX: Build and Run Project",
        "icon": "$(play)"
      },
      {
        "command": "lazyscriptex.checkCurrent",
        "title": "LazyScriptEX: Check Current File",
        "icon": "$(check)"
      },
      {
        "command": "lazyscriptex.refreshIndex",
        "title": "LazyScriptEX: Refresh Recursive Index",
        "icon": "$(refresh)"
      },
      {
        "command": "lazyscriptex.openApi",
        "title": "LazyScriptEX: Open Offline API",
        "icon": "$(book)"
      },
      {
        "command": "lazyscriptex.createProject",
        "title": "LazyScriptEX: Create Project from Template",
        "icon": "$(new-folder)"
      },
      {
        "command": "lazyscriptex.showOutput",
        "title": "LazyScriptEX: Show Output",
        "icon": "$(output)"
      },
      {
        "command": "lazyscriptex.explainSymbol",
        "title": "LazyScriptEX: Explain Symbol Under Cursor",
        "icon": "$(question)"
      },
      {
        "command": "lazyscriptex.selectLazyScriptRoot",
        "title": "LazyScriptEX: Select LazyScript/API Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "lazyscriptex.selectApiPath",
        "title": "LazyScriptEX: Select Offline API Page",
        "icon": "$(file-code)"
      },
      {
        "command": "lazyscriptex.formatDocument",
        "title": "LazyScriptEX: Format Document",
        "icon": "$(indent)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "lazyscriptex.runProject",
          "when": "editorLangId == lazyscriptex",
          "group": "navigation@1"
        },
        {
          "command": "lazyscriptex.buildProject",
          "when": "editorLangId == lazyscriptex",
          "group": "navigation@2"
        },
        {
          "command": "lazyscriptex.checkCurrent",
          "when": "editorLangId == lazyscriptex",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "command": "lazyscriptex.buildProject",
          "when": "editorLangId == lazyscriptex",
          "group": "navigation"
        },
        {
          "command": "lazyscriptex.checkCurrent",
          "when": "editorLangId == lazyscriptex",
          "group": "navigation@2"
        },
        {
          "command": "lazyscriptex.openApi",
          "when": "editorLangId == lazyscriptex",
          "group": "navigation@3"
        },
        {
          "command": "lazyscriptex.explainSymbol",
          "when": "editorLangId == lazyscriptex",
          "group": "navigation@4"
        },
        {
          "command": "lazyscriptex.formatDocument",
          "when": "editorLangId == lazyscriptex",
          "group": "navigation@5"
        }
      ],
      "commandPalette": [
        {
          "command": "lazyscriptex.buildProject"
        },
        {
          "command": "lazyscriptex.runProject"
        },
        {
          "command": "lazyscriptex.checkCurrent"
        },
        {
          "command": "lazyscriptex.refreshIndex"
        },
        {
          "command": "lazyscriptex.openApi"
        },
        {
          "command": "lazyscriptex.createProject"
        },
        {
          "command": "lazyscriptex.explainSymbol"
        },
        {
          "command": "lazyscriptex.selectLazyScriptRoot"
        },
        {
          "command": "lazyscriptex.selectApiPath"
        },
        {
          "command": "lazyscriptex.formatDocument"
        }
      ]
    },
    "keybindings": [
      {
        "command": "lazyscriptex.buildProject",
        "key": "f6",
        "when": "editorLangId == lazyscriptex"
      },
      {
        "command": "lazyscriptex.runProject",
        "key": "ctrl+f6",
        "when": "editorLangId == lazyscriptex"
      },
      {
        "command": "lazyscriptex.checkCurrent",
        "key": "ctrl+shift+f6",
        "when": "editorLangId == lazyscriptex"
      },
      {
        "command": "lazyscriptex.refreshIndex",
        "key": "ctrl+alt+r",
        "when": "editorLangId == lazyscriptex"
      }
    ],
    "configuration": {
      "title": "LazyScriptEX",
      "properties": {
        "lazyscriptex.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute compiler path. Empty auto-detects LazyScript/compiler/lazyscriptex.js."
        },
        "lazyscriptex.checkOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Check the current LSX file and every module it imports when the file is saved."
        },
        "lazyscriptex.recursiveIndex": {
          "type": "boolean",
          "default": true,
          "description": "Index every .lsx file recursively in every workspace folder."
        },
        "lazyscriptex.exclude": {
          "type": "string",
          "default": "**/{build,node_modules,.git,.cache}/**",
          "description": "Glob excluded from recursive indexing."
        },
        "lazyscriptex.apiPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the offline API index.html. Use Select Offline API Page, or select the LazyScript/API folder to configure it automatically."
        },
        "lazyscriptex.lazyScriptRoot": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the LazyScript folder, its api folder, or the toolkit root. Use the Select LazyScript/API Folder command; this path powers @LazyScript imports, compiler checks, API opening, and recursive IntelliSense."
        },
        "lazyscriptex.checkOnType": {
          "type": "boolean",
          "default": true,
          "description": "Run a debounced compiler check for the current LSX file and its imports while editing."
        },
        "lazyscriptex.checkDelay": {
          "type": "number",
          "default": 700,
          "minimum": 250,
          "maximum": 5000,
          "description": "Milliseconds to wait after typing before checking the LSX project."
        },
        "lazyscriptex.moduleRoots": {
          "type": "object",
          "default": {},
          "description": "Optional named LSX module roots. Example: {\"Engine\":\"C:/Projects/MyGame/Engine\"}. Imports then use @Engine/Folder/File.lsx. Paths are indexed recursively and passed to the compiler.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "lazyscriptex.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the built-in LSX document, selection, on-type, and format-on-save formatter."
        },
        "lazyscriptex.completion.autoTrigger": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open IntelliSense while typing inside an LSX function so parameters, locals, loop variables, self, and object members are always visible."
        },
        "lazyscriptex.completion.autoTriggerDelay": {
          "type": "number",
          "default": 35,
          "minimum": 0,
          "maximum": 500,
          "description": "Milliseconds to wait before opening LSX local-scope IntelliSense after typing an identifier character."
        }
      }
    },
    "configurationDefaults": {
      "[lazyscriptex]": {
        "editor.defaultFormatter": "nissyokugames.lazyscriptex-native-gamekit",
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": false
        },
        "editor.suggestOnTriggerCharacters": true,
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.wordBasedSuggestions": "currentDocument"
      }
    }
  },
  "scripts": {
    "test": "node --check extension.js && node test_extension.js"
  },
  "files": [
    "extension.js",
    "language-configuration.json",
    "syntaxes/**",
    "snippets/**",
    "compiler/**",
    "README.md",
    "LICENSE",
    "api/**"
  ]
}
