export fn option() -> Element
    local value = create_element(ELEMENT_INPUT,"option")
    -- Options are logical retained children of a select. They do not consume
    -- normal flex/grid space; the renderer submits the active popup as a
    -- top-level overlay and the document performs popup hit testing directly.
    value.style.display = DISPLAY_NONE
    value.style.cursor = CURSOR_POINTER
    value.focusable = false
    return value
end

