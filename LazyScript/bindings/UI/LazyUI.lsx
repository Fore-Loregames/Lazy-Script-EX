fn resolve_dimension(unit:i32,value:f32,parent:f32,viewport:f32,fontSize:f32) -> f32
    if unit == UNIT_PX then return value end
    if unit == UNIT_PERCENT then return parent * value / 100.0 end
    if unit == UNIT_VW or unit == UNIT_VH then return viewport * value / 100.0 end
    if unit == UNIT_EM then return fontSize * value end
    if unit == UNIT_REM then return 16.0 * value end
    return 0.0
end

fn text_width(element:Element,style:Style) -> f32
    if element.text == null then return 0.0 end
    return string.length(element.text) * style.font_size * 0.55 + style.letter_spacing * string.length(element.text)
end

fn horizontal_insets(style:Style) -> f32
    return style.border_left_width + style.padding_left + style.padding_right + style.border_right_width
end

fn vertical_insets(style:Style) -> f32
    return style.border_top_width + style.padding_top + style.padding_bottom + style.border_bottom_width
end

fn outer_width_for_css(style:Style,value:f32) -> f32
    if value <= 0.0 then return value end
    if style.box_sizing == BOX_CONTENT then return value + horizontal_insets(style) end
    return value
end

fn outer_height_for_css(style:Style,value:f32) -> f32
    if value <= 0.0 then return value end
    if style.box_sizing == BOX_CONTENT then return value + vertical_insets(style) end
    return value
end

fn measure_auto_width(element:Element,availableWidth:f32,availableHeight:f32,viewportWidth:f32,viewportHeight:f32) -> f32
    local style = element.current_style()
    local insets = horizontal_insets(style)
    local directText = text_width(element,style)
    if directText > 0.0 then return directText + insets end
    -- Intrinsic images and any element using aspect-ratio must contribute their
    -- derived automatic dimension during the parent's measurement pass. Without
    -- this, a width-only image is laid out at the correct height later, but its
    -- parent reserves almost no space for it and following controls overlap it.
    if style.aspect_ratio > 0.0 and style.height_unit ~= UNIT_AUTO then
        local ratioHeight = resolve_dimension(style.height_unit,style.height,availableHeight,viewportHeight,style.font_size)
        ratioHeight = outer_height_for_css(style,ratioHeight)
        if ratioHeight > 0.0 then return ratioHeight * style.aspect_ratio end
    end

    if style.display == DISPLAY_GRID then
        local columns = style.grid_columns
        if columns < 1 then columns = 1 end
        local largestGridChild = 0.0
        local visibleGridChildren:i64 = 0
        local gridIndex:i64 = 0
        while gridIndex < element.children.length() do
            local gridChild = element.children.at(gridIndex)
            local gridChildStyle = gridChild.current_style()
            if not gridChild.hidden and gridChildStyle.visibility and gridChildStyle.display ~= DISPLAY_NONE and gridChildStyle.position ~= POSITION_ABSOLUTE and gridChildStyle.position ~= POSITION_FIXED then
                local gridChildWidth = resolve_dimension(gridChildStyle.width_unit,gridChildStyle.width,availableWidth,viewportWidth,gridChildStyle.font_size)
                gridChildWidth = outer_width_for_css(gridChildStyle,gridChildWidth)
                if gridChildWidth <= 0.0 then gridChildWidth = measure_auto_width(gridChild,availableWidth,availableHeight,viewportWidth,viewportHeight) end
                gridChildWidth = gridChildWidth + gridChildStyle.margin_left + gridChildStyle.margin_right
                if gridChildWidth > largestGridChild then largestGridChild = gridChildWidth end
                visibleGridChildren = visibleGridChildren + 1
            end
            gridIndex = gridIndex + 1
        end
        local usedColumns = columns
        if visibleGridChildren < usedColumns then usedColumns = visibleGridChildren end
        if usedColumns < 1 then return insets end
        return insets + largestGridChild * usedColumns + style.column_gap * (usedColumns - 1)
    end

    local total = insets
    local largest = 0.0
    local relativeCount = 0
    local index = 0
    while index < element.children.length() do
        local child = element.children.at(index)
        local childStyle = child.current_style()
        if not child.hidden and childStyle.visibility and childStyle.display ~= DISPLAY_NONE and childStyle.position ~= POSITION_ABSOLUTE and childStyle.position ~= POSITION_FIXED then
            local childWidth = resolve_dimension(childStyle.width_unit,childStyle.width,availableWidth,viewportWidth,childStyle.font_size)
            childWidth = outer_width_for_css(childStyle,childWidth)
            if childWidth <= 0.0 then childWidth = measure_auto_width(child,availableWidth,availableHeight,viewportWidth,viewportHeight) end
            childWidth = childWidth + childStyle.margin_left + childStyle.margin_right
            if style.flex_direction == FLEX_ROW or style.flex_direction == FLEX_ROW_REVERSE then
                total = total + childWidth
                relativeCount = relativeCount + 1
            elseif childWidth > largest then largest = childWidth end
        end
        index = index + 1
    end
    if style.flex_direction == FLEX_ROW or style.flex_direction == FLEX_ROW_REVERSE then
        if relativeCount > 1 then total = total + style.column_gap * (relativeCount - 1) end
    else
        total = total + largest
    end
    return total
end

fn measure_auto_height(element:Element,availableWidth:f32,availableHeight:f32,viewportWidth:f32,viewportHeight:f32) -> f32
    local style = element.current_style()
    local insets = vertical_insets(style)
    local directText = text_width(element,style)
    if directText > 0.0 and element.children.length() == 0 then
        local lineHeight = style.line_height
        if lineHeight <= 0.0 then lineHeight = style.font_size * 1.25 end
        return lineHeight + insets
    end
    -- Match layout_node_sized's width + automatic-height aspect-ratio rule in
    -- the measurement pass as well. This keeps the parent's flow height and hit
    -- testing in sync with the final rendered image dimensions.
    if style.aspect_ratio > 0.0 and style.width_unit ~= UNIT_AUTO then
        local ratioWidth = resolve_dimension(style.width_unit,style.width,availableWidth,viewportWidth,style.font_size)
        ratioWidth = outer_width_for_css(style,ratioWidth)
        if ratioWidth > 0.0 then return ratioWidth / style.aspect_ratio end
    end

    if style.display == DISPLAY_GRID then
        local columns = style.grid_columns
        if columns < 1 then columns = 1 end
        local totalGridHeight = insets
        local currentRowHeight = 0.0
        local visibleGridIndex:i64 = 0
        local gridIndex:i64 = 0
        while gridIndex < element.children.length() do
            local gridChild = element.children.at(gridIndex)
            local gridChildStyle = gridChild.current_style()
            if not gridChild.hidden and gridChildStyle.visibility and gridChildStyle.display ~= DISPLAY_NONE and gridChildStyle.position ~= POSITION_ABSOLUTE and gridChildStyle.position ~= POSITION_FIXED then
                local gridChildHeight = resolve_dimension(gridChildStyle.height_unit,gridChildStyle.height,availableHeight,viewportHeight,gridChildStyle.font_size)
                gridChildHeight = outer_height_for_css(gridChildStyle,gridChildHeight)
                if gridChildHeight <= 0.0 then gridChildHeight = measure_auto_height(gridChild,availableWidth,availableHeight,viewportWidth,viewportHeight) end
                gridChildHeight = gridChildHeight + gridChildStyle.margin_top + gridChildStyle.margin_bottom
                if gridChildHeight > currentRowHeight then currentRowHeight = gridChildHeight end
                local gridColumnIndex = visibleGridIndex % columns
                if gridColumnIndex == columns - 1 then
                    if visibleGridIndex >= columns then totalGridHeight = totalGridHeight + style.row_gap end
                    totalGridHeight = totalGridHeight + currentRowHeight
                    currentRowHeight = 0.0
                end
                visibleGridIndex = visibleGridIndex + 1
            end
            gridIndex = gridIndex + 1
        end
        if visibleGridIndex > 0 and visibleGridIndex % columns ~= 0 then
            if visibleGridIndex > columns then totalGridHeight = totalGridHeight + style.row_gap end
            totalGridHeight = totalGridHeight + currentRowHeight
        end
        return totalGridHeight
    end

    local total = insets
    local largest = 0.0
    local relativeCount = 0
    local index = 0
    while index < element.children.length() do
        local child = element.children.at(index)
        local childStyle = child.current_style()
        if not child.hidden and childStyle.visibility and childStyle.display ~= DISPLAY_NONE and childStyle.position ~= POSITION_ABSOLUTE and childStyle.position ~= POSITION_FIXED then
            local childHeight = resolve_dimension(childStyle.height_unit,childStyle.height,availableHeight,viewportHeight,childStyle.font_size)
            childHeight = outer_height_for_css(childStyle,childHeight)
            if childHeight <= 0.0 then childHeight = measure_auto_height(child,availableWidth,availableHeight,viewportWidth,viewportHeight) end
            childHeight = childHeight + childStyle.margin_top + childStyle.margin_bottom
            if style.flex_direction == FLEX_ROW or style.flex_direction == FLEX_ROW_REVERSE then
                if childHeight > largest then largest = childHeight end
            else
                total = total + childHeight
                relativeCount = relativeCount + 1
            end
        end
        index = index + 1
    end
    if style.flex_direction == FLEX_ROW or style.flex_direction == FLEX_ROW_REVERSE then
        total = total + largest
    elseif relativeCount > 1 then
        total = total + style.row_gap * (relativeCount - 1)
    end
    return total
end

fn preferred_main_size(child:Element,rowLayout:bool,availableWidth:f32,availableHeight:f32,viewportWidth:f32,viewportHeight:f32) -> f32
    local style = child.current_style()
    if rowLayout then
        local value = resolve_dimension(style.width_unit,style.width,availableWidth,viewportWidth,style.font_size)
        value = outer_width_for_css(style,value)
        if value <= 0.0 and style.aspect_ratio > 0.0 and style.height_unit ~= UNIT_AUTO then
            local explicitHeight = resolve_dimension(style.height_unit,style.height,availableHeight,viewportHeight,style.font_size)
            explicitHeight = outer_height_for_css(style,explicitHeight)
            if explicitHeight > 0.0 then value = explicitHeight * style.aspect_ratio end
        end
        if value <= 0.0 and style.flex_basis_unit ~= UNIT_AUTO then
            value = resolve_dimension(style.flex_basis_unit,style.flex_basis,availableWidth,viewportWidth,style.font_size)
        end
        if value <= 0.0 and style.flex_grow <= 0.0 then value = measure_auto_width(child,availableWidth,availableHeight,viewportWidth,viewportHeight) end
        return value
    end
    local columnValue = resolve_dimension(style.height_unit,style.height,availableHeight,viewportHeight,style.font_size)
    columnValue = outer_height_for_css(style,columnValue)
    if columnValue <= 0.0 and style.aspect_ratio > 0.0 and style.width_unit ~= UNIT_AUTO then
        local explicitWidth = resolve_dimension(style.width_unit,style.width,availableWidth,viewportWidth,style.font_size)
        explicitWidth = outer_width_for_css(style,explicitWidth)
        if explicitWidth > 0.0 then columnValue = explicitWidth / style.aspect_ratio end
    end
    if columnValue <= 0.0 and style.flex_basis_unit ~= UNIT_AUTO then
        columnValue = resolve_dimension(style.flex_basis_unit,style.flex_basis,availableHeight,viewportHeight,style.font_size)
    end
    if columnValue <= 0.0 and style.flex_grow <= 0.0 then columnValue = measure_auto_height(child,availableWidth,availableHeight,viewportWidth,viewportHeight) end
    return columnValue
end

fn preferred_cross_size(child:Element,rowLayout:bool,availableWidth:f32,availableHeight:f32,viewportWidth:f32,viewportHeight:f32) -> f32
    local style = child.current_style()
    if rowLayout then
        local value = resolve_dimension(style.height_unit,style.height,availableHeight,viewportHeight,style.font_size)
        value = outer_height_for_css(style,value)
        if value <= 0.0 and style.aspect_ratio > 0.0 then
            local ratioWidth = resolve_dimension(style.width_unit,style.width,availableWidth,viewportWidth,style.font_size)
            ratioWidth = outer_width_for_css(style,ratioWidth)
            if ratioWidth > 0.0 then value = ratioWidth / style.aspect_ratio end
        end
        if value <= 0.0 then value = measure_auto_height(child,availableWidth,availableHeight,viewportWidth,viewportHeight) end
        return value
    end
    local columnValue = resolve_dimension(style.width_unit,style.width,availableWidth,viewportWidth,style.font_size)
    columnValue = outer_width_for_css(style,columnValue)
    if columnValue <= 0.0 and style.aspect_ratio > 0.0 then
        local ratioHeight = resolve_dimension(style.height_unit,style.height,availableHeight,viewportHeight,style.font_size)
        ratioHeight = outer_height_for_css(style,ratioHeight)
        if ratioHeight > 0.0 then columnValue = ratioHeight * style.aspect_ratio end
    end
    if columnValue <= 0.0 then columnValue = measure_auto_width(child,availableWidth,availableHeight,viewportWidth,viewportHeight) end
    return columnValue
end

fn shift_layout_subtree(element:Element,deltaX:f32,deltaY:f32)
    if element == null then return end
    element.x = element.x + deltaX
    element.y = element.y + deltaY
    element.content_x = element.content_x + deltaX
    element.content_y = element.content_y + deltaY
    element.clip_x = element.clip_x + deltaX
    element.clip_y = element.clip_y + deltaY
    local index = 0
    while index < element.children.length() do
        shift_layout_subtree(element.children.at(index),deltaX,deltaY)
        index = index + 1
    end
end

fn update_scroll_metrics(element:Element)
    if element == null then return end
    local maximumRight = element.content_x + element.content_width
    local maximumBottom = element.content_y + element.content_height
    local index = 0
    while index < element.children.length() do
        local child = element.children.at(index)
        if child ~= null and not child.hidden then
            local childStyle = child.current_style()
            if childStyle.visibility and childStyle.display ~= DISPLAY_NONE then
                local right = child.x + element.scroll_x + child.width + childStyle.margin_right
                local bottom = child.y + element.scroll_y + child.height + childStyle.margin_bottom
                if right > maximumRight then maximumRight = right end
                if bottom > maximumBottom then maximumBottom = bottom end
            end
        end
        index = index + 1
    end
    element.scroll_content_width = maximumRight - element.content_x
    element.scroll_content_height = maximumBottom - element.content_y
    if element.scroll_content_width < element.content_width then element.scroll_content_width = element.content_width end
    if element.scroll_content_height < element.content_height then element.scroll_content_height = element.content_height end
    element.scroll_max_x = element.scroll_content_width - element.content_width
    element.scroll_max_y = element.scroll_content_height - element.content_height
    if element.scroll_max_x < 0.0 then element.scroll_max_x = 0.0 end
    if element.scroll_max_y < 0.0 then element.scroll_max_y = 0.0 end

    local previousX = element.scroll_x
    local previousY = element.scroll_y
    if element.scroll_x < 0.0 then element.scroll_x = 0.0 end
    if element.scroll_y < 0.0 then element.scroll_y = 0.0 end
    if element.scroll_x > element.scroll_max_x then element.scroll_x = element.scroll_max_x end
    if element.scroll_y > element.scroll_max_y then element.scroll_y = element.scroll_max_y end
    local shiftX = previousX - element.scroll_x
    local shiftY = previousY - element.scroll_y
    if shiftX ~= 0.0 or shiftY ~= 0.0 then
        index = 0
        while index < element.children.length() do
            shift_layout_subtree(element.children.at(index),shiftX,shiftY)
            index = index + 1
        end
    end
end

fn layout_node_sized(element:Element,x:f32,y:f32,availableWidth:f32,availableHeight:f32,viewportWidth:f32,viewportHeight:f32,forcedWidth:f32,forcedHeight:f32)
    if element == null then return end
    local style = element.current_style()
    if element.hidden or not style.visibility or style.display == DISPLAY_NONE then element.width = 0.0 element.height = 0.0 return end

    local width = forcedWidth
    local height = forcedHeight
    if width <= 0.0 then
        width = resolve_dimension(style.width_unit,style.width,availableWidth,viewportWidth,style.font_size)
        width = outer_width_for_css(style,width)
    end
    if height <= 0.0 then
        height = resolve_dimension(style.height_unit,style.height,availableHeight,viewportHeight,style.font_size)
        height = outer_height_for_css(style,height)
    end
    if width <= 0.0 then
        if element.kind == ELEMENT_TEXT then width = measure_auto_width(element,availableWidth,availableHeight,viewportWidth,viewportHeight)
        else width = availableWidth - style.margin_left - style.margin_right end
    end
    if height <= 0.0 then height = measure_auto_height(element,width,availableHeight,viewportWidth,viewportHeight) end

    local minWidth = resolve_dimension(style.min_width_unit,style.min_width,availableWidth,viewportWidth,style.font_size)
    local minHeight = resolve_dimension(style.min_height_unit,style.min_height,availableHeight,viewportHeight,style.font_size)
    local maxWidth = resolve_dimension(style.max_width_unit,style.max_width,availableWidth,viewportWidth,style.font_size)
    local maxHeight = resolve_dimension(style.max_height_unit,style.max_height,availableHeight,viewportHeight,style.font_size)
    minWidth = outer_width_for_css(style,minWidth)
    minHeight = outer_height_for_css(style,minHeight)
    maxWidth = outer_width_for_css(style,maxWidth)
    maxHeight = outer_height_for_css(style,maxHeight)
    if width < minWidth then width = minWidth end
    if height < minHeight then height = minHeight end
    if maxWidth > 0.0 and width > maxWidth then width = maxWidth end
    if maxHeight > 0.0 and height > maxHeight then height = maxHeight end
    if style.aspect_ratio > 0.0 then
        -- An automatic dimension paired with an explicit one keeps the ratio
        -- even when flex alignment supplied a measured cross-size. This is the
        -- normal <img style="width: ...; height: auto"> behavior.
        if style.height_unit == UNIT_AUTO and style.width_unit ~= UNIT_AUTO then height = width / style.aspect_ratio
        elseif style.width_unit == UNIT_AUTO and style.height_unit ~= UNIT_AUTO then width = height * style.aspect_ratio
        elseif forcedHeight <= 0.0 and style.height_unit == UNIT_AUTO and width > 0.0 then height = width / style.aspect_ratio
        elseif forcedWidth <= 0.0 and style.width_unit == UNIT_AUTO and height > 0.0 then width = height * style.aspect_ratio end
    end

    element.x = x + style.margin_left + style.translate_x
    element.y = y + style.margin_top + style.translate_y
    element.width = width
    element.height = height
    element.content_x = element.x + style.border_left_width + style.padding_left
    element.content_y = element.y + style.border_top_width + style.padding_top
    element.content_width = width - horizontal_insets(style)
    element.content_height = height - vertical_insets(style)
    if element.content_width < 0.0 then element.content_width = 0.0 end
    if element.content_height < 0.0 then element.content_height = 0.0 end
    element.clip_x = element.x
    element.clip_y = element.y
    element.clip_width = width
    element.clip_height = height
    if element.canvas_context ~= null then element.canvas_context.width = element.content_width element.canvas_context.height = element.content_height end
    if element.scroll_x < 0.0 then element.scroll_x = 0.0 end
    if element.scroll_y < 0.0 then element.scroll_y = 0.0 end
    if element.scroll_x > element.scroll_max_x then element.scroll_x = element.scroll_max_x end
    if element.scroll_y > element.scroll_max_y then element.scroll_y = element.scroll_max_y end

    local rowLayout = style.flex_direction == FLEX_ROW or style.flex_direction == FLEX_ROW_REVERSE
    local reverseLayout = style.flex_direction == FLEX_ROW_REVERSE or style.flex_direction == FLEX_COLUMN_REVERSE
    local mainAvailable = element.content_height
    local crossAvailable = element.content_width
    local defaultGap = style.row_gap
    if rowLayout then mainAvailable = element.content_width crossAvailable = element.content_height defaultGap = style.column_gap end

    if style.display == DISPLAY_GRID then
        local columns = style.grid_columns
        if columns < 1 then columns = 1 end
        local columnWidth = (element.content_width - style.column_gap * (columns - 1)) / columns
        local cursorY = element.content_y - element.scroll_y
        local gridIndex = 0
        local rowHeight = 0.0
        while gridIndex < element.children.length() do
            local gridChild = element.children.at(gridIndex)
            local gridStyle = gridChild.current_style()
            if gridStyle.position == POSITION_ABSOLUTE or gridStyle.position == POSITION_FIXED then
                local gridForcedWidth:f32 = 0.0
                local gridForcedHeight:f32 = 0.0
                if gridStyle.width_unit == UNIT_AUTO and gridStyle.left_unit ~= UNIT_AUTO and gridStyle.right_unit ~= UNIT_AUTO then
                    gridForcedWidth = element.content_width - resolve_dimension(gridStyle.left_unit,gridStyle.left,element.content_width,viewportWidth,gridStyle.font_size) - resolve_dimension(gridStyle.right_unit,gridStyle.right,element.content_width,viewportWidth,gridStyle.font_size) - gridStyle.margin_left - gridStyle.margin_right
                    if gridForcedWidth < 0.0 then gridForcedWidth = 0.0 end
                end
                if gridStyle.height_unit == UNIT_AUTO and gridStyle.top_unit ~= UNIT_AUTO and gridStyle.bottom_unit ~= UNIT_AUTO then
                    gridForcedHeight = element.content_height - resolve_dimension(gridStyle.top_unit,gridStyle.top,element.content_height,viewportHeight,gridStyle.font_size) - resolve_dimension(gridStyle.bottom_unit,gridStyle.bottom,element.content_height,viewportHeight,gridStyle.font_size) - gridStyle.margin_top - gridStyle.margin_bottom
                    if gridForcedHeight < 0.0 then gridForcedHeight = 0.0 end
                end
                layout_node_sized(gridChild,element.content_x,element.content_y,element.content_width,element.content_height,viewportWidth,viewportHeight,gridForcedWidth,gridForcedHeight)
                local gridTargetX = gridChild.x
                local gridTargetY = gridChild.y
                local gridScrollX:f32 = 0.0
                local gridScrollY:f32 = 0.0
                if gridStyle.position == POSITION_ABSOLUTE then gridScrollX = element.scroll_x gridScrollY = element.scroll_y end
                if gridStyle.left_unit ~= UNIT_AUTO then gridTargetX = element.content_x - gridScrollX + resolve_dimension(gridStyle.left_unit,gridStyle.left,element.content_width,viewportWidth,gridStyle.font_size) + gridStyle.margin_left + gridStyle.translate_x end
                if gridStyle.right_unit ~= UNIT_AUTO and gridStyle.left_unit == UNIT_AUTO then gridTargetX = element.content_x - gridScrollX + element.content_width - resolve_dimension(gridStyle.right_unit,gridStyle.right,element.content_width,viewportWidth,gridStyle.font_size) - gridChild.width - gridStyle.margin_right + gridStyle.translate_x end
                if gridStyle.top_unit ~= UNIT_AUTO then gridTargetY = element.content_y - gridScrollY + resolve_dimension(gridStyle.top_unit,gridStyle.top,element.content_height,viewportHeight,gridStyle.font_size) + gridStyle.margin_top + gridStyle.translate_y end
                if gridStyle.bottom_unit ~= UNIT_AUTO and gridStyle.top_unit == UNIT_AUTO then gridTargetY = element.content_y - gridScrollY + element.content_height - resolve_dimension(gridStyle.bottom_unit,gridStyle.bottom,element.content_height,viewportHeight,gridStyle.font_size) - gridChild.height - gridStyle.margin_bottom + gridStyle.translate_y end
                shift_layout_subtree(gridChild,gridTargetX-gridChild.x,gridTargetY-gridChild.y)
            else
                local gridColumnIndex = gridIndex % columns
                local gridChildX = element.content_x + gridColumnIndex * (columnWidth + style.column_gap) - element.scroll_x
                layout_node_sized(gridChild,gridChildX,cursorY,columnWidth,element.content_height,viewportWidth,viewportHeight,columnWidth - gridStyle.margin_left - gridStyle.margin_right,0.0)
                local gridOccupiedHeight = gridChild.height + gridStyle.margin_top + gridStyle.margin_bottom
                if gridOccupiedHeight > rowHeight then rowHeight = gridOccupiedHeight end
                if gridColumnIndex == columns - 1 or gridIndex == element.children.length() - 1 then cursorY = cursorY + rowHeight + style.row_gap rowHeight = 0.0 end
            end
            gridIndex = gridIndex + 1
        end
        update_scroll_metrics(element)
        element.layout_dirty = false
        return
    end

    local relativeCount = 0
    local totalMain = 0.0
    local totalGrow = 0.0
    local totalShrink = 0.0
    local scanIndex = 0
    while scanIndex < element.children.length() do
        local scanChild = element.children.at(scanIndex)
        local scanStyle = scanChild.current_style()
        if not scanChild.hidden and scanStyle.visibility and scanStyle.display ~= DISPLAY_NONE and scanStyle.position ~= POSITION_ABSOLUTE and scanStyle.position ~= POSITION_FIXED then
            local scanMain = preferred_main_size(scanChild,rowLayout,element.content_width,element.content_height,viewportWidth,viewportHeight)
            if rowLayout then totalMain = totalMain + scanMain + scanStyle.margin_left + scanStyle.margin_right
            else totalMain = totalMain + scanMain + scanStyle.margin_top + scanStyle.margin_bottom end
            totalGrow = totalGrow + scanStyle.flex_grow
            totalShrink = totalShrink + scanStyle.flex_shrink
            relativeCount = relativeCount + 1
        end
        scanIndex = scanIndex + 1
    end
    if relativeCount > 1 then totalMain = totalMain + defaultGap * (relativeCount - 1) end

    local freeSpace = mainAvailable - totalMain
    local shrinkSpace = 0.0
    if freeSpace < 0.0 then shrinkSpace = -freeSpace freeSpace = 0.0 end
    local leading = 0.0
    local distributedGap = defaultGap
    if totalGrow <= 0.0 and freeSpace > 0.0 then
        if style.justify_content == ALIGN_CENTER then leading = freeSpace * 0.5
        elseif style.justify_content == ALIGN_END then leading = freeSpace
        elseif style.justify_content == ALIGN_SPACE_BETWEEN and relativeCount > 1 then distributedGap = defaultGap + freeSpace / (relativeCount - 1)
        elseif style.justify_content == ALIGN_SPACE_AROUND and relativeCount > 0 then distributedGap = defaultGap + freeSpace / relativeCount leading = distributedGap * 0.5
        elseif style.justify_content == ALIGN_SPACE_EVENLY and relativeCount > 0 then distributedGap = defaultGap + freeSpace / (relativeCount + 1) leading = distributedGap end
    end

    local cursor = leading
    if reverseLayout then cursor = mainAvailable - leading end
    local layoutIndex = 0
    while layoutIndex < element.children.length() do
        local layoutChild = element.children.at(layoutIndex)
        local layoutStyle = layoutChild.current_style()
        if layoutStyle.position == POSITION_ABSOLUTE or layoutStyle.position == POSITION_FIXED then
            local absoluteForcedWidth:f32 = 0.0
            local absoluteForcedHeight:f32 = 0.0
            if layoutStyle.width_unit == UNIT_AUTO and layoutStyle.left_unit ~= UNIT_AUTO and layoutStyle.right_unit ~= UNIT_AUTO then
                absoluteForcedWidth = element.content_width - resolve_dimension(layoutStyle.left_unit,layoutStyle.left,element.content_width,viewportWidth,layoutStyle.font_size) - resolve_dimension(layoutStyle.right_unit,layoutStyle.right,element.content_width,viewportWidth,layoutStyle.font_size) - layoutStyle.margin_left - layoutStyle.margin_right
                if absoluteForcedWidth < 0.0 then absoluteForcedWidth = 0.0 end
            end
            if layoutStyle.height_unit == UNIT_AUTO and layoutStyle.top_unit ~= UNIT_AUTO and layoutStyle.bottom_unit ~= UNIT_AUTO then
                absoluteForcedHeight = element.content_height - resolve_dimension(layoutStyle.top_unit,layoutStyle.top,element.content_height,viewportHeight,layoutStyle.font_size) - resolve_dimension(layoutStyle.bottom_unit,layoutStyle.bottom,element.content_height,viewportHeight,layoutStyle.font_size) - layoutStyle.margin_top - layoutStyle.margin_bottom
                if absoluteForcedHeight < 0.0 then absoluteForcedHeight = 0.0 end
            end
            layout_node_sized(layoutChild,element.content_x,element.content_y,element.content_width,element.content_height,viewportWidth,viewportHeight,absoluteForcedWidth,absoluteForcedHeight)
            local absoluteTargetX = layoutChild.x
            local absoluteTargetY = layoutChild.y
            local absoluteScrollX:f32 = 0.0
            local absoluteScrollY:f32 = 0.0
            if layoutStyle.position == POSITION_ABSOLUTE then absoluteScrollX = element.scroll_x absoluteScrollY = element.scroll_y end
            if layoutStyle.left_unit ~= UNIT_AUTO then absoluteTargetX = element.content_x - absoluteScrollX + resolve_dimension(layoutStyle.left_unit,layoutStyle.left,element.content_width,viewportWidth,layoutStyle.font_size) + layoutStyle.margin_left + layoutStyle.translate_x end
            if layoutStyle.right_unit ~= UNIT_AUTO and layoutStyle.left_unit == UNIT_AUTO then absoluteTargetX = element.content_x - absoluteScrollX + element.content_width - resolve_dimension(layoutStyle.right_unit,layoutStyle.right,element.content_width,viewportWidth,layoutStyle.font_size) - layoutChild.width - layoutStyle.margin_right + layoutStyle.translate_x end
            if layoutStyle.top_unit ~= UNIT_AUTO then absoluteTargetY = element.content_y - absoluteScrollY + resolve_dimension(layoutStyle.top_unit,layoutStyle.top,element.content_height,viewportHeight,layoutStyle.font_size) + layoutStyle.margin_top + layoutStyle.translate_y end
            if layoutStyle.bottom_unit ~= UNIT_AUTO and layoutStyle.top_unit == UNIT_AUTO then absoluteTargetY = element.content_y - absoluteScrollY + element.content_height - resolve_dimension(layoutStyle.bottom_unit,layoutStyle.bottom,element.content_height,viewportHeight,layoutStyle.font_size) - layoutChild.height - layoutStyle.margin_bottom + layoutStyle.translate_y end
            shift_layout_subtree(layoutChild,absoluteTargetX-layoutChild.x,absoluteTargetY-layoutChild.y)
        elseif not layoutChild.hidden and layoutStyle.visibility and layoutStyle.display ~= DISPLAY_NONE then
            local layoutMain = preferred_main_size(layoutChild,rowLayout,element.content_width,element.content_height,viewportWidth,viewportHeight)
            if totalGrow > 0.0 and layoutStyle.flex_grow > 0.0 then layoutMain = layoutMain + freeSpace * layoutStyle.flex_grow / totalGrow end
            if shrinkSpace > 0.0 and totalShrink > 0.0 and layoutStyle.flex_shrink > 0.0 then
                layoutMain = layoutMain - shrinkSpace * layoutStyle.flex_shrink / totalShrink
                if layoutMain < 0.0 then layoutMain = 0.0 end
            end

            local layoutCross = preferred_cross_size(layoutChild,rowLayout,element.content_width,element.content_height,viewportWidth,viewportHeight)
            local layoutAlign = layoutStyle.align_self
            if layoutAlign == ALIGN_AUTO then layoutAlign = style.align_items end
            local layoutCrossMarginStart = layoutStyle.margin_left
            local layoutCrossMarginEnd = layoutStyle.margin_right
            if rowLayout then layoutCrossMarginStart = layoutStyle.margin_top layoutCrossMarginEnd = layoutStyle.margin_bottom end
            if layoutAlign == ALIGN_STRETCH then layoutCross = crossAvailable - layoutCrossMarginStart - layoutCrossMarginEnd end
            if layoutCross < 0.0 then layoutCross = 0.0 end
            local layoutCrossOffset = 0.0
            if layoutAlign == ALIGN_CENTER then layoutCrossOffset = (crossAvailable - layoutCross - layoutCrossMarginStart - layoutCrossMarginEnd) * 0.5
            elseif layoutAlign == ALIGN_END then layoutCrossOffset = crossAvailable - layoutCross - layoutCrossMarginStart - layoutCrossMarginEnd end

            local layoutChildX = element.content_x - element.scroll_x
            local layoutChildY = element.content_y - element.scroll_y
            if reverseLayout then
                if rowLayout then
                    cursor = cursor - layoutStyle.margin_right - layoutMain
                    layoutChildX = element.content_x + cursor - element.scroll_x
                    layoutChildY = element.content_y + layoutCrossOffset - element.scroll_y
                    cursor = cursor - layoutStyle.margin_left - distributedGap
                else
                    cursor = cursor - layoutStyle.margin_bottom - layoutMain
                    layoutChildY = element.content_y + cursor - element.scroll_y
                    layoutChildX = element.content_x + layoutCrossOffset - element.scroll_x
                    cursor = cursor - layoutStyle.margin_top - distributedGap
                end
            else
                if rowLayout then
                    layoutChildX = element.content_x + cursor - element.scroll_x
                    layoutChildY = element.content_y + layoutCrossOffset - element.scroll_y
                    cursor = cursor + layoutStyle.margin_left + layoutMain + layoutStyle.margin_right + distributedGap
                else
                    layoutChildY = element.content_y + cursor - element.scroll_y
                    layoutChildX = element.content_x + layoutCrossOffset - element.scroll_x
                    cursor = cursor + layoutStyle.margin_top + layoutMain + layoutStyle.margin_bottom + distributedGap
                end
            end
            if rowLayout then layout_node_sized(layoutChild,layoutChildX,layoutChildY,layoutMain,layoutCross,viewportWidth,viewportHeight,layoutMain,layoutCross)
            else layout_node_sized(layoutChild,layoutChildX,layoutChildY,layoutCross,layoutMain,viewportWidth,viewportHeight,layoutCross,layoutMain) end
        end
        layoutIndex = layoutIndex + 1
    end
    update_scroll_metrics(element)
    element.layout_dirty = false
end

fn layout_node(element:Element,x:f32,y:f32,availableWidth:f32,availableHeight:f32,viewportWidth:f32,viewportHeight:f32)
    layout_node_sized(element,x,y,availableWidth,availableHeight,viewportWidth,viewportHeight,0.0,0.0)
end

export fn layout(root:Element,width:f32,height:f32)
    layout_node(root,0.0,0.0,width,height,width,height)
end

fn point_inside_element(element:Element,x:f32,y:f32) -> bool
    -- Use branch-by-branch scalar tests so O6 never has to preserve several
    -- float comparison results while forming one compound expression.
    if x < element.x then return false end
    if y < element.y then return false end
    if x > element.x + element.width then return false end
    if y > element.y + element.height then return false end
    return true
end

export fn hit_test(root:Element,x:f32,y:f32) -> Element
    if root == null or root.hidden then return null end
    local style = root.current_style()
    if not style.visibility or not style.pointer_events or style.display == DISPLAY_NONE then return null end

    local inside = point_inside_element(root,x,y)
    local clipsChildren = style.overflow_x ~= OVERFLOW_VISIBLE or style.overflow_y ~= OVERFLOW_VISIBLE
    if not inside and clipsChildren then return null end

    local index = root.children.length() - 1
    while index >= 0 do
        local child = root.children.at(index)
        if child ~= null and not child.hidden then
            local childStyle = child.current_style()
            if childStyle.visibility and childStyle.pointer_events and childStyle.display ~= DISPLAY_NONE then
                local childInside = point_inside_element(child,x,y)
                local childCanOverflow = childStyle.overflow_x == OVERFLOW_VISIBLE or childStyle.overflow_y == OVERFLOW_VISIBLE
                -- Leaf rows that do not contain the pointer are rejected without
                -- a recursive call. This matters for large retained hierarchies.
                if childInside or (child.children.length() > 0 and childCanOverflow) then
                    local result = hit_test(child,x,y)
                    if result ~= null then return result end
                end
            end
        end
        index = index - 1
    end
    if inside then return root end
    return null
end

fn invoke_ui_handler(handler,element:Element,event:UIEvent,context) -> i64
    if handler == null then return 0 end
    local event_pointer = 0
    if event ~= null then event_pointer = memory.ptr(event,0) end
    return ffi.call3(handler,memory.ptr(element,0),event_pointer,context)
end

fn dispatch_ui_event(handler,element:Element,event:UIEvent,context) -> i64
    local result:i64 = 0
    if handler ~= null then result = invoke_ui_handler(handler,element,event,context) end
    if element == null or event == null then return result end
    local eventHash = hash(event.type)
    local index = 0
    while index < element._event_listeners.length() do
        local listener = element._event_listeners.at(index)
        if listener.type_hash == eventHash and listener.handler ~= null then
            result = invoke_ui_handler(listener.handler,element,event,listener.context)
        end
        index = index + 1
    end
    return result
end

fn clear_selected_siblings(element:Element,checkedMode:bool)
    if element == null or element.parent == null then return end
    local siblingIndex = 0
    while siblingIndex < element.parent.children.length() do
        local sibling = element.parent.children.at(siblingIndex)
        if sibling ~= element and sibling.tag_hash == element.tag_hash then
            local sameGroup = true
            if element.name ~= null and sibling.name ~= null then sameGroup = string.equals(element.name,sibling.name) end
            if sameGroup then
                if checkedMode then sibling.checked = false else sibling.selected = false end
                sibling.mark_visual_dirty()
            end
        end
        siblingIndex = siblingIndex + 1
    end
end

fn apply_default_activation(element:Element,event:UIEvent)
    if element == null or element.disabled then return end
    local changed = false
    local checkboxTag = hash("checkbox")
    local toggleTag = hash("toggle")
    local switchTag = hash("switch")
    local switchControlTag = hash("switchcontrol")
    local radioTag = hash("radio")
    local optionTag = hash("option")
    local tabTag = hash("tab")
    if element.tag_hash == checkboxTag or element.tag_hash == toggleTag or element.tag_hash == switchTag or element.tag_hash == switchControlTag then
        element.checked = not element.checked
        changed = true
    elseif element.tag_hash == radioTag then
        clear_selected_siblings(element,true)
        if not element.checked then element.checked = true changed = true end
    elseif element.tag_hash == optionTag or element.tag_hash == tabTag then
        clear_selected_siblings(element,false)
        if not element.selected then element.selected = true changed = true end
    end
    if changed then
        element.mark_visual_dirty()
        event.type = "change"
        dispatch_ui_event(element._on_change,element,event,element._event_context)
    end
end

fn is_text_control(element:Element) -> bool
    if element == null or element.kind ~= ELEMENT_INPUT then return false end
    local tag = element.tag_hash
    if tag == hash("input") or tag == hash("textarea") or tag == hash("search") or tag == hash("password") then return true end
    if tag == hash("email") or tag == hash("url") or tag == hash("tel") or tag == hash("number") then return true end
    if tag == hash("date") or tag == hash("time") or tag == hash("keybind") then return true end
    if tag == hash("colorpicker") then return true end
    return false
end

fn is_multiline_control(element:Element) -> bool
    if element == null then return false end
    return element.tag_hash == hash("textarea") or element.tag_hash == hash("codeeditor") or element.tag_hash == hash("richtext")
end

fn is_range_control(element:Element) -> bool
    if element == null then return false end
    return element.tag_hash == hash("range") or element.tag_hash == hash("slider")
end

export fn is_select_control(element:Element) -> bool
    if element == null or element.kind ~= ELEMENT_INPUT then return false end
    local tag = element.tag_hash
    return tag == hash("select") or tag == hash("combobox") or tag == hash("dropdown")
end

fn is_select_option(element:Element) -> bool
    if element == null then return false end
    return element.tag_hash == hash("option") or element.tag_hash == hash("dropdownitem")
end

export fn select_option_count(element:Element) -> i64
    if not is_select_control(element) then return 0 end
    local count:i64 = 0
    local index:i64 = 0
    while index < element.children.length() do
        if is_select_option(element.children.at(index)) then count = count + 1 end
        index = index + 1
    end
    return count
end

export fn select_option_at(element:Element,optionIndex:i64) -> Element
    if not is_select_control(element) or optionIndex < 0 then return null end
    local found:i64 = 0
    local index:i64 = 0
    while index < element.children.length() do
        local child = element.children.at(index)
        if is_select_option(child) then
            if found == optionIndex then return child end
            found = found + 1
        end
        index = index + 1
    end
    return null
end

fn select_option_text(option:Element) -> string
    if option == null then return null end
    if option.text ~= null and string.length(option.text) > 0 then return option.text end
    return option.value
end

fn select_option_value(option:Element) -> string
    if option == null then return null end
    if option.value ~= null and string.length(option.value) > 0 then return option.value end
    return option.text
end

fn initialize_select_index(element:Element) -> i64
    if not is_select_control(element) then return -1 end
    local count = select_option_count(element)
    if count <= 0 then return -1 end
    if element.selected_index >= 0 and element.selected_index < count then return element.selected_index end
    local chosen:i64 = -1
    local index:i64 = 0
    while index < count do
        local option = select_option_at(element,index)
        local optionValue = select_option_value(option)
        if element.value ~= null and optionValue ~= null and string.equals(element.value,optionValue) then chosen = index end
        if chosen < 0 and option.selected then chosen = index end
        index = index + 1
    end
    if chosen < 0 then chosen = 0 end
    element.selected_index = chosen
    index = 0
    while index < count do
        local selectedOptionItem = select_option_at(element,index)
        selectedOptionItem.selected = index == chosen
        index = index + 1
    end
    return chosen
end

export fn select_display_text(element:Element) -> string
    if not is_select_control(element) then return null end
    local index = initialize_select_index(element)
    if index >= 0 then
        local option = select_option_at(element,index)
        local label = select_option_text(option)
        if label ~= null then return label end
    end
    if element.value ~= null and string.length(element.value) > 0 then return element.value end
    if element.text ~= null and string.length(element.text) > 0 then return element.text end
    return element.placeholder
end

export fn select_set_index(element:Element,index:i64) -> bool
    if not is_select_control(element) then return false end
    local count = select_option_count(element)
    if index < 0 or index >= count then return false end
    local previous = initialize_select_index(element)
    local optionIndex:i64 = 0
    while optionIndex < count do
        local option = select_option_at(element,optionIndex)
        option.selected = optionIndex == index
        optionIndex = optionIndex + 1
    end
    element.selected_index = index
    local selectedOption = select_option_at(element,index)
    local nextValue = select_option_value(selectedOption)
    local valueChanged = previous ~= index
    if nextValue ~= null then
        if element.value == null or not string.equals(element.value,nextValue) then valueChanged = true end
        element.set_value(nextValue)
    else
        element.mark_visual_dirty()
    end
    return valueChanged
end

export fn select_popup_item_height(element:Element) -> f32
    if element == null then return 32.0 end
    local result = element.height
    if result < 30.0 then result = 30.0 end
    if result > 42.0 then result = 42.0 end
    return result
end

export fn select_popup_visible_count(element:Element) -> i64
    local count = select_option_count(element)
    if count > 8 then return 8 end
    return count
end

export fn select_popup_height(element:Element) -> f32
    return select_popup_visible_count(element) * select_popup_item_height(element) + 4.0
end

export fn select_popup_width(element:Element,viewportWidth:f32) -> f32
    if element == null then return 0.0 end
    local result = element.width
    if result < 120.0 then result = 120.0 end
    if viewportWidth > 4.0 and result > viewportWidth - 4.0 then result = viewportWidth - 4.0 end
    return result
end

export fn select_popup_x(element:Element,viewportWidth:f32) -> f32
    if element == null then return 0.0 end
    local popupWidth = select_popup_width(element,viewportWidth)
    local result = element.x
    if result < 2.0 then result = 2.0 end
    if result + popupWidth > viewportWidth - 2.0 then result = viewportWidth - popupWidth - 2.0 end
    if result < 2.0 then result = 2.0 end
    return result
end

export fn select_popup_y(element:Element,viewportHeight:f32) -> f32
    if element == null then return 0.0 end
    local popupHeight = select_popup_height(element)
    local below = element.y + element.height + 3.0
    if below + popupHeight <= viewportHeight then return below end
    local above = element.y - popupHeight - 3.0
    if above >= 0.0 then return above end
    if below < 0.0 then return 0.0 end
    return below
end

export fn select_popup_index_at(element:Element,x:f32,y:f32,viewportWidth:f32,viewportHeight:f32) -> i64
    if element == null or not element.open then return -1 end
    local popupX = select_popup_x(element,viewportWidth)
    local popupWidth = select_popup_width(element,viewportWidth)
    if x < popupX or x > popupX + popupWidth then return -1 end
    local popupY = select_popup_y(element,viewportHeight)
    local popupHeight = select_popup_height(element)
    if y < popupY + 2.0 or y >= popupY + popupHeight - 2.0 then return -1 end
    local itemHeight = select_popup_item_height(element)
    local localIndex:i64 = (y - popupY - 2.0) / itemHeight
    if localIndex < 0 or localIndex >= select_popup_visible_count(element) then return -1 end
    local result = element.popup_scroll_index + localIndex
    if result >= select_option_count(element) then return -1 end
    return result
end

fn input_visual_line_count(element:Element) -> i64
    if element == null then return 1 end
    local text = element.value
    if text == null or string.length(text) == 0 then return 1 end
    local lines:i64 = 1
    local index:i64 = 0
    local length = string.length(text)
    while index < length do
        if string.byte_at(text,index) == 10 then lines = lines + 1 end
        index = index + 1
    end
    return lines
end

fn input_visual_max_columns(element:Element) -> i64
    if element == null then return 0 end
    local text = element.value
    if text == null then return 0 end
    local maximum:i64 = 0
    local current:i64 = 0
    local index:i64 = 0
    local length = string.length(text)
    while index < length do
        if string.byte_at(text,index) == 10 then
            if current > maximum then maximum = current end
            current = 0
        else
            current = current + 1
        end
        index = index + 1
    end
    if current > maximum then maximum = current end
    return maximum
end

export fn effective_scroll_max_y(element:Element) -> f32
    if element == null then return 0.0 end
    if is_text_control(element) and is_multiline_control(element) then
        local style = element.current_style()
        local lineHeight = style.line_height
        if lineHeight <= 0.0 then lineHeight = style.font_size * 1.25 end
        local contentHeight = input_visual_line_count(element) * lineHeight
        local available = element.content_height
        local result = contentHeight - available
        if result < 0.0 then result = 0.0 end
        return result
    end
    return element.scroll_max_y
end

export fn effective_scroll_max_x(element:Element) -> f32
    if element == null then return 0.0 end
    if is_text_control(element) and is_multiline_control(element) then
        local style = element.current_style()
        local approximateWidth = style.font_size * 0.55 + style.letter_spacing
        if approximateWidth < 1.0 then approximateWidth = 1.0 end
        local contentWidth = input_visual_max_columns(element) * approximateWidth
        local result = contentWidth - element.content_width
        if result < 0.0 then result = 0.0 end
        return result
    end
    return element.scroll_max_x
end

export fn effective_scroll_y(element:Element) -> f32
    if element == null then return 0.0 end
    if is_text_control(element) and is_multiline_control(element) then return element.input_scroll_y end
    return element.scroll_y
end

export fn effective_scroll_x(element:Element) -> f32
    if element == null then return 0.0 end
    if is_text_control(element) and is_multiline_control(element) then return element.input_scroll_x end
    return element.scroll_x
end

fn set_effective_scroll_y(element:Element,value:f32)
    if element == null then return end
    if is_text_control(element) and is_multiline_control(element) then element.input_scroll_y = value
    else element.scroll_y = value end
end

fn set_effective_scroll_x(element:Element,value:f32)
    if element == null then return end
    if is_text_control(element) and is_multiline_control(element) then element.input_scroll_x = value
    else element.scroll_x = value end
end

fn is_scrollable_element(element:Element) -> bool
    if element == null then return false end
    local style = element.current_style()
    local horizontal = style.overflow_x == OVERFLOW_SCROLL or style.overflow_x == OVERFLOW_AUTO
    local vertical = style.overflow_y == OVERFLOW_SCROLL or style.overflow_y == OVERFLOW_AUTO
    if horizontal and effective_scroll_max_x(element) > 0.0 then return true end
    if vertical and effective_scroll_max_y(element) > 0.0 then return true end
    return false
end

fn nearest_scrollable(element:Element) -> Element
    local current = element
    while current ~= null do
        if is_scrollable_element(current) then return current end
        current = current.parent
    end
    return null
end

-- Resolve wheel routing from geometry as a fallback instead of depending only
-- on the current leaf hit target. This keeps every independent pane scrollable
-- across empty space, labels, controls, canvas surfaces, and retained children.
fn scrollable_at(root:Element,x:f32,y:f32) -> Element
    if root == null or root.hidden then return null end
    local style = root.current_style()
    if not style.visibility or style.display == DISPLAY_NONE then return null end
    local inside = point_inside_element(root,x,y)
    local clipsChildren = style.overflow_x ~= OVERFLOW_VISIBLE or style.overflow_y ~= OVERFLOW_VISIBLE
    if not inside and clipsChildren then return null end
    local index = root.children.length() - 1
    while index >= 0 do
        local child = root.children.at(index)
        local found = scrollable_at(child,x,y)
        if found ~= null then return found end
        index = index - 1
    end
    if inside and is_scrollable_element(root) then return root end
    return null
end

fn clamp_scroll(element:Element)
    if element == null then return end
    local x = effective_scroll_x(element)
    local y = effective_scroll_y(element)
    local maximumX = effective_scroll_max_x(element)
    local maximumY = effective_scroll_max_y(element)
    if x < 0.0 then x = 0.0 end
    if y < 0.0 then y = 0.0 end
    if x > maximumX then x = maximumX end
    if y > maximumY then y = maximumY end
    set_effective_scroll_x(element,x)
    set_effective_scroll_y(element,y)
end

fn scrollbar_vertical_thumb_height(element:Element) -> f32
    local track = element.height
    if effective_scroll_max_x(element) > 0.0 then track = track - 15.0 end
    if track < 1.0 then return 1.0 end
    local viewport = element.content_height
    if viewport <= 0.0 then viewport = element.height end
    local content = viewport + effective_scroll_max_y(element)
    local thumb = track
    if content > 0.0 then thumb = track * viewport / content end
    if thumb < 24.0 then thumb = 24.0 end
    if thumb > track then thumb = track end
    return thumb
end

fn scrollbar_horizontal_thumb_width(element:Element) -> f32
    local track = element.width
    if effective_scroll_max_y(element) > 0.0 then track = track - 15.0 end
    if track < 1.0 then return 1.0 end
    local viewport = element.content_width
    if viewport <= 0.0 then viewport = element.width end
    local content = viewport + effective_scroll_max_x(element)
    local thumb = track
    if content > 0.0 then thumb = track * viewport / content end
    if thumb < 24.0 then thumb = 24.0 end
    if thumb > track then thumb = track end
    return thumb
end

fn input_cursor_line(buffer:TextBuffer,cursor:i64) -> i64
    if buffer == null then return 0 end
    local line:i64 = 0
    local index:i64 = 0
    if cursor > buffer.length then cursor = buffer.length end
    while index < cursor do
        if memory.read_u8(buffer.buffer,index) == 10 then line = line + 1 end
        index = index + 1
    end
    return line
end

fn input_cursor_column(buffer:TextBuffer,cursor:i64) -> i64
    if buffer == null then return 0 end
    local index = cursor
    if index > buffer.length then index = buffer.length end
    local start = index
    while start > 0 do
        if memory.read_u8(buffer.buffer,start-1) == 10 then return index-start end
        start = start - 1
    end
    return index
end

fn input_leading_visual_width(element:Element) -> f32
    if element == null then return 0.0 end
    if element.tag_hash ~= hash("colorpicker") then return 0.0 end
    local swatchSize = element.content_height
    if swatchSize > 28.0 then swatchSize = 28.0 end
    if swatchSize < 14.0 then swatchSize = 14.0 end
    return swatchSize+10.0
end

fn ensure_input_cursor_visible(element:Element)
    if element == null or not is_text_control(element) then return end
    local buffer = element.ensure_input_buffer()
    local style = element.current_style()
    local approximateWidth = style.font_size * 0.55 + style.letter_spacing
    if approximateWidth < 1.0 then approximateWidth = 1.0 end
    local lineHeight = style.line_height
    if lineHeight <= 0.0 then lineHeight = style.font_size * 1.25 end
    local cursorX = input_cursor_column(buffer,element.cursor_index) * approximateWidth
    local cursorY = input_cursor_line(buffer,element.cursor_index) * lineHeight
    local availableWidth = element.content_width-input_leading_visual_width(element)-4.0
    local availableHeight = element.content_height - 4.0
    if availableWidth < approximateWidth then availableWidth = approximateWidth end
    if availableHeight < lineHeight then availableHeight = lineHeight end
    local previousX = element.input_scroll_x
    local previousY = element.input_scroll_y
    if cursorX < element.input_scroll_x then element.input_scroll_x = cursorX end
    if cursorX > element.input_scroll_x + availableWidth then element.input_scroll_x = cursorX - availableWidth end
    if element.input_scroll_x < 0.0 then element.input_scroll_x = 0.0 end
    if is_multiline_control(element) then
        if cursorY < element.input_scroll_y then element.input_scroll_y = cursorY end
        if cursorY + lineHeight > element.input_scroll_y + availableHeight then element.input_scroll_y = cursorY + lineHeight - availableHeight end
        if element.input_scroll_y < 0.0 then element.input_scroll_y = 0.0 end
    else
        element.input_scroll_y = 0.0
    end
    if previousX ~= element.input_scroll_x or previousY ~= element.input_scroll_y then element.mark_visual_dirty() end
end

fn set_input_cursor_from_pointer(element:Element,x:f32,y:f32,extend:bool)
    if element == null or not is_text_control(element) then return end
    local buffer = element.ensure_input_buffer()
    local style = element.current_style()
    local approximateWidth = style.font_size * 0.55 + style.letter_spacing
    if approximateWidth < 1.0 then approximateWidth = 1.0 end
    local lineHeight = style.line_height
    if lineHeight <= 0.0 then lineHeight = style.font_size * 1.25 end
    local targetLine:i64 = 0
    if is_multiline_control(element) then
        local relativeY = y - element.content_y + element.input_scroll_y
        if relativeY > 0.0 then targetLine = relativeY / lineHeight end
    end
    local line:i64 = 0
    local lineStart:i64 = 0
    local lineEnd:i64 = buffer.length
    local index:i64 = 0
    while index < buffer.length do
        local byteValue = memory.read_u8(buffer.buffer,index)
        if byteValue == 10 then
            if line == targetLine then lineEnd = index index = buffer.length
            else line = line + 1 lineStart = index + 1 end
        end
        index = index + 1
    end
    if targetLine > line then lineStart = buffer.length lineEnd = buffer.length end
    local relativeX = x-element.content_x-input_leading_visual_width(element)+element.input_scroll_x
    local column:i64 = 0
    if relativeX > 0.0 then column = relativeX / approximateWidth + 0.5 end
    local cursor = lineStart + column
    if cursor > lineEnd then cursor = lineEnd end
    if cursor < lineStart then cursor = lineStart end
    if extend then
        element.selection_focus = cursor
    else
        element.selection_anchor = cursor
        element.selection_focus = cursor
    end
    element.cursor_index = cursor
    ensure_input_cursor_visible(element)
    element.mark_visual_dirty()
end

fn delete_input_selection(element:Element) -> bool
    if element == null or not element.has_selection() then return false end
    local buffer = element.ensure_input_buffer()
    local start = element.selection_start()
    local finish = element.selection_end()
    if finish <= start then return false end
    buffer.erase(start,finish-start)
    element.value = buffer.value
    element.cursor_index = start
    element.selection_anchor = start
    element.selection_focus = start
    return true
end

fn move_input_cursor(element:Element,index:i64,extend:bool)
    if element == null then return end
    local buffer = element.ensure_input_buffer()
    if index < 0 then index = 0 end
    if index > buffer.length then index = buffer.length end
    element.cursor_index = index
    if extend then element.selection_focus = index
    else element.selection_anchor = index element.selection_focus = index end
    ensure_input_cursor_visible(element)
    element.mark_visual_dirty()
end

fn line_start_for_cursor(buffer:TextBuffer,cursor:i64) -> i64
    if buffer == null then return 0 end
    local index = cursor
    if index > buffer.length then index = buffer.length end
    while index > 0 do
        if memory.read_u8(buffer.buffer,index-1) == 10 then return index end
        index = index - 1
    end
    return 0
end

fn line_end_for_cursor(buffer:TextBuffer,cursor:i64) -> i64
    if buffer == null then return 0 end
    local index = cursor
    if index < 0 then index = 0 end
    while index < buffer.length do
        if memory.read_u8(buffer.buffer,index) == 10 then return index end
        index = index + 1
    end
    return buffer.length
end

fn copy_input_selection(window:ptr,element:Element)
    if window == 0 or element == null or not element.has_selection() then return end
    local buffer = element.ensure_input_buffer()
    local start = element.selection_start()
    local finish = element.selection_end()
    local count = finish - start
    if count <= 0 then return end
    local temporary = memory.alloc(count + 1)
    if temporary == 0 then return end
    local index:i64 = 0
    while index < count do
        memory.write_u8(temporary,index,memory.read_u8(buffer.buffer,start+index))
        index = index + 1
    end
    memory.write_u8(temporary,count,0)
    GLFW.glfwSetClipboardString(window,string.from_utf8(temporary))
    memory.free(temporary)
end

fn collect_focusable(element:Element,items)
    if element == null or element.hidden then return end
    local style = element.current_style()
    if not style.visibility or style.display == DISPLAY_NONE then return end
    if element.focusable and not element.disabled then items.push(element) end
    local index = 0
    while index < element.children.length() do
        collect_focusable(element.children.at(index),items)
        index = index + 1
    end
end

fn update_range_from_pointer(element:Element,x:f32) -> bool
    if element == null or not is_range_control(element) then return false end
    local width = element.content_width
    if width <= 0.0 then width = element.width end
    if width <= 0.0 then return false end
    local startX = element.content_x
    if element.content_width <= 0.0 then startX = element.x end
    local ratio = (x - startX) / width
    if ratio < 0.0 then ratio = 0.0 end
    if ratio > 1.0 then ratio = 1.0 end
    local minimum = element.min_value
    local maximum = element.max_value
    if maximum <= minimum then maximum = minimum + 1.0 end
    local next = minimum + (maximum - minimum) * ratio
    if element.step_value > 0.0 then
        local stepIndex:i64 = (next - minimum) / element.step_value + 0.5
        next = minimum + stepIndex * element.step_value
    end
    if next < minimum then next = minimum end
    if next > maximum then next = maximum end
    if next == element.number_value then return false end
    element.number_value = next
    element.mark_visual_dirty()
    return true
end

fn collect_selector_matches(element:Element,mode:i32,value:u32,output)
    if element == null then return end
    local matches = false
    if mode == 1 then matches = element.id_hash == value
    elseif mode == 2 then matches = element.has_class_hash(value)
    elseif mode == 4 then matches = element._compact_tag_hash == value
    else matches = element.tag_hash == value end
    if matches then output.push(element) end
    local index = 0
    while index < element.children.length() do
        collect_selector_matches(element.children.at(index),mode,value,output)
        index = index + 1
    end
end

export const Document = {
    root:Element = null,
    hovered:Element = null,
    active:Element = null,
    focused:Element = null,
    scroll_drag_target:Element = null,
    scroll_drag_axis:i32 = 0,
    scroll_drag_offset:f32 = 0.0,
    text_selecting:bool = false,
    open_select:Element = null,
    select_press_index:i64 = -1,
    event:UIEvent = null,
    width:f32 = 0.0,
    height:f32 = 0.0,
    pointer_x:f32 = 0.0,
    pointer_y:f32 = 0.0,
    pointer_button:i32 = 0,
    pointer_valid:bool = false,
    pointer_hit_dirty:bool = true,

    set_root = fn(value:Element)
        self.root = value
        self.pointer_hit_dirty = true
    end,

    -- Finds the first retained LSHTML element using a simple CSS selector.
    -- Use #id, .class, or a tag name such as button. Empty or invalid selectors
    -- return null and do not allocate.
    find = fn(selector:string) -> Element
        if self.root == null or selector == null then return null end
        local length = string.length(selector)
        if length <= 0 then return null end
        local first = string.byte_at(selector,0)
        if first == 35 then
            if length <= 1 then return null end
            return self.root.find_id(hash_range(selector,1,length))
        end
        if first == 46 then
            if length <= 1 then return null end
            return self.root.find_class(hash_range(selector,1,length))
        end
        local found = self.root.find_tag(hash(selector))
        if found ~= null then return found end
        return self.root._find_compact_tag(compact_tag_hash(selector))
    end,

    -- Finds every retained LSHTML element matching #id, .class, or a tag. The
    -- returned table owns only its collection storage; the elements remain owned
    -- by the document tree. Destroy the result table when it is no longer needed.
    find_all = fn(selector:string)
        local result = {}
        if self.root == null or selector == null then return result end
        local length = string.length(selector)
        if length <= 0 then return result end
        local first = string.byte_at(selector,0)
        local mode = 3
        local selectorHash:u32 = 0
        if first == 35 then
            if length <= 1 then return result end
            mode = 1
            selectorHash = hash_range(selector,1,length)
        elseif first == 46 then
            if length <= 1 then return result end
            mode = 2
            selectorHash = hash_range(selector,1,length)
        else
            selectorHash = hash(selector)
            if self.root.find_tag(selectorHash) == null then
                mode = 4
                selectorHash = compact_tag_hash(selector)
            end
        end
        collect_selector_matches(self.root,mode,selectorHash,result)
        return result
    end,

    _set_hover_target = fn(target:Element)
        if self.hovered == target then return end
        if self.hovered ~= null then
            self.hovered.hovered = false
            self.hovered.mark_visual_dirty()
        end
        self.hovered = target
        if self.hovered ~= null then
            self.hovered.hovered = true
            self.hovered.mark_visual_dirty()
        end
    end,

    _refresh_hover = fn(force:bool)
        if self.root == null or not self.pointer_valid then return end
        if not force and not self.pointer_hit_dirty and not self.root.layout_dirty then return end
        local popupIndex:i64 = -1
        if self.open_select ~= null then popupIndex = select_popup_index_at(self.open_select,self.pointer_x,self.pointer_y,self.width,self.height) end
        local target = null
        if popupIndex >= 0 then target = self.open_select
        else target = hit_test(self.root,self.pointer_x,self.pointer_y) end
        self._set_hover_target(target)
        self.pointer_hit_dirty = false
    end,

    resize = fn(width:f32,height:f32)
        local sizeChanged = self.width ~= width or self.height ~= height
        self.width = width
        self.height = height
        if self.root ~= null and (sizeChanged or self.root.layout_dirty) then
            layout(self.root,width,height)
            self.pointer_hit_dirty = true
            self._refresh_hover(true)
        end
    end,

    _event = fn(type:string,target:Element) -> UIEvent
        if self.event == null then self.event = UIEvent.new() end
        self.event.reset()
        self.event.type = type
        self.event.x = self.pointer_x
        self.event.y = self.pointer_y
        self.event.target = target
        self.event.current_target = target
        return self.event
    end,

    _emit_input = fn(element:Element)
        if element == null then return end
        element.mark_visual_dirty()
        local event = self._event("input",element)
        event.text = element.value
        dispatch_ui_event(element._on_input,element,event,element._event_context)
    end,

    _emit_change = fn(element:Element)
        if element == null then return end
        local event = self._event("change",element)
        dispatch_ui_event(element._on_change,element,event,element._event_context)
    end,

    _try_begin_scrollbar_drag = fn() -> bool
        -- Resolve the scroll owner from retained geometry rather than walking
        -- parent pointers from the leaf hit. LSHTML elements are retained in
        -- growable typed tables, so geometry routing is both safer and cheaper
        -- than a potentially stale ancestry chain during construction changes.
        local candidate = scrollable_at(self.root,self.pointer_x,self.pointer_y)
        if candidate == null then return false end
        local style = candidate.current_style()
        local vertical = effective_scroll_max_y(candidate) > 0.0 and (style.overflow_y == OVERFLOW_SCROLL or style.overflow_y == OVERFLOW_AUTO)
        local horizontal = effective_scroll_max_x(candidate) > 0.0 and (style.overflow_x == OVERFLOW_SCROLL or style.overflow_x == OVERFLOW_AUTO)
        if vertical and self.pointer_x >= candidate.x + candidate.width - 15.0 then
            local trackHeight = candidate.height
            if horizontal then trackHeight = trackHeight - 15.0 end
            local thumbHeight = scrollbar_vertical_thumb_height(candidate)
            local travel = trackHeight - thumbHeight
            local thumbY = candidate.y
            local candidateMaximumY = effective_scroll_max_y(candidate)
            if candidateMaximumY > 0.0 and travel > 0.0 then thumbY = candidate.y + effective_scroll_y(candidate) / candidateMaximumY * travel end
            self.scroll_drag_target = candidate
            self.scroll_drag_axis = 2
            if self.pointer_y >= thumbY and self.pointer_y <= thumbY + thumbHeight then
                self.scroll_drag_offset = self.pointer_y - thumbY
            else
                self.scroll_drag_offset = thumbHeight * 0.5
                local nextY = self.pointer_y - candidate.y - self.scroll_drag_offset
                if nextY < 0.0 then nextY = 0.0 end
                if nextY > travel then nextY = travel end
                if travel > 0.0 then set_effective_scroll_y(candidate,nextY / travel * candidateMaximumY) end
                candidate.mark_layout_dirty()
                self.pointer_hit_dirty = true
            end
            return true
        end
        if horizontal and self.pointer_y >= candidate.y + candidate.height - 15.0 then
            local trackWidth = candidate.width
            if vertical then trackWidth = trackWidth - 15.0 end
            local thumbWidth = scrollbar_horizontal_thumb_width(candidate)
            local horizontalTravel = trackWidth - thumbWidth
            local thumbX = candidate.x
            local candidateMaximumX = effective_scroll_max_x(candidate)
            if candidateMaximumX > 0.0 and horizontalTravel > 0.0 then thumbX = candidate.x + effective_scroll_x(candidate) / candidateMaximumX * horizontalTravel end
            self.scroll_drag_target = candidate
            self.scroll_drag_axis = 1
            if self.pointer_x >= thumbX and self.pointer_x <= thumbX + thumbWidth then
                self.scroll_drag_offset = self.pointer_x - thumbX
            else
                self.scroll_drag_offset = thumbWidth * 0.5
                local nextX = self.pointer_x - candidate.x - self.scroll_drag_offset
                if nextX < 0.0 then nextX = 0.0 end
                if nextX > horizontalTravel then nextX = horizontalTravel end
                if horizontalTravel > 0.0 then set_effective_scroll_x(candidate,nextX / horizontalTravel * candidateMaximumX) end
                candidate.mark_layout_dirty()
                self.pointer_hit_dirty = true
            end
            return true
        end
        return false
    end,

    -- GLFW cursor coordinates are expressed in window coordinates while LazyUI
    -- is laid out in framebuffer pixels. On a high-DPI display those coordinate
    -- spaces differ, which otherwise makes drags jump, pins miss their targets,
    -- and color pickers update from the wrong location.
    pointer_move_scaled = fn(x:f32,y:f32,window_width:f32,window_height:f32)
        local mapped_x = x
        local mapped_y = y
        if window_width > 0.0 and self.width > 0.0 then mapped_x = x * self.width / window_width end
        if window_height > 0.0 and self.height > 0.0 then mapped_y = y * self.height / window_height end
        self.pointer_move(mapped_x,mapped_y)
    end,

    pointer_move = fn(x:f32,y:f32)
        if self.pointer_valid and self.pointer_x == x and self.pointer_y == y and self.scroll_drag_target == null and not self.text_selecting and not self.pointer_hit_dirty and (self.root == null or not self.root.layout_dirty) then return end
        self.pointer_valid = true
        self.pointer_x = x
        self.pointer_y = y

        if self.scroll_drag_target ~= null then
            local target = self.scroll_drag_target
            if self.scroll_drag_axis == 2 then
                local track = target.height
                if effective_scroll_max_x(target) > 0.0 then track = track - 15.0 end
                local thumb = scrollbar_vertical_thumb_height(target)
                local travel = track - thumb
                local next = y - target.y - self.scroll_drag_offset
                if next < 0.0 then next = 0.0 end
                if next > travel then next = travel end
                local targetMaximumY = effective_scroll_max_y(target)
                if travel > 0.0 then set_effective_scroll_y(target,next / travel * targetMaximumY) end
            else
                local horizontalTrack = target.width
                if effective_scroll_max_y(target) > 0.0 then horizontalTrack = horizontalTrack - 15.0 end
                local horizontalThumb = scrollbar_horizontal_thumb_width(target)
                local horizontalTravel = horizontalTrack - horizontalThumb
                local horizontalNext = x - target.x - self.scroll_drag_offset
                if horizontalNext < 0.0 then horizontalNext = 0.0 end
                if horizontalNext > horizontalTravel then horizontalNext = horizontalTravel end
                local targetMaximumX = effective_scroll_max_x(target)
                if horizontalTravel > 0.0 then set_effective_scroll_x(target,horizontalNext / horizontalTravel * targetMaximumX) end
            end
            target.mark_layout_dirty()
            self.pointer_hit_dirty = true
            return
        end

        if self.active ~= null and is_range_control(self.active) then
            if update_range_from_pointer(self.active,x) then self._emit_input(self.active) end
        elseif self.text_selecting and self.active ~= null and is_text_control(self.active) then
            set_input_cursor_from_pointer(self.active,x,y,true)
        end

        local popupIndex:i64 = -1
        if self.open_select ~= null then
            popupIndex = select_popup_index_at(self.open_select,x,y,self.width,self.height)
            if self.open_select.popup_hover_index ~= popupIndex then
                self.open_select.popup_hover_index = popupIndex
                self.open_select.mark_visual_dirty()
            end
        end

        local hoverTarget = null
        if popupIndex >= 0 then hoverTarget = self.open_select
        else hoverTarget = hit_test(self.root,x,y) end
        self._set_hover_target(hoverTarget)
        self.pointer_hit_dirty = false
        -- While a pointer is down, route movement to the element that received
        -- pointer_down. This is implicit pointer capture and is required for
        -- real drags (node headers, graph pins, color planes, splitters, etc.).
        -- Hover still updates independently for drop-target feedback.
        local moveTarget = self.hovered
        if self.active ~= null and self.active._on_pointer_move ~= null then moveTarget = self.active end
        if moveTarget ~= null and moveTarget._on_pointer_move ~= null then
            local event = self._event("pointermove",moveTarget)
            dispatch_ui_event(moveTarget._on_pointer_move,moveTarget,event,moveTarget._event_context)
        end
    end,

    pointer_down = fn()
        self._refresh_hover(true)
        self.select_press_index = -1
        if self.open_select ~= null then
            local popupIndex = select_popup_index_at(self.open_select,self.pointer_x,self.pointer_y,self.width,self.height)
            if popupIndex >= 0 then
                self.active = self.open_select
                self.select_press_index = popupIndex
                self.active.active = true
                self.active.mark_visual_dirty()
                if self.active.focusable then self.focus(self.active) end
                return
            end
            local onOpenField = point_inside_element(self.open_select,self.pointer_x,self.pointer_y)
            if not onOpenField then
                self.open_select.open = false
                self.open_select.popup_hover_index = -1
                self.open_select.mark_visual_dirty()
                self.open_select = null
            end
        end
        if self._try_begin_scrollbar_drag() then return end
        self.active = self.hovered
        if self.active ~= null and self.active.disabled then self.active = null end
        if self.active ~= null then
            self.active.active = true
            self.active.mark_visual_dirty()
            local event = self._event("pointerdown",self.active)
            event.button = self.pointer_button
            dispatch_ui_event(self.active._on_pointer_down,self.active,event,self.active._event_context)
            if is_text_control(self.active) then
                self.active.ensure_input_buffer()
                set_input_cursor_from_pointer(self.active,self.pointer_x,self.pointer_y,false)
                self.text_selecting = true
            elseif is_range_control(self.active) then
                if update_range_from_pointer(self.active,self.pointer_x) then self._emit_input(self.active) end
            end
            if self.active.focusable then self.focus(self.active) end
        else
            self.focus(null)
        end
    end,

    pointer_down_button = fn(button:i32)
        self.pointer_button = button
        self.pointer_down()
    end,

    pointer_up = fn()
        if self.scroll_drag_target ~= null then
            self.scroll_drag_target = null
            self.scroll_drag_axis = 0
            self.scroll_drag_offset = 0.0
            return
        end
        if self.active ~= null then
            local event = self._event("pointerup",self.active)
            event.button = self.pointer_button
            dispatch_ui_event(self.active._on_pointer_up,self.active,event,self.active._event_context)
            if self.select_press_index >= 0 and is_select_control(self.active) then
                local releaseIndex = select_popup_index_at(self.active,self.pointer_x,self.pointer_y,self.width,self.height)
                if releaseIndex == self.select_press_index then
                    local selectionChanged = select_set_index(self.active,releaseIndex)
                    if selectionChanged then self._emit_input(self.active) self._emit_change(self.active) end
                end
                self.active.open = false
                self.active.popup_hover_index = -1
                self.active.mark_visual_dirty()
                self.open_select = null
            elseif is_range_control(self.active) then
                self._emit_change(self.active)
            elseif is_select_control(self.active) and self.active == self.hovered and not self.active.disabled and not event.default_prevented then
                if self.open_select ~= null and self.open_select ~= self.active then
                    self.open_select.open = false
                    self.open_select.popup_hover_index = -1
                    self.open_select.mark_visual_dirty()
                end
                initialize_select_index(self.active)
                self.active.open = not self.active.open
                if self.active.open then self.open_select = self.active else self.open_select = null end
                self.active.mark_visual_dirty()
                event.type = "click"
                dispatch_ui_event(self.active._on_click,self.active,event,self.active._event_context)
            elseif self.active == self.hovered and not self.active.disabled and not event.default_prevented then
                apply_default_activation(self.active,event)
                event.type = "click"
                dispatch_ui_event(self.active._on_click,self.active,event,self.active._event_context)
            end
            self.active.active = false
            self.active.mark_visual_dirty()
        end
        self.active = null
        self.select_press_index = -1
        self.text_selecting = false
    end,

    pointer_up_button = fn(button:i32)
        self.pointer_button = button
        self.pointer_up()
    end,

    scroll = fn(deltaX:f32,deltaY:f32)
        -- Wheel routing is resolved from the current pointer coordinates every
        -- time instead of depending on a stale global hover record. Each
        -- scrollable element owns its own scroll_x/scroll_y state, so several
        -- inspector, hierarchy, browser, console, textarea, and popup panes can
        -- scroll independently in the same document.
        self._refresh_hover(true)
        if self.open_select ~= null then
            local popupIndex = select_popup_index_at(self.open_select,self.pointer_x,self.pointer_y,self.width,self.height)
            if popupIndex >= 0 then
                local count = select_option_count(self.open_select)
                local visible = select_popup_visible_count(self.open_select)
                local maximumStart = count - visible
                if maximumStart < 0 then maximumStart = 0 end
                local nextStart = self.open_select.popup_scroll_index
                if deltaY > 0.0 then nextStart = nextStart - 1
                elseif deltaY < 0.0 then nextStart = nextStart + 1 end
                if nextStart < 0 then nextStart = 0 end
                if nextStart > maximumStart then nextStart = maximumStart end
                if nextStart ~= self.open_select.popup_scroll_index then
                    self.open_select.popup_scroll_index = nextStart
                    self.open_select.popup_hover_index = select_popup_index_at(self.open_select,self.pointer_x,self.pointer_y,self.width,self.height)
                    self.open_select.mark_visual_dirty()
                end
                return
            end
        end
        -- Custom surfaces such as infinite node graphs can consume wheel input
        -- without pretending to have a finite native scroll range. Walk up from
        -- the current hit target and give the nearest onscroll handler first
        -- refusal; normal overflow scrolling continues when it does not prevent
        -- the default action.
        local customTarget = self.hovered
        while customTarget ~= null and customTarget._on_scroll == null do customTarget = customTarget.parent end
        if customTarget ~= null then
            local customEvent = self._event("scroll",customTarget)
            customEvent.delta_x = deltaX
            customEvent.delta_y = deltaY
            dispatch_ui_event(customTarget._on_scroll,customTarget,customEvent,customTarget._event_context)
            if customEvent.default_prevented then return end
        end
        local target = scrollable_at(self.root,self.pointer_x,self.pointer_y)
        if target == null and self.hovered ~= null then target = nearest_scrollable(self.hovered) end
        if target == null then return end
        local event = self._event("scroll",target)
        event.delta_x = deltaX
        event.delta_y = deltaY
        if target ~= customTarget then dispatch_ui_event(target._on_scroll,target,event,target._event_context) end
        if not event.default_prevented then
            local previousX = effective_scroll_x(target)
            local previousY = effective_scroll_y(target)
            set_effective_scroll_x(target,previousX - deltaX * 42.0)
            set_effective_scroll_y(target,previousY - deltaY * 42.0)
            clamp_scroll(target)
            if previousX ~= effective_scroll_x(target) or previousY ~= effective_scroll_y(target) then
                if is_text_control(target) then target.mark_visual_dirty() else target.mark_layout_dirty() end
                self.pointer_hit_dirty = true
            end
        end
    end,

    focus = fn(element:Element)
        if self.focused == element then return end
        if self.open_select ~= null and element ~= self.open_select then
            self.open_select.open = false
            self.open_select.popup_hover_index = -1
            self.open_select.mark_visual_dirty()
            self.open_select = null
        end
        if self.focused ~= null then
            local previous = self.focused
            previous.focused = false
            previous.mark_visual_dirty()
            local blurEvent = self._event("blur",previous)
            dispatch_ui_event(previous._on_blur,previous,blurEvent,previous._event_context)
            if is_text_control(previous) then self._emit_change(previous) end
        end
        self.focused = element
        if self.focused ~= null then
            self.focused.focused = true
            if is_text_control(self.focused) then self.focused.ensure_input_buffer() ensure_input_cursor_visible(self.focused) end
            self.focused.mark_visual_dirty()
            local focusEvent = self._event("focus",self.focused)
            dispatch_ui_event(self.focused._on_focus,self.focused,focusEvent,self.focused._event_context)
        end
    end,

    focus_next = fn(reverse:bool)
        local items = {}
        collect_focusable(self.root,items)
        if items.length() == 0 then items.destroy() return end
        local current:i64 = -1
        local index:i64 = 0
        while index < items.length() do
            if items[index] == self.focused then current = index end
            index = index + 1
        end
        local next:i64 = current + 1
        if reverse then next = current - 1 end
        if next >= items.length() then next = 0 end
        if next < 0 then next = items.length() - 1 end
        self.focus(items[next])
        items.destroy()
    end,

    key_down_window = fn(key:i32,modifiers:i32,window:ptr)
        if key == GLFW.GLFW_KEY_TAB then
            self.focus_next((modifiers % 2) == 1)
            return
        end
        if key == GLFW.GLFW_KEY_PAGE_UP or key == GLFW.GLFW_KEY_PAGE_DOWN then
            local scrollTarget = nearest_scrollable(self.hovered)
            if scrollTarget == null then scrollTarget = nearest_scrollable(self.focused) end
            if scrollTarget ~= null then
                local scrollAmount = scrollTarget.content_height * 0.82
                if scrollAmount < 42.0 then scrollAmount = 42.0 end
                local pageY = effective_scroll_y(scrollTarget)
                if key == GLFW.GLFW_KEY_PAGE_UP then pageY = pageY - scrollAmount
                else pageY = pageY + scrollAmount end
                set_effective_scroll_y(scrollTarget,pageY)
                clamp_scroll(scrollTarget)
                if is_text_control(scrollTarget) then scrollTarget.mark_visual_dirty() else scrollTarget.mark_layout_dirty() end
                return
            end
        end
        if self.focused == null then return end
        local event = self._event("keydown",self.focused)
        event.key = key
        event.modifiers = modifiers
        dispatch_ui_event(self.focused._on_key_down,self.focused,event,self.focused._event_context)
        if event.default_prevented then return end

        local control = (modifiers / GLFW.GLFW_MOD_CONTROL % 2) == 1 or (modifiers / GLFW.GLFW_MOD_SUPER % 2) == 1
        local shift = (modifiers / GLFW.GLFW_MOD_SHIFT % 2) == 1
        if is_select_control(self.focused) and not self.focused.disabled then
            local selectElement = self.focused
            local count = select_option_count(selectElement)
            local currentIndex = initialize_select_index(selectElement)
            if key == GLFW.GLFW_KEY_ESCAPE then
                selectElement.open = false
                selectElement.popup_hover_index = -1
                selectElement.mark_visual_dirty()
                self.open_select = null
                return
            end
            if key == GLFW.GLFW_KEY_ENTER or key == GLFW.GLFW_KEY_SPACE then
                selectElement.open = not selectElement.open
                if selectElement.open then self.open_select = selectElement else self.open_select = null end
                selectElement.mark_visual_dirty()
                return
            end
            local nextIndex = currentIndex
            if key == GLFW.GLFW_KEY_UP or key == GLFW.GLFW_KEY_LEFT then nextIndex = currentIndex - 1
            elseif key == GLFW.GLFW_KEY_DOWN or key == GLFW.GLFW_KEY_RIGHT then nextIndex = currentIndex + 1
            else nextIndex = -1 end
            if nextIndex >= 0 and count > 0 then
                if nextIndex >= count then nextIndex = count - 1 end
                if select_set_index(selectElement,nextIndex) then self._emit_input(selectElement) self._emit_change(selectElement) end
                local visible = select_popup_visible_count(selectElement)
                if nextIndex < selectElement.popup_scroll_index then selectElement.popup_scroll_index = nextIndex end
                if nextIndex >= selectElement.popup_scroll_index + visible then selectElement.popup_scroll_index = nextIndex - visible + 1 end
                selectElement.popup_hover_index = nextIndex
                selectElement.mark_visual_dirty()
                return
            end
        elseif is_text_control(self.focused) and not self.focused.read_only and not self.focused.disabled then
            local element = self.focused
            local buffer = element.ensure_input_buffer()
            if control and key == GLFW.GLFW_KEY_A then element.select_all() ensure_input_cursor_visible(element) return end
            if control and key == GLFW.GLFW_KEY_C then copy_input_selection(window,element) return end
            if control and key == GLFW.GLFW_KEY_X then
                copy_input_selection(window,element)
                if delete_input_selection(element) then ensure_input_cursor_visible(element) self._emit_input(element) end
                return
            end
            if control and key == GLFW.GLFW_KEY_V then
                local clipboard = GLFW.glfwGetClipboardString(window)
                if clipboard ~= null then
                    delete_input_selection(element)
                    local written = buffer.insert_text(element.cursor_index,clipboard,is_multiline_control(element),element.max_length)
                    if written > 0 then
                        element.cursor_index = element.cursor_index + written
                        element.selection_anchor = element.cursor_index
                        element.selection_focus = element.cursor_index
                        element.value = buffer.value
                        ensure_input_cursor_visible(element)
                        self._emit_input(element)
                    end
                end
                return
            end
            if key == GLFW.GLFW_KEY_BACKSPACE then
                local changed = delete_input_selection(element)
                if not changed and element.cursor_index > 0 then
                    local previous = previous_utf8_index(buffer,element.cursor_index)
                    changed = buffer.erase(previous,element.cursor_index-previous)
                    element.cursor_index = previous
                    element.selection_anchor = previous
                    element.selection_focus = previous
                end
                if changed then element.value = buffer.value ensure_input_cursor_visible(element) self._emit_input(element) end
                return
            end
            if key == GLFW.GLFW_KEY_DELETE then
                local deleteChanged = delete_input_selection(element)
                if not deleteChanged and element.cursor_index < buffer.length then
                    local deleteNext = next_utf8_index(buffer,element.cursor_index)
                    deleteChanged = buffer.erase(element.cursor_index,deleteNext-element.cursor_index)
                end
                if deleteChanged then element.value = buffer.value ensure_input_cursor_visible(element) self._emit_input(element) end
                return
            end
            if key == GLFW.GLFW_KEY_LEFT then
                local leftCursor = previous_utf8_index(buffer,element.cursor_index)
                if not shift and element.has_selection() then leftCursor = element.selection_start() end
                move_input_cursor(element,leftCursor,shift)
                return
            end
            if key == GLFW.GLFW_KEY_RIGHT then
                local rightCursor = next_utf8_index(buffer,element.cursor_index)
                if not shift and element.has_selection() then rightCursor = element.selection_end() end
                move_input_cursor(element,rightCursor,shift)
                return
            end
            if is_multiline_control(element) and key == GLFW.GLFW_KEY_UP then
                local currentStart = line_start_for_cursor(buffer,element.cursor_index)
                local currentColumn = element.cursor_index - currentStart
                local upTarget = currentStart
                if currentStart > 0 then
                    local previousEnd = currentStart - 1
                    local previousStart = line_start_for_cursor(buffer,previousEnd)
                    local previousLength = previousEnd - previousStart
                    if currentColumn > previousLength then currentColumn = previousLength end
                    upTarget = previousStart + currentColumn
                end
                move_input_cursor(element,upTarget,shift)
                return
            end
            if is_multiline_control(element) and key == GLFW.GLFW_KEY_DOWN then
                local currentEnd = line_end_for_cursor(buffer,element.cursor_index)
                local currentLineStart = line_start_for_cursor(buffer,element.cursor_index)
                local downColumn = element.cursor_index - currentLineStart
                local downTarget = currentEnd
                if currentEnd < buffer.length then
                    local nextStart = currentEnd + 1
                    local nextEnd = line_end_for_cursor(buffer,nextStart)
                    local nextLength = nextEnd - nextStart
                    if downColumn > nextLength then downColumn = nextLength end
                    downTarget = nextStart + downColumn
                end
                move_input_cursor(element,downTarget,shift)
                return
            end
            if key == GLFW.GLFW_KEY_HOME then move_input_cursor(element,line_start_for_cursor(buffer,element.cursor_index),shift) return end
            if key == GLFW.GLFW_KEY_END then move_input_cursor(element,line_end_for_cursor(buffer,element.cursor_index),shift) return end
            if key == GLFW.GLFW_KEY_ENTER then
                if is_multiline_control(element) then self.input_codepoint(10)
                else self._emit_change(element) end
                return
            end
            if key == GLFW.GLFW_KEY_ESCAPE then self.focus(null) return end
        elseif is_range_control(self.focused) then
            local direction:f32 = 0.0
            if key == GLFW.GLFW_KEY_LEFT or key == GLFW.GLFW_KEY_DOWN then direction = -1.0 end
            if key == GLFW.GLFW_KEY_RIGHT or key == GLFW.GLFW_KEY_UP then direction = 1.0 end
            if direction ~= 0.0 then
                local step = self.focused.step_value
                if step <= 0.0 then step = (self.focused.max_value-self.focused.min_value)/100.0 end
                self.focused.number_value = self.focused.number_value + direction * step
                if self.focused.number_value < self.focused.min_value then self.focused.number_value = self.focused.min_value end
                if self.focused.number_value > self.focused.max_value then self.focused.number_value = self.focused.max_value end
                self.focused.mark_visual_dirty()
                self._emit_input(self.focused)
                self._emit_change(self.focused)
                return
            end
        end
        if (key == GLFW.GLFW_KEY_ENTER or key == GLFW.GLFW_KEY_SPACE) and not is_select_control(self.focused) then
            apply_default_activation(self.focused,event)
        end
    end,

    key_down = fn(key:i32,modifiers:i32)
        self.key_down_window(key,modifiers,0)
    end,

    key_up = fn(key:i32,modifiers:i32)
        if self.focused == null then return end
        local event = self._event("keyup",self.focused)
        event.key = key
        event.modifiers = modifiers
        dispatch_ui_event(self.focused._on_key_up,self.focused,event,self.focused._event_context)
    end,

    input_codepoint = fn(codepoint:u32)
        if self.focused == null or not is_text_control(self.focused) then return end
        if self.focused.read_only or self.focused.disabled then return end
        if codepoint < 32 and codepoint ~= 10 then return end
        local element = self.focused
        local buffer = element.ensure_input_buffer()
        delete_input_selection(element)
        local written = buffer.insert_codepoint(element.cursor_index,codepoint,is_multiline_control(element),element.max_length)
        if written > 0 then
            element.cursor_index = element.cursor_index + written
            element.selection_anchor = element.cursor_index
            element.selection_focus = element.cursor_index
            element.value = buffer.value
            ensure_input_cursor_visible(element)
            self._emit_input(element)
        end
    end,

    input_text = fn(value:string)
        if self.focused == null or not is_text_control(self.focused) then return end
        if self.focused.read_only or self.focused.disabled then return end
        local element = self.focused
        local buffer = element.ensure_input_buffer()
        delete_input_selection(element)
        local written = buffer.insert_text(element.cursor_index,value,is_multiline_control(element),element.max_length)
        if written > 0 then
            element.cursor_index = element.cursor_index + written
            element.selection_anchor = element.cursor_index
            element.selection_focus = element.cursor_index
            element.value = buffer.value
            ensure_input_cursor_visible(element)
            self._emit_input(element)
        end
    end,

    change = fn(element:Element)
        self._emit_change(element)
    end,

    destroy = fn()
        if self.root ~= null then self.root.destroy() self.root = null end
        if self.event ~= null then self.event.destroy() self.event = null end
        self.hovered = null
        self.active = null
        self.focused = null
        self.scroll_drag_target = null
        self.open_select = null
        self.select_press_index = -1
        self.pointer_hit_dirty = true
    end
}

export fn document(root:Element) -> Document
    local value = Document.new()
    -- Initialize capture state explicitly so a recycled slab block can never
    -- leak a previous document's hovered/active pointers into the first frame.
    value.root = root
    value.hovered = null
    value.active = null
    value.focused = null
    value.scroll_drag_target = null
    value.open_select = null
    value.event = UIEvent.new()
    value.select_press_index = -1
    value.scroll_drag_axis = 0
    value.scroll_drag_offset = 0.0
    value.text_selecting = false
    value.width = 0.0
    value.height = 0.0
    value.pointer_x = 0.0
    value.pointer_y = 0.0
    value.pointer_button = 0
    value.pointer_valid = false
    value.pointer_hit_dirty = true
    return value
end

export const WindowInput = {
    window:ptr = 0,
    native_window:handle = 0,
    document:Document = null,
    original_wndproc:ptr = 0,

    attach = fn(window:ptr,document:Document) -> bool
        if window == 0 or document == null then return false end
        self.window = window
        self.document = document
        GLFW.glfwSetWindowUserPointer(window,self)
        GLFW.glfwSetKeyCallback(window,lazyui_key_callback)
        GLFW.glfwSetCharCallback(window,lazyui_char_callback)
        -- glfwCreateWindow returns GLFWwindow*, not HWND. Resolve the real
        -- native window before installing the wheel message bridge.
        self.native_window = GLFW.glfwGetWin32Window(window)
        if self.native_window ~= 0 then self.original_wndproc = Win32.SetWindowLongPtrW(self.native_window,Win32.GWLP_WNDPROC,lazyui_window_proc) end
        return true
    end,

    destroy = fn()
        if self.window ~= 0 then
            if self.native_window ~= 0 and self.original_wndproc ~= 0 then Win32.SetWindowLongPtrW(self.native_window,Win32.GWLP_WNDPROC,self.original_wndproc) end
            GLFW.glfwSetKeyCallback(self.window,0)
            GLFW.glfwSetCharCallback(self.window,0)
            if GLFW.glfwGetWindowUserPointer(self.window) == self then GLFW.glfwSetWindowUserPointer(self.window,0) end
        end
        self.original_wndproc = 0
        self.native_window = 0
        self.window = 0
        self.document = null
    end
}

fn wheel_delta_from_wparam(wparam:u64) -> i32
    local high:i64 = wparam / 65536 % 65536
    if high >= 32768 then high = high - 65536 end
    return high
end

fn lazyui_window_proc(window:handle,message:u32,wparam:u64,lparam:i64) -> i64
    -- GLFW stores the WindowInput object on GLFWwindow*, so map the HWND back
    -- through the active context. LazyUI windows process events on the owning
    -- thread and the current context remains attached throughout the loop.
    local glfwWindow = GLFW.glfwGetCurrentContext()
    local input:WindowInput = GLFW.glfwGetWindowUserPointer(glfwWindow)
    if input ~= null and input.document ~= null then
        if message == Win32.WM_MOUSEWHEEL then
            local wheelY:f32 = wheel_delta_from_wparam(wparam) / 120.0
            input.document.scroll(0.0,wheelY)
        elseif message == Win32.WM_MOUSEHWHEEL then
            local wheelX:f32 = wheel_delta_from_wparam(wparam) / 120.0
            input.document.scroll(-wheelX,0.0)
        end
        if input.original_wndproc ~= 0 then return Win32.CallWindowProcW(input.original_wndproc,window,message,wparam,lparam) end
    end
    return Win32.DefWindowProcW(window,message,wparam,lparam)
end


fn lazyui_key_callback(window:ptr,key:i32,scancode:i32,action:i32,modifiers:i32)
    local input:WindowInput = GLFW.glfwGetWindowUserPointer(window)
    if input == null or input.document == null then return end
    if action == GLFW.GLFW_PRESS or action == GLFW.GLFW_REPEAT then input.document.key_down_window(key,modifiers,window)
    elseif action == GLFW.GLFW_RELEASE then input.document.key_up(key,modifiers) end
end

fn lazyui_char_callback(window:ptr,codepoint:u32)
    local input:WindowInput = GLFW.glfwGetWindowUserPointer(window)
    if input == null or input.document == null then return end
    input.document.input_codepoint(codepoint)
end


export fn connect_window_input(window:ptr,document:Document) -> WindowInput
    local input = WindowInput.new()
    input.attach(window,document)
    return input
end
