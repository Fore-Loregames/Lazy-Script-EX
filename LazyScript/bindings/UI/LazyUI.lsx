}

export const CanvasContext = {
    commands = {},
    path = {},
    states = {},
    width:f32 = 0.0,
    height:f32 = 0.0,
    fill_color:u32 = 4294967295,
    stroke_color:u32 = 4294967295,
    line_width:f32 = 1.0,
    font_size:f32 = 16.0,
    global_alpha:f32 = 1.0,
    translate_x:f32 = 0.0,
    translate_y:f32 = 0.0,
    scale_x:f32 = 1.0,
    scale_y:f32 = 1.0,
    rotation:f32 = 0.0,
    path_closed:bool = false,
    dirty:bool = true,

    _transform_x = fn(x:f32,y:f32) -> f32
        local cosine = canvas_cos(self.rotation)
        local sine = canvas_sin(self.rotation)
        return x * self.scale_x * cosine - y * self.scale_y * sine + self.translate_x
    end,

    _transform_y = fn(x:f32,y:f32) -> f32
        local cosine = canvas_cos(self.rotation)
        local sine = canvas_sin(self.rotation)
        return x * self.scale_x * sine + y * self.scale_y * cosine + self.translate_y
    end,

    _clear_path = fn()
        local index = 0
        while index < self.path.length() do
            local point = self.path[index]
            point.destroy()
            index = index + 1
        end
        self.path.clear()
        self.path_closed = false
    end,

    resize = fn(width:f32,height:f32)
        self.width = width
        self.height = height
        return self
    end,

    clear = fn()
        local index = 0
        while index < self.commands.length() do
            local command = self.commands[index]
            command.destroy()
            index = index + 1
        end
        self.commands.clear()
        self._clear_path()
        self.dirty = true
        return self
    end,

    push = fn(command:CanvasCommand)
        self.commands.push(command)
        self.dirty = true
        return command
    end,

    save = fn()
        local state = CanvasState.new()
        state.fill_color = self.fill_color
        state.stroke_color = self.stroke_color
        state.line_width = self.line_width
        state.font_size = self.font_size
        state.global_alpha = self.global_alpha
        state.translate_x = self.translate_x
        state.translate_y = self.translate_y
        state.scale_x = self.scale_x
        state.scale_y = self.scale_y
        state.rotation = self.rotation
        self.states.push(state)
        return self
    end,

    restore = fn()
        if self.states.length() == 0 then return self end
        local index = self.states.length() - 1
        local state = self.states[index]
        self.fill_color = state.fill_color
        self.stroke_color = state.stroke_color
        self.line_width = state.line_width
        self.font_size = state.font_size
        self.global_alpha = state.global_alpha
        self.translate_x = state.translate_x
        self.translate_y = state.translate_y
        self.scale_x = state.scale_x
        self.scale_y = state.scale_y
        self.rotation = state.rotation
        self.states.remove(index)
        state.destroy()
        return self
    end,

    reset_transform = fn()
        self.translate_x = 0.0
        self.translate_y = 0.0
        self.scale_x = 1.0
        self.scale_y = 1.0
        self.rotation = 0.0
        return self
    end,

    translate = fn(x:f32,y:f32)
        self.translate_x = self.translate_x + x
        self.translate_y = self.translate_y + y
        return self
    end,

    scale = fn(x:f32,y:f32)
        self.scale_x = self.scale_x * x
        self.scale_y = self.scale_y * y
        return self
    end,

    rotate = fn(radians:f32)
        self.rotation = self.rotation + radians
        return self
    end,

    set_fill = fn(color:u32) self.fill_color = color return self end,
    set_stroke = fn(color:u32) self.stroke_color = color return self end,
    set_line_width = fn(value:f32) self.line_width = value return self end,
    set_font_size = fn(value:f32) self.font_size = value return self end,
    set_alpha = fn(value:f32) self.global_alpha = value return self end,

    fill_rect = fn(x:f32,y:f32,width:f32,height:f32,color:u32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_FILL_RECT
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.width = width * self.scale_x
        command.height = height * self.scale_y
        command.color = canvas_alpha(color,self.global_alpha)
        self.push(command)
    end,

    fill_box = fn(x:f32,y:f32,width:f32,height:f32)
        self.fill_rect(x,y,width,height,self.fill_color)
    end,

    stroke_rect = fn(x:f32,y:f32,width:f32,height:f32,lineWidth:f32,color:u32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_STROKE_RECT
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.width = width * self.scale_x
        command.height = height * self.scale_y
        command.line_width = lineWidth
        command.color = canvas_alpha(color,self.global_alpha)
        self.push(command)
    end,

    stroke_box = fn(x:f32,y:f32,width:f32,height:f32)
        self.stroke_rect(x,y,width,height,self.line_width,self.stroke_color)
    end,

    rounded_rect = fn(x:f32,y:f32,width:f32,height:f32,radius:f32,color:u32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_ROUNDED_RECT
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.width = width * self.scale_x
        command.height = height * self.scale_y
        command.radius = radius
        command.color = canvas_alpha(color,self.global_alpha)
        self.push(command)
    end,

    fill_rounded_rect = fn(x:f32,y:f32,width:f32,height:f32,radius:f32)
        self.rounded_rect(x,y,width,height,radius,self.fill_color)
    end,

    stroke_rounded_rect = fn(x:f32,y:f32,width:f32,height:f32,radius:f32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_STROKE_ROUNDED_RECT
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.width = width * self.scale_x
        command.height = height * self.scale_y
        command.radius = radius
        command.line_width = self.line_width
        command.color = canvas_alpha(self.stroke_color,self.global_alpha)
        self.push(command)
    end,

    circle = fn(x:f32,y:f32,radius:f32,color:u32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_CIRCLE
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.radius = radius * self.scale_x
        command.color = canvas_alpha(color,self.global_alpha)
        self.push(command)
    end,

    fill_circle = fn(x:f32,y:f32,radius:f32)
        self.circle(x,y,radius,self.fill_color)
    end,

    stroke_circle = fn(x:f32,y:f32,radius:f32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_STROKE_CIRCLE
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.radius = radius * self.scale_x
        command.line_width = self.line_width
        command.color = canvas_alpha(self.stroke_color,self.global_alpha)
        self.push(command)
    end,

    ellipse = fn(x:f32,y:f32,radiusX:f32,radiusY:f32,color:u32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_ELLIPSE
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.width = radiusX * self.scale_x
        command.height = radiusY * self.scale_y
        command.color = canvas_alpha(color,self.global_alpha)
        self.push(command)
    end,

    fill_ellipse = fn(x:f32,y:f32,radiusX:f32,radiusY:f32)
        self.ellipse(x,y,radiusX,radiusY,self.fill_color)
    end,

    stroke_ellipse = fn(x:f32,y:f32,radiusX:f32,radiusY:f32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_STROKE_ELLIPSE
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.width = radiusX * self.scale_x
        command.height = radiusY * self.scale_y
        command.line_width = self.line_width
        command.color = canvas_alpha(self.stroke_color,self.global_alpha)
        self.push(command)
    end,

    _line_absolute = fn(x:f32,y:f32,x2:f32,y2:f32,lineWidth:f32,color:u32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_LINE
        command.x = x
        command.y = y
        command.x2 = x2
        command.y2 = y2
        command.line_width = lineWidth
        command.color = color
        self.push(command)
    end,

    line = fn(x:f32,y:f32,x2:f32,y2:f32,lineWidth:f32,color:u32)
        self._line_absolute(
            self._transform_x(x,y),
            self._transform_y(x,y),
            self._transform_x(x2,y2),
            self._transform_y(x2,y2),
            lineWidth,
            canvas_alpha(color,self.global_alpha)
        )
    end,

    stroke_line = fn(x:f32,y:f32,x2:f32,y2:f32)
        self.line(x,y,x2,y2,self.line_width,self.stroke_color)
    end,

    _triangle_absolute = fn(x:f32,y:f32,x2:f32,y2:f32,x3:f32,y3:f32,color:u32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_TRIANGLE
        command.x = x
        command.y = y
        command.x2 = x2
        command.y2 = y2
        command.x3 = x3
        command.y3 = y3
        command.color = color
        self.push(command)
    end,

    triangle = fn(x:f32,y:f32,x2:f32,y2:f32,x3:f32,y3:f32,color:u32)
        self._triangle_absolute(
            self._transform_x(x,y),
            self._transform_y(x,y),
            self._transform_x(x2,y2),
            self._transform_y(x2,y2),
            self._transform_x(x3,y3),
            self._transform_y(x3,y3),
            canvas_alpha(color,self.global_alpha)
        )
    end,

    begin_path = fn()
        self._clear_path()
        return self
    end,

    move_to = fn(x:f32,y:f32)
        local point = CanvasPoint.new()
        point.x = self._transform_x(x,y)
        point.y = self._transform_y(x,y)
        self.path.push(point)
        return self
    end,

    line_to = fn(x:f32,y:f32)
        return self.move_to(x,y)
    end,

    quadratic_curve_to = fn(controlX:f32,controlY:f32,x:f32,y:f32)
        if self.path.length() == 0 then return self.move_to(x,y) end
        local last = self.path[self.path.length() - 1]
        local startX = last.x
        local startY = last.y
        local controlTX = self._transform_x(controlX,controlY)
        local controlTY = self._transform_y(controlX,controlY)
        local endX = self._transform_x(x,y)
        local endY = self._transform_y(x,y)
        local segment = 1
        while segment <= 16 do
            local t = segment * 1.0 / 16.0
            local inverse = 1.0 - t
            local point = CanvasPoint.new()
            point.x = inverse * inverse * startX + 2.0 * inverse * t * controlTX + t * t * endX
            point.y = inverse * inverse * startY + 2.0 * inverse * t * controlTY + t * t * endY
            self.path.push(point)
            segment = segment + 1
        end
        return self
    end,

    bezier_curve_to = fn(control1X:f32,control1Y:f32,control2X:f32,control2Y:f32,x:f32,y:f32)
        if self.path.length() == 0 then return self.move_to(x,y) end
        local last = self.path[self.path.length() - 1]
        local startX = last.x
        local startY = last.y
        local c1x = self._transform_x(control1X,control1Y)
        local c1y = self._transform_y(control1X,control1Y)
        local c2x = self._transform_x(control2X,control2Y)
        local c2y = self._transform_y(control2X,control2Y)
        local endX = self._transform_x(x,y)
        local endY = self._transform_y(x,y)
        local segment = 1
        while segment <= 24 do
            local t = segment * 1.0 / 24.0
            local inverse = 1.0 - t
            local point = CanvasPoint.new()
            point.x = inverse * inverse * inverse * startX + 3.0 * inverse * inverse * t * c1x + 3.0 * inverse * t * t * c2x + t * t * t * endX
            point.y = inverse * inverse * inverse * startY + 3.0 * inverse * inverse * t * c1y + 3.0 * inverse * t * t * c2y + t * t * t * endY
            self.path.push(point)
            segment = segment + 1
        end
        return self
    end,

    arc = fn(x:f32,y:f32,radius:f32,startAngle:f32,endAngle:f32)
        local segment = 0
        while segment <= 32 do
            local t = segment * 1.0 / 32.0
            local angle = startAngle + (endAngle - startAngle) * t
            local px = x + canvas_cos(angle) * radius
            local py = y + canvas_sin(angle) * radius
            self.move_to(px,py)
            segment = segment + 1
        end
        return self
    end,

    close_path = fn()
        self.path_closed = true
        return self
    end,

    stroke = fn()
        local count = self.path.length()
        local index = 1
        while index < count do
            local first = self.path[index - 1]
            local second = self.path[index]
            self._line_absolute(first.x,first.y,second.x,second.y,self.line_width,canvas_alpha(self.stroke_color,self.global_alpha))
            index = index + 1
        end
        if self.path_closed and count > 2 then
            local last_point = self.path[count - 1]
            local first_point = self.path[0]
            self._line_absolute(last_point.x,last_point.y,first_point.x,first_point.y,self.line_width,canvas_alpha(self.stroke_color,self.global_alpha))
        end
        return self
    end,

    fill = fn()
        local count = self.path.length()
        if count < 3 then return self end
        local origin = self.path[0]
        local index = 2
        while index < count do
            local second = self.path[index - 1]
            local third = self.path[index]
            self._triangle_absolute(origin.x,origin.y,second.x,second.y,third.x,third.y,canvas_alpha(self.fill_color,self.global_alpha))
            index = index + 1
        end
        return self
    end,

    draw_text = fn(text:string,x:f32,y:f32,color:u32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_TEXT
        command.text = text
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.font_size = self.font_size
        command.color = canvas_alpha(color,self.global_alpha)
        self.push(command)
    end,

    fill_text = fn(text:string,x:f32,y:f32)
        self.draw_text(text,x,y,self.fill_color)
    end,

    stroke_text = fn(text:string,x:f32,y:f32)
        self.draw_text(text,x,y,self.stroke_color)
    end,

    draw_image = fn(texture:u32,x:f32,y:f32,width:f32,height:f32,color:u32)
        local command = CanvasCommand.new()
        command.kind = CANVAS_IMAGE
        command.texture = texture
        command.x = self._transform_x(x,y)
        command.y = self._transform_y(x,y)
        command.width = width * self.scale_x
        command.height = height * self.scale_y
        command.color = canvas_alpha(color,self.global_alpha)
        self.push(command)
    end,

    image = fn(texture:u32,x:f32,y:f32,width:f32,height:f32)
        self.draw_image(texture,x,y,width,height,4294967295)
    end,

    destroy = fn()
        self.clear()
        local index = 0
        while index < self.states.length() do
            local state = self.states[index]
            state.destroy()
            index = index + 1
        end
        self.states.destroy()
        self.path.destroy()
        self.commands.destroy()
    end
}


export const UIEvent = {
    type:string = null,
    x:f32 = 0.0,
    y:f32 = 0.0,
    delta_x:f32 = 0.0,
    delta_y:f32 = 0.0,
    button:i32 = 0,
    key:i32 = 0,
    modifiers:i32 = 0,
    text:string = null,
    target:Element = null,
    current_target:Element = null,
    handled:bool = false,
    default_prevented:bool = false,
    propagation_stopped:bool = false,

    stop_propagation = fn() self.propagation_stopped = true end,
    prevent_default = fn() self.default_prevented = true end,
    handle = fn() self.handled = true self.propagation_stopped = true end,
    -- Event targets are borrowed references into the retained tree. They must
    -- never be recursively destroyed when the reusable event object is freed.
    destroy = fn()
        self.target = null
        self.current_target = null
        self.text = null
    end,
    reset = fn()
        self.type = null
        self.delta_x = 0.0
        self.delta_y = 0.0
        self.button = 0
        self.key = 0
        self.modifiers = 0
        self.text = null
        self.target = null
        self.current_target = null
        self.handled = false
        self.default_prevented = false
        self.propagation_stopped = false
    end
}


-- Internal record used by Element.add_event_listener(). Each listener keeps
-- its own callback and optional LSX context object, allowing multiple runtime
-- listeners on the same LSHTML element without exposing native pointers.
const EventListener = {
    type_hash:u32 = 0,
    handler:fnptr = null,
    context:u64 = 0,

    destroy = fn()
        self.handler = null
        self.context = 0
        self.type_hash = 0
    end
}


-- Persistent numeric text buffer for counters such as FPS displays. The
-- backing UTF-8 storage is allocated once and updated in place, so changing a
-- counter does not allocate a new string every frame. Pointer details remain
-- inside the LazyUI binding; front-end LSX uses this as an ordinary object.
export const CounterText = {
    buffer:u64 = 0,
    capacity:i64 = 0,
    prefix_length:i64 = 0,
    value:string = null,

    initialize = fn(prefix:string,requested_capacity:i64) -> bool
        if self.buffer ~= 0 then memory.free(self.buffer) self.buffer = 0 end
        local prefixLength:i64 = 0
        if prefix ~= null then prefixLength = string.length(prefix) end
        local required = prefixLength + 24
        local size = requested_capacity
        if size < required then size = required end
        if size < 32 then size = 32 end
        self.buffer = memory.alloc(size)
        if self.buffer == 0 then
            self.capacity = 0
            self.prefix_length = 0
            self.value = null
            return false
        end
        self.capacity = size
        self.prefix_length = prefixLength
        local index:i64 = 0
        while index < prefixLength do
            memory.write_u8(self.buffer,index,string.byte_at(prefix,index))
            index = index + 1
        end
        memory.write_u8(self.buffer,prefixLength,0)
        self.value = string.from_utf8(self.buffer)
        return true
    end,

    set_i64 = fn(number:i64) -> string
        if self.buffer == 0 then
            if not self.initialize(null,32) then return null end
        end
        local remaining = number
        local negative = remaining < 0
        if negative then remaining = 0 - remaining end
        local digits:i64 = 1
        local probe = remaining
        while probe >= 10 do
            probe = probe / 10
            digits = digits + 1
        end
        local total = self.prefix_length + digits
        if negative then total = total + 1 end
        if total >= self.capacity then return self.value end
        memory.write_u8(self.buffer,total,0)
        local cursor = total - 1
        if remaining == 0 then
            memory.write_u8(self.buffer,cursor,48)
            cursor = cursor - 1
        else
            while remaining > 0 do
                local digit = remaining % 10
                memory.write_u8(self.buffer,cursor,48 + digit)
                cursor = cursor - 1
                remaining = remaining / 10
            end
        end
        if negative then memory.write_u8(self.buffer,cursor,45) end
        return self.value
    end,

    destroy = fn()
        if self.buffer ~= 0 then memory.free(self.buffer) self.buffer = 0 end
        self.capacity = 0
        self.prefix_length = 0
        self.value = null
    end
}

export fn counter_text(prefix:string,capacity:i64) -> CounterText
    local result = CounterText.new()
    result.initialize(prefix,capacity)
    return result
end


-- Mutable UTF-8 backing storage used by real text inputs and textareas.
-- The owner Element keeps an ordinary string view into this buffer; reallocating,
-- insertion, deletion, selection, and clipboard details stay inside LazyUI.
export const TextBuffer = {
    buffer:u64 = 0,
    length:i64 = 0,
    capacity:i64 = 0,
    value:string = null,

    ensure = fn(required:i64) -> bool
        if required + 1 <= self.capacity and self.buffer ~= 0 then return true end
        local next:i64 = self.capacity
        if next < 32 then next = 32 end
        while next < required + 1 do next = next * 2 end
        local replacement = memory.alloc(next)
        if replacement == 0 then return false end
        local index:i64 = 0
        while index < self.length do
            memory.write_u8(replacement,index,memory.read_u8(self.buffer,index))
            index = index + 1
        end
        memory.write_u8(replacement,self.length,0)
        if self.buffer ~= 0 then memory.free(self.buffer) end
        self.buffer = replacement
        self.capacity = next
        self.value = string.from_utf8(self.buffer)
        return true
    end,

    set = fn(text:string) -> bool
        local required:i64 = 0
        if text ~= null then required = string.length(text) end
        self.length = 0
        if not self.ensure(required) then self.value = null return false end
        local index:i64 = 0
        while index < required do
            memory.write_u8(self.buffer,index,string.byte_at(text,index))
            index = index + 1
        end
        self.length = required
        memory.write_u8(self.buffer,self.length,0)
        self.value = string.from_utf8(self.buffer)
        return true
    end,

    erase = fn(start:i64,count:i64) -> bool
        if self.buffer == 0 or count <= 0 or start < 0 or start >= self.length then return false end
        local finish = start + count
        if finish > self.length then finish = self.length end
        local removed = finish - start
        local readIndex = finish
        local writeIndex = start
        while readIndex < self.length do
            memory.write_u8(self.buffer,writeIndex,memory.read_u8(self.buffer,readIndex))
            readIndex = readIndex + 1
            writeIndex = writeIndex + 1
        end
        self.length = self.length - removed
        memory.write_u8(self.buffer,self.length,0)
        self.value = string.from_utf8(self.buffer)
        return true
    end,

    insert_text = fn(index:i64,text:string,allow_newlines:bool,max_length:i64) -> i64
        if text == null then return 0 end
        if index < 0 then index = 0 end
        if index > self.length then index = self.length end
        local sourceLength = string.length(text)
        local accepted:i64 = 0
        local scan:i64 = 0
        while scan < sourceLength do
            local byteValue = string.byte_at(text,scan)
            local allowed = true
            if not allow_newlines and (byteValue == 10 or byteValue == 13) then allowed = false end
            if byteValue == 13 then allowed = false end
            if allowed then
                if max_length <= 0 or self.length + accepted < max_length then accepted = accepted + 1 end
            end
            scan = scan + 1
        end
        if accepted <= 0 then return 0 end
        if not self.ensure(self.length + accepted) then return 0 end
        local move = self.length - 1
        while move >= index do
            memory.write_u8(self.buffer,move + accepted,memory.read_u8(self.buffer,move))
            move = move - 1
        end
        local outputIndex = index
        scan = 0
        local written:i64 = 0
        while scan < sourceLength and written < accepted do
            local outputByte = string.byte_at(text,scan)
            local outputAllowed = true
            if not allow_newlines and (outputByte == 10 or outputByte == 13) then outputAllowed = false end
            if outputByte == 13 then outputAllowed = false end
            if outputAllowed then
                memory.write_u8(self.buffer,outputIndex,outputByte)
                outputIndex = outputIndex + 1
                written = written + 1
            end
            scan = scan + 1
        end
        self.length = self.length + written
        memory.write_u8(self.buffer,self.length,0)
        self.value = string.from_utf8(self.buffer)
        return written
    end,

    insert_codepoint = fn(index:i64,codepoint:u32,allow_newlines:bool,max_length:i64) -> i64
        if codepoint == 13 then codepoint = 10 end
        if codepoint == 10 and not allow_newlines then return 0 end
        local byteCount:i64 = 1
        if codepoint >= 128 and codepoint < 2048 then byteCount = 2
        elseif codepoint >= 2048 and codepoint < 65536 then byteCount = 3
        elseif codepoint >= 65536 then byteCount = 4 end
        if max_length > 0 and self.length + byteCount > max_length then return 0 end
        if index < 0 then index = 0 end
        if index > self.length then index = self.length end
        if not self.ensure(self.length + byteCount) then return 0 end
        local move = self.length - 1
        while move >= index do
            memory.write_u8(self.buffer,move + byteCount,memory.read_u8(self.buffer,move))
            move = move - 1
        end
        if byteCount == 1 then
            memory.write_u8(self.buffer,index,codepoint)
        elseif byteCount == 2 then
            memory.write_u8(self.buffer,index,192 + codepoint / 64)
            memory.write_u8(self.buffer,index + 1,128 + codepoint % 64)
        elseif byteCount == 3 then
            memory.write_u8(self.buffer,index,224 + codepoint / 4096)
            memory.write_u8(self.buffer,index + 1,128 + codepoint / 64 % 64)
            memory.write_u8(self.buffer,index + 2,128 + codepoint % 64)
        else
            memory.write_u8(self.buffer,index,240 + codepoint / 262144)
            memory.write_u8(self.buffer,index + 1,128 + codepoint / 4096 % 64)
            memory.write_u8(self.buffer,index + 2,128 + codepoint / 64 % 64)
            memory.write_u8(self.buffer,index + 3,128 + codepoint % 64)
        end
        self.length = self.length + byteCount
        memory.write_u8(self.buffer,self.length,0)
        self.value = string.from_utf8(self.buffer)
        return byteCount
    end,

    destroy = fn()
        if self.buffer ~= 0 then memory.free(self.buffer) self.buffer = 0 end
        self.length = 0
        self.capacity = 0
        self.value = null
    end
}

fn previous_utf8_index(buffer:TextBuffer,index:i64) -> i64
    if buffer == null or index <= 0 then return 0 end
    local result = index - 1
    while result > 0 and memory.read_u8(buffer.buffer,result) >= 128 and memory.read_u8(buffer.buffer,result) < 192 do
        result = result - 1
    end
    return result
end

fn next_utf8_index(buffer:TextBuffer,index:i64) -> i64
    if buffer == null or index >= buffer.length then return buffer.length end
    local result = index + 1
    while result < buffer.length and memory.read_u8(buffer.buffer,result) >= 128 and memory.read_u8(buffer.buffer,result) < 192 do
        result = result + 1
    end
    return result
end

fn color_hex_digit(value:i32) -> i32
    if value < 10 then return 48 + value end
    return 55 + value
end

export const Element = {

    ui_marker:u32 = UI_MARKER,

    creation_kind:i32 = CREATION_FUNCTION,

    runner_ready:bool = true,

    runner_attached:bool = false,

    template_root:bool = false,

    inherit_style:bool = false,

    template_id:u32 = 0,

    _runner:u64 = 0,

    _ecs_entity:u64 = 0,

    kind:i32 = ELEMENT_CUSTOM,

    tag_hash:u32 = 0,

    _compact_tag_hash:u32 = 0,

    source_tag:string = null,

    id:string = null,

    id_hash:u32 = 0,

    class_name:string = null,

    name:string = null,

    title:string = null,

    text:string = null,

    value:string = null,

    placeholder:string = null,

    input_buffer:TextBuffer = null,

    masked_buffer:TextBuffer = null,

    color_value:u32 = 0,

    has_color_value:bool = false,

    cursor_index:i64 = 0,

    selection_anchor:i64 = 0,

    selection_focus:i64 = 0,

    max_length:i64 = 0,

    input_scroll_x:f32 = 0.0,

    input_scroll_y:f32 = 0.0,

    source:string = null,

    alt:string = null,

    hidden:bool = false,

    disabled:bool = false,

    checked:bool = false,

    selected:bool = false,

    open:bool = false,

    selected_index:i64 = -1,

    popup_hover_index:i64 = -1,

    popup_scroll_index:i64 = 0,

    read_only:bool = false,

    multiple:bool = false,

    draggable:bool = false,

    focusable:bool = false,

    hovered:bool = false,

    active:bool = false,

    focused:bool = false,

    tab_index:i32 = 0,

    number_value:f32 = 0.0,

    min_value:f32 = 0.0,

    max_value:f32 = 1.0,

    step_value:f32 = 1.0,

    texture:u32 = 0,

    canvas_shape:i32 = 0,

    canvas_x:f32 = 0.0,

    canvas_y:f32 = 0.0,

    canvas_x2:f32 = 0.0,

    canvas_y2:f32 = 0.0,

    canvas_x3:f32 = 0.0,

    canvas_y3:f32 = 0.0,

    canvas_width:f32 = 0.0,

    canvas_height:f32 = 0.0,

    canvas_radius:f32 = 0.0,

    canvas_radius_x:f32 = 0.0,

    canvas_radius_y:f32 = 0.0,

    canvas_closed:bool = false,

    canvas_points = {},

    x:f32 = 0.0,

    y:f32 = 0.0,

    width:f32 = 0.0,

    height:f32 = 0.0,

    content_x:f32 = 0.0,

    content_y:f32 = 0.0,

    content_width:f32 = 0.0,

    content_height:f32 = 0.0,

    clip_x:f32 = 0.0,

    clip_y:f32 = 0.0,

    clip_width:f32 = 0.0,

    clip_height:f32 = 0.0,

    scroll_x:f32 = 0.0,

    scroll_y:f32 = 0.0,

    scroll_content_width:f32 = 0.0,

    scroll_content_height:f32 = 0.0,

    scroll_max_x:f32 = 0.0,

    scroll_max_y:f32 = 0.0,

    layout_dirty:bool = true,

    visual_dirty:bool = true,

    style:Style = null,

    hover_style:Style = null,

    active_style:Style = null,

    focus_style:Style = null,

    disabled_style:Style = null,

    checked_style:Style = null,

    selected_style:Style = null,

    parent:Element = null,

    children = {},

    classes = {},

    attributes = {},

    bindings = {},

    canvas_context:CanvasContext = null,

    _on_click:fnptr = null,

    _on_change:fnptr = null,

    _on_input:fnptr = null,

    _on_focus:fnptr = null,

    _on_blur:fnptr = null,

    _on_key_down:fnptr = null,

    _on_key_up:fnptr = null,

    _on_pointer_down:fnptr = null,

    _on_pointer_up:fnptr = null,

    _on_pointer_move:fnptr = null,

    _on_scroll:fnptr = null,

    _event_context:u64 = 0,

    _event_listeners = {},


    -- Dirty state is propagated to the retained root so layout and renderer
    -- caches can reject unchanged frames in O(1). Runtime code should call
    -- these methods after direct field/style edits instead of only setting
    -- the local flags.
    mark_visual_dirty = fn()
        local current = self
        while current ~= null do
            current.visual_dirty = true
            current = current.parent
        end
    end,

    mark_layout_dirty = fn()
        local current = self
        while current ~= null do
            current.layout_dirty = true
            current.visual_dirty = true
            current = current.parent
        end
    end,

    repair_parent_links = fn()
        local retainedIndex:i64 = 0
        while retainedIndex < self.children.length() do
            local retained = self.children.at(retainedIndex)
            retained.parent = self
            retained.repair_parent_links()
            retainedIndex = retainedIndex + 1
        end
    end,

    add = fn(child:Element) -> Element
        if child == null then return child end
        child.parent = self
        -- Retained child tables own native object pointers. Pushing a child
        -- preserves its identity; it must not copy or release the object body.
        self.children.push(child)
        self.repair_parent_links()
        self.mark_layout_dirty()
        return self.children.at(self.children.length()-1)
    end,

    remove = fn(child:Element) -> bool
        local index = 0
        while index < self.children.length() do
            if self.children.at(index) == child then
                self.children.remove(index)
                child.parent = null
                self.mark_layout_dirty()
                return true
            end
            index = index + 1
        end
        return false
    end,

    child = fn(index:i64) -> Element
        if index < 0 or index >= self.children.length() then return null end
        return self.children.at(index)
    end,

    child_count = fn() -> i64 return self.children.length() end,

    set_id = fn(value:string)
        self.id = value
        self.id_hash = hash(value)
    end,

    set_class = fn(value:string)
        self.class_name = value
        self.classes.clear()
        append_class_hashes(self.classes,value)
        self.mark_layout_dirty()
    end,

    add_class = fn(value:string)
        if value == null then return self end
        append_class_hashes(self.classes,value)
        if self.class_name == null then self.class_name = value end
        self.mark_layout_dirty()
        return self
    end,

    remove_class = fn(value:string)
        local target = hash(value)
        local index = self.classes.length() - 1
        while index >= 0 do
            if self.classes[index] == target then self.classes.remove(index) end
            index = index - 1
        end
        self.mark_layout_dirty()
        return self
    end,

    has_class = fn(value:string) -> bool
        return self.has_class_hash(hash(value))
    end,

    has_class_hash = fn(value:u32) -> bool
        local index = 0
        while index < self.classes.length() do
            if self.classes[index] == value then return true end
            index = index + 1
        end
        return false
    end,

    set_text = fn(value:string)
        self.text = value
        self.mark_layout_dirty()
    end,

    set_value = fn(value:string)
        if self.kind == ELEMENT_INPUT then
            if self.input_buffer == null then self.input_buffer = TextBuffer.new() end
            if self.input_buffer.set(value) then
                self.value = self.input_buffer.value
                self.cursor_index = self.input_buffer.length
                self.selection_anchor = self.cursor_index
                self.selection_focus = self.cursor_index
            else
                self.value = value
            end
        else
            self.value = value
        end
        self.mark_visual_dirty()
    end,

    ensure_input_buffer = fn() -> TextBuffer
        if self.input_buffer == null then
            self.input_buffer = TextBuffer.new()
            self.input_buffer.set(self.value)
            self.value = self.input_buffer.value
            self.cursor_index = self.input_buffer.length
            self.selection_anchor = self.cursor_index
            self.selection_focus = self.cursor_index
        end
        return self.input_buffer
    end,


    password_display_value = fn() -> string
        local source = self.ensure_input_buffer()
        if self.masked_buffer == null then self.masked_buffer = TextBuffer.new() end
        if not self.masked_buffer.ensure(source.length) then return self.value end
        local index:i64 = 0
        while index < source.length do
            memory.write_u8(self.masked_buffer.buffer,index,42)
            index = index + 1
        end
        self.masked_buffer.length = source.length
        memory.write_u8(self.masked_buffer.buffer,source.length,0)
        self.masked_buffer.value = string.from_utf8(self.masked_buffer.buffer)
        return self.masked_buffer.value
    end,

    set_color = fn(value:u32)
        self.color_value = value
        self.has_color_value = true
        local buffer = self.ensure_input_buffer()
        if buffer.ensure(9) then
            local red:i32 = value % 256
            local green:i32 = value / 256 % 256
            local blue:i32 = value / 65536 % 256
            local alpha:i32 = value / 16777216 % 256
            memory.write_u8(buffer.buffer,0,35)
            memory.write_u8(buffer.buffer,1,color_hex_digit(red / 16))
            memory.write_u8(buffer.buffer,2,color_hex_digit(red % 16))
            memory.write_u8(buffer.buffer,3,color_hex_digit(green / 16))
            memory.write_u8(buffer.buffer,4,color_hex_digit(green % 16))
            memory.write_u8(buffer.buffer,5,color_hex_digit(blue / 16))
            memory.write_u8(buffer.buffer,6,color_hex_digit(blue % 16))
            memory.write_u8(buffer.buffer,7,color_hex_digit(alpha / 16))
            memory.write_u8(buffer.buffer,8,color_hex_digit(alpha % 16))
            buffer.length = 9
            memory.write_u8(buffer.buffer,9,0)
            buffer.value = string.from_utf8(buffer.buffer)
            self.value = buffer.value
            if self.cursor_index > buffer.length then self.cursor_index = buffer.length end
            if self.selection_anchor > buffer.length then self.selection_anchor = buffer.length end
            if self.selection_focus > buffer.length then self.selection_focus = buffer.length end
        end
        self.mark_visual_dirty()
    end,

    selection_start = fn() -> i64
        if self.selection_anchor < self.selection_focus then return self.selection_anchor end
        return self.selection_focus
    end,

    selection_end = fn() -> i64
        if self.selection_anchor > self.selection_focus then return self.selection_anchor end
        return self.selection_focus
    end,

    has_selection = fn() -> bool
        return self.selection_anchor ~= self.selection_focus
    end,

    collapse_selection = fn(index:i64)
        self.cursor_index = index
        self.selection_anchor = index
        self.selection_focus = index
        self.mark_visual_dirty()
    end,

    select_all = fn()
        local buffer = self.ensure_input_buffer()
        self.selection_anchor = 0
        self.selection_focus = buffer.length
        self.cursor_index = buffer.length
        self.mark_visual_dirty()
    end,

    set_placeholder = fn(value:string) self.placeholder = value self.mark_visual_dirty() end,
    set_source = fn(value:string) self.source = value self.mark_visual_dirty() end,

    -- Assigns an already-loaded OpenGL texture to an image element and records
    -- its intrinsic aspect ratio. With only CSS width or height specified, the
    -- other dimension remains automatic and layout preserves the source image
    -- proportions instead of stretching it.
    set_texture = fn(texture_id:u32,intrinsic_width:f32,intrinsic_height:f32)
        self.texture = texture_id
        if intrinsic_width > 0.0 and intrinsic_height > 0.0 then
            self.style.aspect_ratio = intrinsic_width / intrinsic_height
        end
        self.mark_layout_dirty()
        return self
    end,

    set_alt = fn(value:string) self.alt = value end,
    set_title = fn(value:string) self.title = value end,
    set_name = fn(value:string) self.name = value end,

    set_attribute = fn(name:string,value:string)
        local item = Attribute.new()
        item.name = name item.value = value item.name_hash = hash(name)
        self.attributes.push(item)
    end,

    add_binding = fn(property:string,expression:string)
        local binding = Binding.new()
        binding.property = property binding.expression = expression binding.property_hash = hash(property)
        self.bindings.push(binding)
    end,

    clear_canvas_points = fn()
        local point_index = 0
        while point_index < self.canvas_points.length() do
            local point = self.canvas_points[point_index]
            point.destroy()
            point_index = point_index + 1
        end
        self.canvas_points.clear()
        self.mark_visual_dirty()
        return self
    end,

    add_canvas_point = fn(point_x:f32,point_y:f32)
        local point = CanvasPoint.new()
        point.x = point_x
        point.y = point_y
        self.canvas_points.push(point)
        self.mark_visual_dirty()
        return self
    end,



    -- Adds a runtime event listener to an element returned by Document.find().
    -- Event names use the normal DOM spelling: click, change, input, focus,
    -- blur, keydown, keyup, pointerdown, pointerup, pointermove, and scroll.
    -- More than one listener may be attached to the same event.
    add_event_listener = fn(type:string,handler) -> Element
        if type == null or handler == null then return self end
        local listener = EventListener.new()
        listener.type_hash = hash(type)
        listener.handler = handler
        listener.context = self._event_context
        self._event_listeners.push(listener)
        return self
    end,

    -- Adds a listener with its own ordinary LSX context object. The context is
    -- passed as the callback's third argument and remains compiler-managed.
    add_event_listener_with_context = fn(type:string,handler,context_handle:u64) -> Element
        if type == null or handler == null then return self end
        local listener = EventListener.new()
        listener.type_hash = hash(type)
        listener.handler = handler
        listener.context = context_handle
        self._event_listeners.push(listener)
        return self
    end,

    -- Removes the first matching runtime listener. Inline LSHTML on... handlers
    -- are separate and remain attached until replaced through the on_* helpers.
    remove_event_listener = fn(type:string,handler) -> bool
        if type == null or handler == null then return false end
        local typeHash = hash(type)
        local index = 0
        while index < self._event_listeners.length() do
            local listener = self._event_listeners.at(index)
            if listener.type_hash == typeHash and listener.handler == handler then
                listener.destroy()
                self._event_listeners.remove(index)
                return true
            end
            index = index + 1
        end
        return false
    end,

    -- Removes every runtime listener for one event name and returns the count.
    clear_event_listeners = fn(type:string) -> i64
        if type == null then return 0 end
        local typeHash = hash(type)
        local removed:i64 = 0
        local index = self._event_listeners.length()
        while index > 0 do
            index = index - 1
            local listener = self._event_listeners.at(index)
            if listener.type_hash == typeHash then
                listener.destroy()
                self._event_listeners.remove(index)
                removed = removed + 1
            end
        end
        return removed
    end,

    find_id = fn(value:u32) -> Element
        if self.id_hash == value then return self end
        local index = 0
        while index < self.children.length() do
            local child = self.children.at(index)
            local found = child.find_id(value)
            if found ~= null then return found end
            index = index + 1
        end
        return null
    end,

    find_class = fn(value:u32) -> Element
        if self.has_class_hash(value) then return self end
        local index = 0
        while index < self.children.length() do
            local child = self.children.at(index)
            local found = child.find_class(value)
            if found ~= null then return found end
            index = index + 1
        end
        return null
    end,

    find_tag = fn(value:u32) -> Element
        if self.tag_hash == value then return self end
        local index = 0
        while index < self.children.length() do
            local child = self.children.at(index)
            local found = child.find_tag(value)
            if found ~= null then return found end
            index = index + 1
        end
        return null
    end,


    _find_compact_tag = fn(value:u32) -> Element
        if self._compact_tag_hash == value then return self end
        local index = 0
        while index < self.children.length() do
            local child = self.children.at(index)
            local found = child._find_compact_tag(value)
            if found ~= null then return found end
            index = index + 1
        end
        return null
    end,

    current_style = fn() -> Style
        if self.inherit_style and self.parent ~= null then return self.parent.current_style() end
        if self.disabled and self.disabled_style ~= null then return self.disabled_style end
        if self.active and self.active_style ~= null then return self.active_style end
        if self.focused and self.focus_style ~= null then return self.focus_style end
        if self.checked and self.checked_style ~= null then return self.checked_style end
        if self.selected and self.selected_style ~= null then return self.selected_style end
        if self.hovered and self.hover_style ~= null then return self.hover_style end
        return self.style
    end,

    emit_click = fn() -> i64
        local event = UIEvent.new()
        event.type = "click"
        event.target = self
        event.current_target = self
        local result = dispatch_ui_event(self._on_click,self,event,self._event_context)
        event.destroy()
        return result
    end,

    emit_change = fn() -> i64
        local event = UIEvent.new()
        event.type = "change"
        event.target = self
        event.current_target = self
        local result = dispatch_ui_event(self._on_change,self,event,self._event_context)
        event.destroy()
        return result
    end,

    emit_input = fn() -> i64
        local event = UIEvent.new()
        event.type = "input"
        event.target = self
        event.current_target = self
        local result = dispatch_ui_event(self._on_input,self,event,self._event_context)
        event.destroy()
        return result
    end,

    destroy = fn()
        local index = 0
        while index < self.children.length() do
            local child = self.children.at(index)
            child.destroy()
            index = index + 1
        end
        index = 0
        while index < self._event_listeners.length() do
            local listener = self._event_listeners.at(index)
            listener.destroy()
            index = index + 1
        end
        self._event_listeners.destroy()
        index = 0
        while index < self.attributes.length() do
            local attribute = self.attributes[index]
            attribute.destroy()
            index = index + 1
        end
        index = 0
        while index < self.bindings.length() do
            local binding = self.bindings[index]
            binding.destroy()
            index = index + 1
        end
        if self.canvas_context ~= null then self.canvas_context.destroy() self.canvas_context = null end
        if self.input_buffer ~= null then self.input_buffer.destroy() self.input_buffer = null end
        if self.masked_buffer ~= null then self.masked_buffer.destroy() self.masked_buffer = null end
        self.clear_canvas_points()
        if self.style ~= null then self.style.destroy() self.style = null end
        if self.hover_style ~= null then self.hover_style.destroy() self.hover_style = null end
        if self.active_style ~= null then self.active_style.destroy() self.active_style = null end
        if self.focus_style ~= null then self.focus_style.destroy() self.focus_style = null end
        if self.disabled_style ~= null then self.disabled_style.destroy() self.disabled_style = null end
        if self.checked_style ~= null then self.checked_style.destroy() self.checked_style = null end
        if self.selected_style ~= null then self.selected_style.destroy() self.selected_style = null end
        self.children.destroy()
        self.classes.destroy()
        self.attributes.destroy()
        self.bindings.destroy()
        self.canvas_points.destroy()
    end
}


fn copy_style(source:Style) -> Style
    local result = Style.new()

    result.display = source.display

    result.position = source.position

    result.box_sizing = source.box_sizing

    result.visibility = source.visibility

    result.pointer_events = source.pointer_events

    result.width_unit = source.width_unit

    result.width = source.width

    result.height_unit = source.height_unit

    result.height = source.height

    result.min_width_unit = source.min_width_unit

    result.min_width = source.min_width

    result.min_height_unit = source.min_height_unit

    result.min_height = source.min_height

    result.max_width_unit = source.max_width_unit

    result.max_width = source.max_width

    result.max_height_unit = source.max_height_unit

    result.max_height = source.max_height

    result.left_unit = source.left_unit

    result.left = source.left

    result.right_unit = source.right_unit

    result.right = source.right

    result.top_unit = source.top_unit

    result.top = source.top

    result.bottom_unit = source.bottom_unit

    result.bottom = source.bottom

    result.margin_top = source.margin_top

    result.margin_right = source.margin_right

    result.margin_bottom = source.margin_bottom

    result.margin_left = source.margin_left

    result.padding_top = source.padding_top

    result.padding_right = source.padding_right

    result.padding_bottom = source.padding_bottom

    result.padding_left = source.padding_left

    result.gap = source.gap

    result.row_gap = source.row_gap

    result.column_gap = source.column_gap

    result.flex_direction = source.flex_direction

    result.flex_wrap = source.flex_wrap

    result.flex_grow = source.flex_grow

    result.flex_shrink = source.flex_shrink

    result.flex_basis_unit = source.flex_basis_unit

    result.flex_basis = source.flex_basis

    result.justify_content = source.justify_content

    result.align_items = source.align_items

    result.align_self = source.align_self

    result.align_content = source.align_content

    result.order = source.order

    result.grid_columns = source.grid_columns

    result.grid_rows = source.grid_rows

    result.overflow_x = source.overflow_x

    result.overflow_y = source.overflow_y

    result.z_index = source.z_index

    result.cursor = source.cursor

    result.aspect_ratio = source.aspect_ratio

    result.background = source.background

    result.background_end = source.background_end

    result.gradient_mode = source.gradient_mode

    result.gradient_angle = source.gradient_angle

    result.opacity = source.opacity

    result.border_top_width = source.border_top_width

    result.border_right_width = source.border_right_width

    result.border_bottom_width = source.border_bottom_width

    result.border_left_width = source.border_left_width

    result.border_top_color = source.border_top_color

    result.border_right_color = source.border_right_color

    result.border_bottom_color = source.border_bottom_color

    result.border_left_color = source.border_left_color

    result.radius_top_left = source.radius_top_left

    result.radius_top_right = source.radius_top_right

    result.radius_bottom_right = source.radius_bottom_right

    result.radius_bottom_left = source.radius_bottom_left

    result.shadow_x = source.shadow_x

    result.shadow_y = source.shadow_y

    result.shadow_blur = source.shadow_blur

    result.shadow_spread = source.shadow_spread

    result.shadow_color = source.shadow_color

    result.outline_width = source.outline_width

    result.outline_color = source.outline_color

    result.outline_offset = source.outline_offset

    result.text_color = source.text_color

    result.font_size = source.font_size

    result.font_weight = source.font_weight

    result.line_height = source.line_height

    result.letter_spacing = source.letter_spacing

    result.word_spacing = source.word_spacing

    result.text_align = source.text_align

    result.vertical_align = source.vertical_align

    result.white_space = source.white_space

    result.text_overflow = source.text_overflow

    result.translate_x = source.translate_x

    result.translate_y = source.translate_y

    result.scale_x = source.scale_x

    result.scale_y = source.scale_y

    result.rotate = source.rotate

    result.origin_x = source.origin_x

    result.origin_y = source.origin_y

    result.object_fit = source.object_fit

    result.image_tint = source.image_tint

    result.transition_duration = source.transition_duration

    return result
end


fn hash_range(value:string,start:i64,end_index:i64) -> u32
    local result:u64 = 5381
    local index = start
    while index < end_index do
        result = (result * 33 + string.byte_at(value,index)) % 2147483647
        index = index + 1
    end
    return result
end

fn append_class_hashes(output,value:string)
    if value == null then return end
    local length = string.length(value)
    local start = 0
    local index = 0
    while index <= length do
        local separator = index == length
        if not separator then
            local byte = string.byte_at(value,index)
            separator = byte == 32 or byte == 9 or byte == 10 or byte == 13
        end
        if separator then
            if index > start then output.push(hash_range(value,start,index)) end
            start = index + 1
        end
        index = index + 1
    end
end

export fn hash(value:string) -> u32
    if value == null then return 0 end
    local result:u64 = 5381
    local index = 0
    local length = string.length(value)
    while index < length do
        result = (result * 33 + string.byte_at(value,index)) % 2147483647
        index = index + 1
    end
    return result
end


-- Tag selectors are ASCII case-insensitive and accept the same kebab-case or
-- underscore spelling used in LSHTML, even when an older element factory stores
-- its internal source tag without separators (status-bar -> statusbar).
fn compact_tag_hash(value:string) -> u32
    if value == null then return 0 end
    local result:u64 = 5381
    local index = 0
    local length = string.length(value)
    while index < length do
        local byte = string.byte_at(value,index)
        if byte >= 65 and byte <= 90 then byte = byte + 32 end
        if byte ~= 45 and byte ~= 95 then result = (result * 33 + byte) % 2147483647 end
        index = index + 1
    end
    return result
end

export fn rgba(red:i32,green:i32,blue:i32,alpha:i32) -> u32
    return red + green * 256 + blue * 65536 + alpha * 16777216
end

fn create_element(kind:i32,tag:string) -> Element
    local value = Element.new()
    value.kind = kind
    value.source_tag = tag
    value.tag_hash = hash(tag)
    value._compact_tag_hash = compact_tag_hash(tag)
    value.style = Style.new()
    value.creation_kind = CREATION_FUNCTION
    value.runner_ready = true
    if kind == ELEMENT_BUTTON or kind == ELEMENT_INPUT then
        value.focusable = true
        value.style.cursor = CURSOR_POINTER
    end
    if kind == ELEMENT_INPUT then value.style.cursor = CURSOR_TEXT end
    return value
end

fn create_canvas_shape(shape:i32,tag:string) -> Element
    local value = create_element(ELEMENT_CANVAS_SHAPE,tag)
    value.canvas_shape = shape
    value.style.position = POSITION_ABSOLUTE
    value.style.pointer_events = false
    value.style.flex_shrink = 0.0
    return value
end

export fn attach_runner(element:Element,runner)
    if element == null then return end
    if runner == null then element._runner = 0 element.runner_attached = false return end
    element._runner = memory.ptr(runner,0)
    element.runner_attached = true
end

export fn attach_entity(element:Element,entity)
    if element == null then return end
    if entity == null then element._ecs_entity = 0 return end
    element._ecs_entity = memory.ptr(entity,0)
end

-- Event handlers are ordinary LSX functions. Raw function pointers stay private
-- inside the runtime object and are never part of user-facing LSX code.
export fn on_click(element:Element,handler) if element ~= null then element._on_click = handler end return element end
export fn on_change(element:Element,handler) if element ~= null then element._on_change = handler end return element end
export fn on_input(element:Element,handler) if element ~= null then element._on_input = handler end return element end
export fn on_focus(element:Element,handler) if element ~= null then element._on_focus = handler end return element end
export fn on_blur(element:Element,handler) if element ~= null then element._on_blur = handler end return element end
export fn on_key_down(element:Element,handler) if element ~= null then element._on_key_down = handler end return element end
export fn on_key_up(element:Element,handler) if element ~= null then element._on_key_up = handler end return element end
export fn on_pointer_down(element:Element,handler) if element ~= null then element._on_pointer_down = handler end return element end
export fn on_pointer_up(element:Element,handler) if element ~= null then element._on_pointer_up = handler end return element end
export fn on_pointer_move(element:Element,handler) if element ~= null then element._on_pointer_move = handler end return element end
export fn on_scroll(element:Element,handler) if element ~= null then element._on_scroll = handler end return element end
-- Internal lowering target used by lshtml context={...}. The compiler converts
-- the normal LSX object reference to an opaque value so imported object types do
-- not leak into the UI binding signature. User code never writes a pointer.
export fn _set_event_context_handle(element:Element,context_handle:u64)
    if element == null then return element end
    element._event_context = context_handle
    return element
end

-- Programmatic retained UI can bind an ordinary LSX object as event context.
-- The object-to-address conversion remains inside LazyUI so front-end LSX never
-- exposes native pointer syntax.
export fn bind_context(element:Element,context)
    if element == null then return element end
    if context == null then element._event_context = 0
    else element._event_context = memory.ptr(context,0) end
    return element
end

-- Compiler lowering targets for lshtml event handlers. These keep the
-- element, handler, and ordinary LSX context object together so callback
-- parameters can be inferred without exposing types in user code.
export fn _bind_click(element:Element,handler,context_handle:u64) on_click(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_change(element:Element,handler,context_handle:u64) on_change(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_input(element:Element,handler,context_handle:u64) on_input(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_focus(element:Element,handler,context_handle:u64) on_focus(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_blur(element:Element,handler,context_handle:u64) on_blur(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_key_down(element:Element,handler,context_handle:u64) on_key_down(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_key_up(element:Element,handler,context_handle:u64) on_key_up(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_pointer_down(element:Element,handler,context_handle:u64) on_pointer_down(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_pointer_up(element:Element,handler,context_handle:u64) on_pointer_up(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_pointer_move(element:Element,handler,context_handle:u64) on_pointer_move(element,handler) if element ~= null then element._event_context = context_handle end return element end
export fn _bind_scroll(element:Element,handler,context_handle:u64) on_scroll(element,handler) if element ~= null then element._event_context = context_handle end return element end

export fn style_for_state(element:Element,state:i32) -> Style
    if state == STATE_NORMAL then return element.style end
    if state == STATE_HOVER then
        if element.hover_style == null then element.hover_style = copy_style(element.style) end
        return element.hover_style
    end
    if state == STATE_ACTIVE then
        if element.active_style == null then element.active_style = copy_style(element.style) end
        return element.active_style
    end
    if state == STATE_FOCUS then
        if element.focus_style == null then element.focus_style = copy_style(element.style) end
        return element.focus_style
    end
    if state == STATE_DISABLED then
        if element.disabled_style == null then element.disabled_style = copy_style(element.style) end
        return element.disabled_style
    end
    if state == STATE_CHECKED then
        if element.checked_style == null then element.checked_style = copy_style(element.style) end
        return element.checked_style
    end
    if element.selected_style == null then element.selected_style = copy_style(element.style) end
    return element.selected_style
end

export fn apply_style(element:Element,style:Style)
    if element == null or style == null then return end
    if element.style ~= null then element.style.destroy() end
    element.style = copy_style(style)
    element.mark_layout_dirty()
end


