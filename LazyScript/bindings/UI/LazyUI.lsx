fn canvas_absolute(value:f32) -> f32
    if value < 0.0 then return -value end
    return value
end

fn canvas_wrap_angle(value:f32) -> f32
    local result = value
    while result > 3.14159265 do result = result - 6.28318530 end
    while result < -3.14159265 do result = result + 6.28318530 end
    return result
end

fn canvas_sin(value:f32) -> f32
    local x = canvas_wrap_angle(value)
    local base = 1.27323954 * x
    local curve = 0.405284735 * x * x
    local result = base - curve
    if x < 0.0 then result = base + curve end
    local magnitude = canvas_absolute(result)
    local correction = result * magnitude - result
    return result + correction * 0.225
end

fn canvas_cos(value:f32) -> f32
    return canvas_sin(value + 1.57079632)
end

fn canvas_alpha(color:u32,alpha:f32) -> u32
    local original = color / 16777216 % 256
    local adjusted = original * alpha
    if adjusted < 0.0 then adjusted = 0.0 end
    if adjusted > 255.0 then adjusted = 255.0 end
    return color % 16777216 + adjusted * 16777216
end


