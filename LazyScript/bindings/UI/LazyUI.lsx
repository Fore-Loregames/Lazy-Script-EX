export fn canvas_context(element:Element) -> CanvasContext
    if element == null then return null end
    if element.canvas_context == null then element.canvas_context = CanvasContext.new() end
    return element.canvas_context
end


export fn css_display(element:Element,state:i32,value:i32)
    local style = style_for_state(element,state)
    style.display = value
    element.mark_layout_dirty()
end

export fn css_position(element:Element,state:i32,value:i32)
    local style = style_for_state(element,state)
    style.position = value
    element.mark_layout_dirty()
end

