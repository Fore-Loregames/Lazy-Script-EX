    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h26")))
    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h27")))
    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h28")))
    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h29")))
    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h30")))
    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h31")))
    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h32")))
    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h33")))
    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h34")))
    add_horizontal_grid_line(props,props.root.find_id(UI.hash("grid-h35")))
end

fn initialize_graph(props,root)
    props.root = root
    props.graph = root.find_id(UI.hash("graph"))
    props.canvas = root.find_id(UI.hash("graph-canvas"))
    props.minimap = root.find_id(UI.hash("minimap"))
    props.mini_canvas = root.find_id(UI.hash("mini-canvas"))
    add_graph_node(props,root.find_id(UI.hash("node-start")),root.find_id(UI.hash("mini-start")),0.0,0.0)
    add_graph_node(props,root.find_id(UI.hash("node-branch")),root.find_id(UI.hash("mini-branch")),370.0,210.0)
    add_graph_node(props,root.find_id(UI.hash("node-play")),root.find_id(UI.hash("mini-play")),760.0,15.0)
    add_graph_node(props,root.find_id(UI.hash("node-print")),root.find_id(UI.hash("mini-print")),1110.0,270.0)
    add_graph_node(props,root.find_id(UI.hash("node-delay")),root.find_id(UI.hash("mini-delay")),700.0,500.0)
    apply_all_node_positions(props)
    push_grid_lines(props)
    add_connection_slot(props,root.find_id(UI.hash("wire-0-a")),root.find_id(UI.hash("wire-0-b")),root.find_id(UI.hash("wire-0-c")),root.find_id(UI.hash("mini-wire-0")))
    add_connection_slot(props,root.find_id(UI.hash("wire-1-a")),root.find_id(UI.hash("wire-1-b")),root.find_id(UI.hash("wire-1-c")),root.find_id(UI.hash("mini-wire-1")))
    add_connection_slot(props,root.find_id(UI.hash("wire-2-a")),root.find_id(UI.hash("wire-2-b")),root.find_id(UI.hash("wire-2-c")),root.find_id(UI.hash("mini-wire-2")))
    add_connection_slot(props,root.find_id(UI.hash("wire-3-a")),root.find_id(UI.hash("wire-3-b")),root.find_id(UI.hash("wire-3-c")),root.find_id(UI.hash("mini-wire-3")))
    add_connection_slot(props,root.find_id(UI.hash("wire-4-a")),root.find_id(UI.hash("wire-4-b")),root.find_id(UI.hash("wire-4-c")),root.find_id(UI.hash("mini-wire-4")))
    add_connection_slot(props,root.find_id(UI.hash("wire-5-a")),root.find_id(UI.hash("wire-5-b")),root.find_id(UI.hash("wire-5-c")),root.find_id(UI.hash("mini-wire-5")))
    connect_ports(props,root.find_id(UI.hash("port-start-exec")),root.find_id(UI.hash("port-branch-in")))
    connect_ports(props,root.find_id(UI.hash("port-start-position")),root.find_id(UI.hash("port-play-target")))
    connect_ports(props,root.find_id(UI.hash("port-branch-true")),root.find_id(UI.hash("port-play-exec")))
    local initialNode = props.nodes.at(1)
    select_node(props,initialNode.element,"Branch")
    set_zoom_readout(props)
end

fn set_zoom_readout(props)
    if props.root == null then return end
    local readout = props.root.find_id(UI.hash("zoom-readout"))
    if readout == null then return end
    if props.zoom < 0.35 then readout.set_text("30%")
    elseif props.zoom < 0.45 then readout.set_text("40%")
    elseif props.zoom < 0.55 then readout.set_text("50%")
    elseif props.zoom < 0.68 then readout.set_text("60%")
    elseif props.zoom < 0.83 then readout.set_text("75%")
    elseif props.zoom < 0.95 then readout.set_text("90%")
    elseif props.zoom < 1.06 then readout.set_text("100%")
    elseif props.zoom < 1.18 then readout.set_text("110%")
    elseif props.zoom < 1.38 then readout.set_text("125%")
    elseif props.zoom < 1.63 then readout.set_text("150%")
    elseif props.zoom < 1.88 then readout.set_text("175%")
    elseif props.zoom < 2.25 then readout.set_text("200%")
    else readout.set_text("250%") end
end

fn set_graph_zoom(props,newZoom,anchorX,anchorY)
    if props.graph == null then return end
    if newZoom < props.min_zoom then newZoom = props.min_zoom end
    if newZoom > props.max_zoom then newZoom = props.max_zoom end
    local oldZoom = props.zoom
    if oldZoom <= 0.0 then oldZoom = 1.0 end
    local localX = anchorX-props.graph.content_x
    local localY = anchorY-props.graph.content_y
    local worldX = (localX-props.pan_x)/oldZoom
    local worldY = (localY-props.pan_y)/oldZoom
    props.zoom = newZoom
    props.pan_x = localX-worldX*newZoom
    props.pan_y = localY-worldY*newZoom
    apply_all_node_positions(props)
    set_zoom_readout(props)
end

fn zoom_graph_center(props,factor)
    if props.graph == null then return end
    set_graph_zoom(props,props.zoom*factor,props.graph.content_x+props.graph.content_width*0.5,props.graph.content_y+props.graph.content_height*0.5)
end

fn zoom_in_graph(element,event,props)
    zoom_graph_center(props,1.20)
    set_status(props,"Graph zoomed in")
    return 0
end

fn zoom_out_graph(element,event,props)
    zoom_graph_center(props,0.8333333)
    set_status(props,"Graph zoomed out")
    return 0
end

fn reset_zoom_graph(element,event,props)
    if props.graph ~= null then set_graph_zoom(props,1.0,props.graph.content_x+props.graph.content_width*0.5,props.graph.content_y+props.graph.content_height*0.5) end
    set_status(props,"Graph zoom reset")
    return 0
end

fn move_dragging_node(props,x,y)
    if props.dragging_node == null or props.graph == null then return end
    local deltaX = x-props.drag_offset_x
    local deltaY = y-props.drag_offset_y
    local absoluteX = graph_absolute_value(deltaX)
    local absoluteY = graph_absolute_value(deltaY)
    if not props.dragging_node_moved then
        if absoluteX < 2.0 and absoluteY < 2.0 then return end
        props.dragging_node_moved = true
    end
    local zoom = props.zoom
    if zoom <= 0.0 then zoom = 1.0 end
    props.dragging_node.world_x = props.drag_world_x+deltaX/zoom
    props.dragging_node.world_y = props.drag_world_y+deltaY/zoom
    apply_node_screen_position(props,props.dragging_node)
    props.pointer_x = x
    props.pointer_y = y
    props.graph_dirty = true
end

fn move_graph_camera(props,x,y)
    if not props.panning then return end
    local deltaX = x-props.pan_start_x
    local deltaY = y-props.pan_start_y
    if not props.panning_moved then
        if graph_absolute_value(deltaX) < 2.0 and graph_absolute_value(deltaY) < 2.0 then return end
        props.panning_moved = true
    end
    props.pan_x = props.pan_origin_x+deltaX
    props.pan_y = props.pan_origin_y+deltaY
    apply_all_node_positions(props)
end

fn ensure_pointer_gesture_started(props,root,button,x,y)
    if props == null or root == null then return end
    local target = UI.hit_test(root,x,y)
    if button == GLFW.GLFW_MOUSE_BUTTON_MIDDLE and point_inside_graph(props,x,y) then
        if not props.panning then
            props.panning = true
            props.panning_moved = false
            props.pan_start_x = x
            props.pan_start_y = y
            props.pan_origin_x = props.pan_x
            props.pan_origin_y = props.pan_y
        end
        return
    end
    if button ~= GLFW.GLFW_MOUSE_BUTTON_LEFT then return end
    if props.space_down and point_inside_graph(props,x,y) then
        if not props.panning then
            props.panning = true
            props.panning_moved = false
            props.pan_start_x = x
            props.pan_start_y = y
            props.pan_origin_x = props.pan_x
            props.pan_origin_y = props.pan_y
        end
        return
    end
    if target == null then return end
    local title = element_or_ancestor_has_class(target,"node-title")
    if title ~= null and props.dragging_node == null then
        local node = find_graph_node_ancestor(props,title)
        if node ~= null then
            props.dragging_node = node
            props.dragging_node_moved = false
            props.drag_offset_x = x
            props.drag_offset_y = y
            props.drag_world_x = node.world_x
            props.drag_world_y = node.world_y
            select_node(props,node.element,title.text)
        end
        return
    end
    local socket = element_or_ancestor_has_class(target,"socket")
    if socket ~= null and socket.min_value >= 0.5 and not props.dragging_wire then
        clear_pending_output(props)
        props.pending_output = socket
        props.dragging_wire = true
        props.pointer_x = x
        props.pointer_y = y
        socket.selected = true
        socket.mark_visual_dirty()
        props.graph_dirty = true
        return
    end
    local mini = element_or_ancestor_has_class(target,"minimap")
    if mini ~= null and not props.minimap_dragging then
        props.minimap_dragging = true
        minimap_pan_to_xy(props,x,y)
    end
end

fn update_active_graph_gesture(props,x,y)
    props.pointer_x = x
    props.pointer_y = y
    if props.dragging_node ~= null then move_dragging_node(props,x,y)
    elseif props.panning then move_graph_camera(props,x,y)
    elseif props.minimap_dragging then minimap_pan_to_xy(props,x,y)
    elseif props.dragging_wire then props.graph_dirty = true end
end

fn node_drag_start(element,event,props)
    if event.button ~= GLFW.GLFW_MOUSE_BUTTON_LEFT then return 0 end
    local nodeElement = element.parent
    if nodeElement == null or props.graph == null then return 0 end
    local node = find_graph_node(props,nodeElement)
    if node == null then return 0 end
    props.dragging_node = node
    props.dragging_node_moved = false
    props.drag_offset_x = event.x
    props.drag_offset_y = event.y
    props.drag_world_x = node.world_x
    props.drag_world_y = node.world_y
    select_node(props,node.element,element.text)
    set_status(props,"Moving node")
    event.prevent_default()
    return 0
end

fn node_drag_move(element,event,props)
    move_dragging_node(props,event.x,event.y)
    event.prevent_default()
    return 0
end

fn node_drag_end(element,event,props)
    move_dragging_node(props,event.x,event.y)
    local moved = props.dragging_node_moved
    props.dragging_node = null
    props.dragging_node_moved = false
    if moved then set_status(props,"Node moved") else set_status(props,"Node selected") end
    event.prevent_default()
    return 0
end

fn graph_pan_start(element,event,props)
    local valid = event.button == GLFW.GLFW_MOUSE_BUTTON_MIDDLE
    if event.button == GLFW.GLFW_MOUSE_BUTTON_LEFT and props.space_down then valid = true end
    if not valid then return 0 end
    props.panning = true
    props.panning_moved = false
    props.pan_start_x = event.x
    props.pan_start_y = event.y
    props.pan_origin_x = props.pan_x
    props.pan_origin_y = props.pan_y
    set_status(props,"Panning graph camera")
    event.prevent_default()
    return 0
end

fn graph_pan_move(element,event,props)
    move_graph_camera(props,event.x,event.y)
    event.prevent_default()
    return 0
end

fn graph_pan_end(element,event,props)
    move_graph_camera(props,event.x,event.y)
    local moved = props.panning_moved
    props.panning = false
    props.panning_moved = false
    if moved then set_status(props,"Graph pan complete") end
    event.prevent_default()
    return 0
end

fn graph_scrolled(element,event,props)
    local factor = 1.12
    if event.delta_y < 0.0 then factor = 0.8928571 end
    if event.delta_y == 0.0 then
        if event.delta_x > 0.0 then factor = 1.12
        elseif event.delta_x < 0.0 then factor = 0.8928571 end
    end
    set_graph_zoom(props,props.zoom*factor,event.x,event.y)
    set_status(props,"Wheel zoomed graph at pointer")
    event.prevent_default()
    return 0
end

fn minimap_pan_to_xy(props,x,y)
    if props.graph == null or props.mini_canvas == null then return end
    local width = props.mini_canvas.content_width
    local height = props.mini_canvas.content_height
    if width <= 0.0 or height <= 0.0 then return end
    local ratioX = (x-props.mini_canvas.content_x)/width
    local ratioY = (y-props.mini_canvas.content_y)/height
    if ratioX < 0.0 then ratioX = 0.0 end
    if ratioX > 1.0 then ratioX = 1.0 end
    if ratioY < 0.0 then ratioY = 0.0 end
    if ratioY > 1.0 then ratioY = 1.0 end
    local worldX = props.map_min_x+ratioX*(props.map_max_x-props.map_min_x)
    local worldY = props.map_min_y+ratioY*(props.map_max_y-props.map_min_y)
    props.pan_x = props.graph.content_width*0.5-worldX*props.zoom
    props.pan_y = props.graph.content_height*0.5-worldY*props.zoom
    apply_all_node_positions(props)
end

fn minimap_pan_start(element,event,props)
    if event.button ~= GLFW.GLFW_MOUSE_BUTTON_LEFT then return 0 end
    props.minimap_dragging = true
    minimap_pan_to_xy(props,event.x,event.y)
    set_status(props,"Navigator moving camera")
    event.prevent_default()
    return 0
end

fn minimap_pan_move(element,event,props)
    if props.minimap_dragging then minimap_pan_to_xy(props,event.x,event.y) end
    event.prevent_default()
    return 0
end

fn minimap_pan_end(element,event,props)
    if props.minimap_dragging then minimap_pan_to_xy(props,event.x,event.y) end
    props.minimap_dragging = false
    set_status(props,"Navigator recentered graph")
    event.prevent_default()
    return 0
end

fn port_drag_start(element,event,props)
    if event.button ~= GLFW.GLFW_MOUSE_BUTTON_LEFT or element.min_value < 0.5 then return 0 end
    clear_pending_output(props)
    props.pending_output = element
    props.dragging_wire = true
    props.pointer_x = event.x props.pointer_y = event.y
    element.selected = true element.mark_visual_dirty()
    props.graph_dirty = true
    set_status(props,"Dragging wire - drop on a matching input pin")
    event.prevent_default()
    return 0
end

fn port_drag_move(element,event,props)
    if not props.dragging_wire then return 0 end
    props.pointer_x = event.x props.pointer_y = event.y props.graph_dirty = true
    event.prevent_default()
    return 0
end

fn port_drag_end(element,event,props)
    if not props.dragging_wire then return 0 end
    props.pointer_x = event.x props.pointer_y = event.y
    local target = UI.hit_test(props.root,event.x,event.y)
    local connected = false
    if target ~= null and target.has_class("socket") and target.min_value < 0.5 then connected = connect_ports(props,props.pending_output,target) end
    clear_pending_output(props)
    if connected then set_status(props,"Pins connected by drag and drop")
    else set_status(props,"Wire cancelled - drop directly on a matching input pin") end
    event.prevent_default()
    return 0
end

fn input_port_clicked(element,event,props)
    local existing = find_connection_to(props,element)
    if existing ~= null then disconnect_connection(existing) props.graph_dirty = true set_status(props,"Input wire disconnected")
    else set_status(props,"Input is unconnected - drag an output pin onto it") end
    return 0
end

fn compile_graph(element,event,props)
    set_status(props,"Graph compiled - active pin types validated")
    return 0
end

fn clear_connections_clicked(element,event,props)
    local index = 0
    while index < props.connections.length() do
        disconnect_connection(props.connections.at(index))
        index = index + 1
    end
    clear_pending_output(props)
    props.graph_dirty = true
    set_status(props,"All wires cleared")
    return 0
end

fn auto_layout_graph(element,event,props)
    set_world_position(props.nodes.at(0),0.0,20.0)
    set_world_position(props.nodes.at(1),350.0,210.0)
    set_world_position(props.nodes.at(2),730.0,20.0)
    set_world_position(props.nodes.at(3),1080.0,240.0)
    set_world_position(props.nodes.at(4),700.0,500.0)
    apply_all_node_positions(props)
    set_status(props,"Auto layout applied")
    return 0
end

fn frame_graph_contents(props)
    if props.graph == null or props.nodes.length() == 0 then return end
    local minX = 1000000.0
    local minY = 1000000.0
    local maxX = -1000000.0
    local maxY = -1000000.0
    local index = 0
    while index < props.nodes.length() do
        local node = props.nodes.at(index)
        if node.element ~= null and not node.element.hidden then
            if node.world_x < minX then minX = node.world_x end
            if node.world_y < minY then minY = node.world_y end
            if node.world_x+250.0 > maxX then maxX = node.world_x+250.0 end
            if node.world_y+190.0 > maxY then maxY = node.world_y+190.0 end
        end
        index = index + 1
    end
    local boundsWidth = maxX-minX
    local boundsHeight = maxY-minY
    if boundsWidth <= 1.0 then boundsWidth = 1.0 end
    if boundsHeight <= 1.0 then boundsHeight = 1.0 end
    local targetX = (props.graph.content_width-100.0)/boundsWidth
    local targetY = (props.graph.content_height-100.0)/boundsHeight
    local target = targetX
    if targetY < target then target = targetY end
    if target > 1.25 then target = 1.25 end
    if target < props.min_zoom then target = props.min_zoom end
    props.zoom = target
    props.pan_x = props.graph.content_width*0.5-(minX+maxX)*0.5*target
    props.pan_y = props.graph.content_height*0.5-(minY+maxY)*0.5*target
    apply_all_node_positions(props)
    set_zoom_readout(props)
end

fn frame_all_graph(element,event,props)
    frame_graph_contents(props)
    set_status(props,"All graph nodes framed")
    return 0
end

fn add_palette_node(element,event,props)
    local node = null
    local title = "Node"
    if element.number_value == 4.0 then node = props.nodes.at(3) title = "Print String"
    elseif element.number_value == 5.0 then node = props.nodes.at(4) title = "Delay" end
    if node == null or node.element == null then return 0 end
    if node.element.hidden then
        node.element.hidden = false
        props.node_count = props.node_count+1
        node.element.mark_layout_dirty()
        set_node_count_text(props)
        props.graph_dirty = true
        set_status(props,"Node added from palette")
    else set_status(props,"Node is already present") end
    select_node(props,node.element,title)
    return 0
end

fn graph_absolute_value(value)
    if value < 0.0 then return -value end
    return value
end

fn graph_hit_is(root,element,x,y)
    if root == null or element == null then return false end
    local target = UI.hit_test(root,x,y)
    if target == null then return false end
    return target.id_hash == element.id_hash
end

fn verify_graph_interactions(document,props)
    if document == null or props == null or props.root == null or props.graph == null or props.minimap == null then return false end
    local title = props.root.find_id(UI.hash("title-start"))
    local output = props.root.find_id(UI.hash("port-start-actor"))
    local input = props.root.find_id(UI.hash("port-branch-condition"))
    local miniStart = props.root.find_id(UI.hash("mini-start"))
    local miniView = props.root.find_id(UI.hash("mini-view"))
    local miniWire = props.root.find_id(UI.hash("mini-wire-0"))
    if title == null or output == null or input == null or miniStart == null or miniView == null or miniWire == null or props.nodes.length() < 3 then return false end

    local verifyWidth = document.width
    local verifyHeight = document.height
    if verifyWidth < 100.0 then verifyWidth = 1460.0 end
    if verifyHeight < 100.0 then verifyHeight = 860.0 end
    document.resize(verifyWidth,verifyHeight)
    update_graph_visuals(props)
    local passed = true

    local titleX = title.content_x+title.content_width*0.5
    local titleY = title.content_y+title.content_height*0.5
    if not graph_hit_is(props.root,title,titleX,titleY) then passed = false end

    -- Title dragging must travel through the real Document pointer capture path.
    local node = props.nodes.at(0)
    local originalNodeX = node.world_x
    local originalNodeY = node.world_y
    document.pointer_move(titleX,titleY)
    document.pointer_down_button(GLFW.GLFW_MOUSE_BUTTON_LEFT)
    document.pointer_move(titleX+42.0,titleY+26.0)
    document.pointer_up_button(GLFW.GLFW_MOUSE_BUTTON_LEFT)
    if graph_absolute_value(node.world_x-(originalNodeX+42.0/props.zoom)) > 0.75 then passed = false end
    if graph_absolute_value(node.world_y-(originalNodeY+26.0/props.zoom)) > 0.75 then passed = false end
    set_world_position(node,originalNodeX,originalNodeY)
    apply_all_node_positions(props)
    document.resize(document.width,document.height)
    update_graph_visuals(props)

    -- The graph is an unbounded camera: MMB changes pan; no retained scrollbar
    -- state is allowed to become the graph navigation mechanism.
    local blankX = props.graph.content_x+props.graph.content_width-300.0
    local blankY = props.graph.content_y+props.graph.content_height-220.0
    local originalPanX = props.pan_x
    local originalPanY = props.pan_y
    document.pointer_move(blankX,blankY)
    document.pointer_down_button(GLFW.GLFW_MOUSE_BUTTON_MIDDLE)
    document.pointer_move(blankX+36.0,blankY-22.0)
    document.pointer_up_button(GLFW.GLFW_MOUSE_BUTTON_MIDDLE)
    if graph_absolute_value(props.pan_x-(originalPanX+36.0)) > 0.75 then passed = false end
    if graph_absolute_value(props.pan_y-(originalPanY-22.0)) > 0.75 then passed = false end
    if props.graph.scroll_x ~= 0.0 or props.graph.scroll_y ~= 0.0 then passed = false end
    if props.graph.scroll_max_x ~= 0.0 or props.graph.scroll_max_y ~= 0.0 then passed = false end

    -- Wheel zoom keeps the world point under the cursor anchored.
    local zoomBefore = props.zoom
    document.pointer_move(blankX,blankY)
    document.scroll(0.0,1.0)
    if props.zoom <= zoomBefore then passed = false end

    -- Navigator must contain node rectangles, live viewport and active links.
    document.resize(document.width,document.height)
    update_graph_visuals(props)
    if miniStart.hidden or miniStart.canvas_width <= 0.0 or miniStart.canvas_height <= 0.0 then passed = false end
    if miniView.canvas_width <= 0.0 or miniView.canvas_height <= 0.0 then passed = false end
    if miniWire.hidden then passed = false end
    local mapStartX = props.mini_canvas.content_x+props.mini_canvas.content_width*0.25
    local mapStartY = props.mini_canvas.content_y+props.mini_canvas.content_height*0.25
    local panBeforeMapX = props.pan_x
    local panBeforeMapY = props.pan_y
    document.pointer_move(mapStartX,mapStartY)
    document.pointer_down_button(GLFW.GLFW_MOUSE_BUTTON_LEFT)
    document.pointer_move(mapStartX+24.0,mapStartY+16.0)
    document.pointer_up_button(GLFW.GLFW_MOUSE_BUTTON_LEFT)
    if graph_absolute_value(props.pan_x-panBeforeMapX) < 1.0 and graph_absolute_value(props.pan_y-panBeforeMapY) < 1.0 then passed = false end

    -- Pins connect using pointer capture and final hit-testing at release.
    document.resize(document.width,document.height)
    update_graph_visuals(props)
    local outputX = output.x+output.width*0.5
    local outputY = output.y+output.height*0.5
    local inputX = input.x+input.width*0.5
    local inputY = input.y+input.height*0.5
    document.pointer_move(outputX,outputY)
    document.pointer_down_button(GLFW.GLFW_MOUSE_BUTTON_LEFT)
    document.pointer_move(inputX,inputY)
    document.pointer_up_button(GLFW.GLFW_MOUSE_BUTTON_LEFT)
    local connected = find_connection_to(props,input)
    if connected == null or connected.output == null or connected.output.id_hash ~= output.id_hash then passed = false end

    props.dragging_node = null
    props.dragging_node_moved = false
    props.panning = false
    props.panning_moved = false
    props.minimap_dragging = false
    clear_pending_output(props)
    props.zoom = 1.0
    props.pan_x = originalPanX
    props.pan_y = originalPanY
    set_world_position(node,originalNodeX,originalNodeY)
    apply_all_node_positions(props)
    document.resize(document.width,document.height)
    update_graph_visuals(props)
    document.focus(null)
    return passed
end

fn destroy_graph_props(props)
    if props == null then return end
    local index = 0
    if props.connections ~= null then
        while index < props.connections.length() do
            local connection = props.connections.at(index)
            if connection ~= null then
                connection.output = null connection.input = null
                connection.line_a = null connection.line_b = null connection.line_c = null connection.mini_line = null
                connection.destroy()
            end
            index = index + 1
        end
        props.connections.destroy() props.connections = null
    end
    index = 0
    if props.nodes ~= null then
        while index < props.nodes.length() do
            local node = props.nodes.at(index)
            if node ~= null then node.element = null node.mini = null node.destroy() end
            index = index + 1
        end
        props.nodes.destroy() props.nodes = null
    end
    index = 0
    if props.vertical_grid ~= null then
        while index < props.vertical_grid.length() do
            local vertical = props.vertical_grid.at(index)
            if vertical ~= null then vertical.element = null vertical.destroy() end
            index = index + 1
        end
        props.vertical_grid.destroy() props.vertical_grid = null
    end
    index = 0
    if props.horizontal_grid ~= null then
        while index < props.horizontal_grid.length() do
            local horizontal = props.horizontal_grid.at(index)
            if horizontal ~= null then horizontal.element = null horizontal.destroy() end
            index = index + 1
        end
        props.horizontal_grid.destroy() props.horizontal_grid = null
    end
    props.dragging_node = null
    props.pending_output = null
    props.root = null
    props.graph = null
    props.canvas = null
    props.minimap = null
    props.mini_canvas = null
    props.destroy()
end

fn main()
    local props = GraphProps.new()
    local root = graph_view(props)
    initialize_graph(props,root)
    if GLFW.lsxLoadLibraries() < 1 or GLFW.glfwInit() == 0 then return fail("GLFW initialization failed.") end
    GLFW.glfwWindowHint(GLFW.GLFW_CONTEXT_VERSION_MAJOR,4)
    GLFW.glfwWindowHint(GLFW.GLFW_CONTEXT_VERSION_MINOR,6)
    GLFW.glfwWindowHint(GLFW.GLFW_OPENGL_PROFILE,GLFW.GLFW_OPENGL_CORE_PROFILE)
    local window = GLFW.glfwCreateWindow(1460,860,"31 - LazyUI infinite draggable node graph",0,0)
    if window == 0 then return fail("Window creation failed.") end
    GLFW.glfwMakeContextCurrent(window)
    GLFW.glfwSwapInterval(1)
    if GL.lsxLoadOpenGL() < 1 then return fail("OpenGL initialization failed.") end
    local renderer = UIRenderer.create(null,64)
    local document = UI.document(root)
    local windowInput = UI.connect_window_input(window,document)
    local framebuffer = GLFW.FramebufferSize.new()
    local windowSize = GLFW.WindowSize.new()
    local cursor = GLFW.CursorPosition.new()
    local mouseButtonDown = -1
    local previousWidth = 0
    local previousHeight = 0
    local frameKeyDown = false
    local plusKeyDown = false
    local minusKeyDown = false

    framebuffer.refresh(window)
    windowSize.refresh(window)
    document.resize(framebuffer.width,framebuffer.height)
    apply_all_node_positions(props)
    document.resize(framebuffer.width,framebuffer.height)
    update_graph_visuals(props)
    -- Do not synthesize a full interaction sequence before the first visible
    -- frame. On a real GLFW window that can route pointer capture through an
    -- unpainted document and terminate the example before the window appears.
    -- The same verification routine remains available to compiler/runtime tests.
    set_status(props,"Ready - drag nodes, pins, empty graph space, wheel, and minimap")

    while GLFW.glfwWindowShouldClose(window) == 0 do
        framebuffer.refresh(window)
        windowSize.refresh(window)
        if framebuffer.width ~= previousWidth or framebuffer.height ~= previousHeight then props.graph_dirty = true previousWidth = framebuffer.width previousHeight = framebuffer.height end
        document.resize(framebuffer.width,framebuffer.height)
        cursor.refresh(window)
        props.space_down = GLFW.glfwGetKey(window,GLFW.GLFW_KEY_SPACE) == GLFW.GLFW_PRESS
        local framePressed = GLFW.glfwGetKey(window,GLFW.GLFW_KEY_F) == GLFW.GLFW_PRESS
        local plusPressed = GLFW.glfwGetKey(window,GLFW.GLFW_KEY_EQUAL) == GLFW.GLFW_PRESS
        local minusPressed = GLFW.glfwGetKey(window,GLFW.GLFW_KEY_MINUS) == GLFW.GLFW_PRESS
        if framePressed and not frameKeyDown then frame_graph_contents(props) set_status(props,"All graph nodes framed") end
        if plusPressed and not plusKeyDown then zoom_graph_center(props,1.20) end
        if minusPressed and not minusKeyDown then zoom_graph_center(props,0.8333333) end
        frameKeyDown = framePressed
        plusKeyDown = plusPressed
        minusKeyDown = minusPressed
        document.pointer_move_scaled(cursor.x,cursor.y,windowSize.width,windowSize.height)
        props.pointer_x = document.pointer_x props.pointer_y = document.pointer_y
        local pressedButton = -1
        if GLFW.glfwGetMouseButton(window,GLFW.GLFW_MOUSE_BUTTON_LEFT) == GLFW.GLFW_PRESS then pressedButton = GLFW.GLFW_MOUSE_BUTTON_LEFT
        elseif GLFW.glfwGetMouseButton(window,GLFW.GLFW_MOUSE_BUTTON_MIDDLE) == GLFW.GLFW_PRESS then pressedButton = GLFW.GLFW_MOUSE_BUTTON_MIDDLE end
        if pressedButton >= 0 and mouseButtonDown < 0 then
            document.pointer_down_button(pressedButton)
            -- The retained Document provides normal pointer capture. This
            -- graph-owned fallback mirrors the source editor controller and
            -- guarantees title dragging/MMB panning/minimap navigation even
            -- when a decorative child is the exact hit target.
            ensure_pointer_gesture_started(props,root,pressedButton,document.pointer_x,document.pointer_y)
        end
        if pressedButton >= 0 then update_active_graph_gesture(props,document.pointer_x,document.pointer_y) end
        if pressedButton < 0 and mouseButtonDown >= 0 then
            update_active_graph_gesture(props,document.pointer_x,document.pointer_y)
            document.pointer_up_button(mouseButtonDown)
            props.dragging_node = null
            props.dragging_node_moved = false
            props.panning = false
            props.panning_moved = false
            props.minimap_dragging = false
            if props.dragging_wire then clear_pending_output(props) end
        end
        mouseButtonDown = pressedButton
        document.resize(framebuffer.width,framebuffer.height)
        update_graph_visuals(props)

        GL.glViewport(0,0,framebuffer.width,framebuffer.height)
        GL.glClearColor(0.015,0.02,0.03,1.0)
        GL.glClear(GL.GL_COLOR_BUFFER_BIT)
        renderer.begin(framebuffer.width,framebuffer.height)
        renderer.submit(root)
        renderer.flush()
        GLFW.glfwSwapBuffers(window)
        GLFW.glfwPollEvents()
    end

    windowInput.destroy()
    cursor.destroy()
    windowSize.destroy()
    framebuffer.destroy()
    document.destroy()
    renderer.destroy()
    destroy_graph_props(props)
    GLFW.glfwDestroyWindow(window)
    GLFW.glfwTerminate()
    GLFW.lsxUnloadLibraries()
    return 0
end

fn fail(message)
    Win32.MessageBoxA(0,message,"LazyUI",Win32.MB_OK+Win32.MB_ICONERROR)
    return 1
end
