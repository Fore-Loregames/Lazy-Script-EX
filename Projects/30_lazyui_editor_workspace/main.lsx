    flex_shrink = 0
    padding = "6px 9px"
    flex_direction = "row"
    align_items = "center"
    background = "#202c3e"
    border_bottom = "1px #354761"
    color = "#f1f5ff"
}
lscss .hierarchy = {
    flex_grow = 1
    min_height = "0px"
    padding = "4px 20px 4px 4px"
    gap = "2px"
    overflow_x = "hidden"
    overflow_y = "scroll"
}
lscss treeitem = {
    height = "24px"
    flex_shrink = 0
    padding = "4px 7px"
