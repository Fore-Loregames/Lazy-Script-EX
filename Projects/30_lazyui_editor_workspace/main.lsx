lshtml workspace(props) = {(
    <ui class="editor">
        <menubar class="menubar"><menuitem>File</menuitem><menuitem>Edit</menuitem><menuitem>Assets</menuitem><menuitem>GameObject</menuitem><menuitem>Window</menuitem><menuitem>Help</menuitem></menubar>
        <toolbar class="toolbar"><button class="tool">W</button><button class="tool">E</button><button class="tool">R</button><separator /><button class="tool play">Play</button><button class="tool">Pause</button><spacer /><badge>Local</badge><badge>Shaded</badge></toolbar>
        <row class="workspace">
            <dockpanel class="dock left">
                <titlebar class="panel-head"><span>Hierarchy</span><spacer /><badge>34</badge></titlebar>
                <hierarchy class="hierarchy">
                    <treeitem selected>v Main Scene</treeitem>
                    <treeitem class="indent-1">Directional Light</treeitem><treeitem class="indent-1">Global Volume</treeitem><treeitem class="indent-1">Reflection Probe</treeitem>
                    <treeitem>v Environment</treeitem><treeitem class="indent-1">Terrain</treeitem><treeitem class="indent-1">Water Plane</treeitem><treeitem class="indent-1">Sky Controller</treeitem><treeitem class="indent-1">Fog Volume</treeitem>
                    <treeitem>v Characters</treeitem><treeitem class="indent-1">Player</treeitem><treeitem class="indent-2">Body Mesh</treeitem><treeitem class="indent-2">Animator</treeitem><treeitem class="indent-2">Camera Target</treeitem><treeitem class="indent-1">Companion</treeitem><treeitem class="indent-2">Body Mesh</treeitem><treeitem class="indent-2">AI Controller</treeitem>
                    <treeitem>v Gameplay Systems</treeitem><treeitem class="indent-1">Quest Manager</treeitem><treeitem class="indent-1">Dialogue Manager</treeitem><treeitem class="indent-1">Inventory Manager</treeitem><treeitem class="indent-1">Save System</treeitem><treeitem class="indent-1">LazyBehavior Host</treeitem>
                    <treeitem>v Props</treeitem><treeitem class="indent-1">Farm House</treeitem><treeitem class="indent-1">Well</treeitem><treeitem class="indent-1">Barn</treeitem><treeitem class="indent-1">Fence Group</treeitem><treeitem class="indent-1">Market Stall</treeitem><treeitem class="indent-1">Road Signs</treeitem><treeitem class="indent-1">Bridge</treeitem><treeitem class="indent-1">Windmill</treeitem><treeitem class="indent-1">Lantern Group</treeitem><treeitem class="indent-1">Ambient Audio</treeitem>
                </hierarchy>
            </dockpanel>
            <column class="center">
                <dockpanel class="dock scene">
                    <tabs class="tabs"><tab selected>Scene</tab><tab>Game</tab><tab>Lighting</tab><spacer /><badge>Perspective</badge></tabs>
                    <canvas class="scene">
                        <rect class="scene-grid" x=55 y=40 width=620 height=330 />
                        <line x1=80 y1=300 x2=640 y2=300 stroke="#49617f" stroke_width=2 />
                        <line x1=360 y1=65 x2=360 y2=340 stroke="#49617f" stroke_width=2 />
                        <circle cx=360 cy=205 r=72 fill="#3e82ff" />
                        <canvas-text x=90 y=80 fill="#dce9ff" font_size=20>Scene viewport and gizmo canvas</canvas-text>
                    </canvas>
                </dockpanel>
                <row class="bottom">
                    <projectbrowser class="dock project">
                        <row class="panel-head"><breadcrumb>Assets / Environment / Materials</breadcrumb><spacer /><search placeholder="Search assets..." /></row>
                        <column class="asset-scroll">
                            <grid class="asset-grid">
                                <thumbnail>Grass</thumbnail><thumbnail>Rock</thumbnail><thumbnail>Water</thumbnail><thumbnail>Sky</thumbnail>
                                <thumbnail>Tree</thumbnail><thumbnail>Path</thumbnail><thumbnail>House</thumbnail><thumbnail>Fence</thumbnail>
                                <thumbnail>Mud</thumbnail><thumbnail>Roof</thumbnail><thumbnail>Glass</thumbnail><thumbnail>Metal</thumbnail>
                                <thumbnail>Lantern</thumbnail><thumbnail>Flower</thumbnail><thumbnail>Bridge</thumbnail><thumbnail>Windmill</thumbnail>
                                <thumbnail>Hay</thumbnail><thumbnail>Stone Wall</thumbnail><thumbnail>River Foam</thumbnail><thumbnail>Clouds</thumbnail>
                            </grid>
                        </column>
                    </projectbrowser>
                    <console class="dock console">
                        <tabs class="tabs"><tab selected>Console</tab><tab>Profiler</tab><tab>Jobs</tab></tabs>
                        <column class="console-list">
                            <consoleentry class="success">Renderer initialized in 18.2 ms</consoleentry><consoleentry>Loaded scene MainScene.lsx</consoleentry>
                            <consoleentry>Compiled 12 LazyBehavior scripts</consoleentry><consoleentry>Uploaded 148 material instances</consoleentry>
                            <consoleentry class="warn">Warning: reflection probe uses fallback cubemap</consoleentry><consoleentry>Terrain streaming cell 4,7 ready</consoleentry>
                            <consoleentry>Audio mixer initialized</consoleentry><consoleentry>Navigation mesh rebuilt in 6.4 ms</consoleentry>
                            <consoleentry>Saved autosave/MainScene_004.scene</consoleentry><consoleentry class="error">Example error row for styling</consoleentry>
                            <consoleentry>Shader cache hit: 97.3%</consoleentry><consoleentry>UI batches: 4 draws</consoleentry>
                            <consoleentry>Hierarchy virtualization active</consoleentry><consoleentry>Editor frame complete</consoleentry>
                        </column>
                    </console>
                </row>
            </column>
            <dockpanel class="dock right">
                <titlebar class="panel-head"><span>Inspector</span><spacer /><badge>Player</badge></titlebar>
                <propertyeditor class="inspector">
                    <componentheader>Transform</componentheader>
                    <property><label class="property-label">Position</label><row class="vector-row"><row class="axis"><span class="axis-label">X</span><number class="axis-value" value="0.0" /></row><row class="axis"><span class="axis-label">Y</span><number class="axis-value" value="1.0" /></row><row class="axis"><span class="axis-label">Z</span><number class="axis-value" value="0.0" /></row></row></property>
                    <property><label class="property-label">Rotation</label><row class="vector-row"><row class="axis"><span class="axis-label">X</span><number class="axis-value" value="0.0" /></row><row class="axis"><span class="axis-label">Y</span><number class="axis-value" value="35.0" /></row><row class="axis"><span class="axis-label">Z</span><number class="axis-value" value="0.0" /></row></row></property>
                    <property><label class="property-label">Scale</label><row class="vector-row"><row class="axis"><span class="axis-label">X</span><number class="axis-value" value="1.0" /></row><row class="axis"><span class="axis-label">Y</span><number class="axis-value" value="1.0" /></row><row class="axis"><span class="axis-label">Z</span><number class="axis-value" value="1.0" /></row></row></property>
                    <componentheader>Mesh Renderer</componentheader>
                    <property class="asset-property"><label class="property-label">Mesh</label><row class="asset-picker"><panel class="asset-icon">M</panel><column class="asset-copy"><span class="asset-title">PlayerBody.glb</span><span class="asset-subtitle">Skinned mesh | 42,816 vertices</span></column><button class="picker-button" onclick={asset_clicked} context={props}>...</button></row></property>
                    <property class="asset-property"><label class="property-label">Material</label><row class="asset-picker"><panel class="asset-icon material-icon">MAT</panel><column class="asset-copy"><span class="asset-title">M_PlayerSkin</span><span class="asset-subtitle">PBR material instance</span></column><button class="picker-button" onclick={asset_clicked} context={props}>...</button></row></property>
                    <property><label class="property-label">Cast Shadows</label><checkbox checked>Enabled</checkbox></property>
                    <property><label class="property-label">Receive Shadows</label><checkbox checked>Enabled</checkbox></property>
                    <property><label class="property-label">Render Layer</label><select class="wide-value" value="Default"><option value="Default" selected>Default</option><option value="Characters">Characters</option><option value="Environment">Environment</option><option value="UI Preview">UI Preview</option></select></property>
                    <componentheader>Rigidbody</componentheader>
                    <property><label class="property-label">Mass</label><number class="wide-value" value="75.0" /></property>
                    <property><label class="property-label">Drag</label><number class="wide-value" value="0.15" /></property>
                    <property><label class="property-label">Use Gravity</label><checkbox checked>Enabled</checkbox></property>
                    <property><label class="property-label">Kinematic</label><checkbox>Disabled</checkbox></property>
                    <componentheader>Capsule Collider</componentheader>
                    <property><label class="property-label">Center</label><row class="vector-row"><row class="axis"><span class="axis-label">X</span><number class="axis-value" value="0.0" /></row><row class="axis"><span class="axis-label">Y</span><number class="axis-value" value="0.9" /></row><row class="axis"><span class="axis-label">Z</span><number class="axis-value" value="0.0" /></row></row></property>
                    <property><label class="property-label">Radius</label><number class="wide-value" value="0.45" /></property>
                    <property><label class="property-label">Height</label><number class="wide-value" value="1.8" /></property>
                    <componentheader>LazyBehavior</componentheader>
                    <property class="asset-property"><label class="property-label">Script</label><row class="asset-picker"><panel class="asset-icon script-icon">LSX</panel><column class="asset-copy"><span class="asset-title">PlayerController.lsx</span><span class="asset-subtitle">Compiled LazyBehavior</span></column><button class="picker-button" onclick={asset_clicked} context={props}>...</button></row></property>
                    <property><label class="property-label">Speed</label><number class="wide-value" value="6.5" /></property>
                    <property><label class="property-label">Jump Force</label><number class="wide-value" value="8.0" /></property>
                    <property><label class="property-label">Input Map</label><select class="wide-value" value="Player"><option value="Player" selected>Player</option><option value="UI">UI</option><option value="Vehicle">Vehicle</option></select></property>
                    <componentheader>Audio Source</componentheader>
                    <property class="asset-property"><label class="property-label">Clip</label><row class="asset-picker"><panel class="asset-icon audio-icon">SFX</panel><column class="asset-copy"><span class="asset-title">Footsteps_Grass.wav</span><span class="asset-subtitle">48 kHz mono clip</span></column><button class="picker-button" onclick={asset_clicked} context={props}>...</button></row></property>
                    <property><label class="property-label">Volume</label><range class="wide-value" min=0 max=100 step=1 number-value=72 /></property>
                    <property><label class="property-label">Spatial</label><checkbox checked>3D</checkbox></property>
                </propertyeditor>
            </dockpanel>
        </row>
        <statusbar class="status"><span id="editor-status">{props.status}</span><spacer /><span>4 instanced draws | visible independent scrollbars | SDF text</span></statusbar>
    </ui>
)}

fn asset_clicked(element,event,props)
    props.status = "Asset picker button clicked - hierarchy, project, console and inspector keep separate scroll state"
    local root = element
    while root.parent ~= null do root = root.parent end
    local status = root.find_id(UI.hash("editor-status"))
    if status ~= null then status.set_text(props.status) end
    return 0
end

fn main()
    local props = EditorProps.new()
    local root = workspace(props)
    local window = LSG.open("30 - LazyUI editor workspace",1440,850)
    if window.ready() then window.set_vsync(false) end
    if not window.ready() then return fail(window.error()) end
    local renderer = UIRenderer.create(null,64)
    local document = UI.document(root)
    local windowInput = UI.connect_graphics_input(window,document)
    local logicalSize = LSG.window_size()
    local cursor = LSG.cursor()
    local mouseDown = false

    while window.running() do
        logicalSize.refresh(window)
        document.resize(window.width,window.height)
        window.cursor_position(cursor)
        document.pointer_move_scaled(cursor.x,cursor.y,logicalSize.width,logicalSize.height)
        local pressed = window.is_mouse_down(LSG.Mouse.Left)
        if pressed and not mouseDown then document.pointer_down_button(LSG.Mouse.Left) end
        if not pressed and mouseDown then document.pointer_up_button(LSG.Mouse.Left) end
        mouseDown = pressed
        document.resize(window.width,window.height)
        window.begin(0.02,0.025,0.035)
        renderer.begin(window.width,window.height)
        renderer.submit(root)
        renderer.flush()
        window.end()
    end

    windowInput.destroy()
    cursor.destroy()
    logicalSize.destroy()
    document.destroy()
    props.destroy()
    renderer.destroy()
    window.destroy()
    return 0
end

fn fail(message) return LSG.show_error(message) end
