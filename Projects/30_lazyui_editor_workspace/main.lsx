    hover = { background = "#263750" }
    selected = { background = "#35557e" }
}
lscss .indent-1 = { padding_left = "20px" }
lscss .indent-2 = { padding_left = "34px" }
lscss .scene = {
    flex_grow = 1
    min_height = "0px"
    background = "#090e15"
    border = "1px #2e3d54"
    border_radius = "5px"
    overflow = "hidden"
}
lscss .scene-grid = {
    background = "linear-gradient(135deg, #19253a, #0c111a)"
    border = "1px #415a80"
    border_radius = "12px"
}
lscss .bottom = {
    height = "216px"
    min_height = "0px"
    flex_direction = "row"
    gap = "4px"
}
lscss .project = { flex_grow = 1; min_width = "0px"; min_height = "0px" }
lscss .console = { width = "39%"; min_height = "0px" }
lscss .asset-scroll = {
    flex_grow = 1
    min_height = "0px"
    padding = "7px 20px 7px 7px"
    overflow_x = "hidden"
    overflow_y = "scroll"
}
lscss .asset-grid = {
    display = "grid"
    grid_columns = 4
    gap = "7px"
    flex_shrink = 0
}
lscss thumbnail = {
    height = "74px"
    flex_shrink = 0
    padding = "9px"
    background = "#1a2535"
    border = "1px #344963"
    border_radius = "7px"
    text_align = "center"
    hover = { border = "1px #6b91c9"; background = "#263750" }
}
lscss .console-list = {
    flex_grow = 1
    min_height = "0px"
    padding_right = "20px"
