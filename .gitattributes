# Keep source and documentation normalized while preserving Windows scripts.
* text=auto

*.bat text eol=crlf
*.ps1 text eol=crlf
*.lsx text eol=lf
*.lssl text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.c text eol=lf
*.h text eol=lf

# Native/runtime and packaged assets must never be rewritten as text.
*.dll -text
*.lib -text
*.exe -text
*.obj -text
*.wasm -text
*.png -text
*.jpg -text
*.jpeg -text
*.wav -text
*.ttf -text
*.otf -text
*.vsix -text
*.zip -text
